                        <label for="checkIn" class="flex items-center text-sm font-bold text-white mb-3">
                            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-sky-400 to-blue-400 flex items-center justify-center mr-2 group-hover:scale-110 transition-transform shadow-lg">
                                <i class="fas fa-calendar-alt text-white text-sm"></i>
                            </div>
                            <span class="bg-gradient-to-r from-sky-200 to-blue-200 bg-clip-text text-transparent">Check-in</span>
                        </label>
                        <input type="date" 
                               id="checkIn" 
                               name="checkIn" 
