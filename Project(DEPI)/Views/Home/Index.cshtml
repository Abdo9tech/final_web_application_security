                               class="w-full px-5 py-4 bg-white/90 backdrop-blur-sm border-2 border-white/30 rounded-xl focus:ring-4 focus:ring-sky-400/50 focus:border-sky-400 transition-all text-gray-900 font-medium shadow-lg hover:shadow-sky-400/30">
                    </div>

                    <!-- Check-out with Gradient Icon -->
                    <div class="group">
                        <label for="checkOut" class="flex items-center text-sm font-bold text-white mb-3">
                            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-purple-400 to-pink-400 flex items-center justify-center mr-2 group-hover:scale-110 transition-transform shadow-lg">
                                <i class="fas fa-calendar-check text-white text-sm"></i>
                            </div>
                            <span class="bg-gradient-to-r from-purple-200 to-pink-200 bg-clip-text text-transparent">Check-out</span>
                        </label>
                        <input type="date" 
                               id="checkOut" 
                               name="checkOut" 
                               min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")"
