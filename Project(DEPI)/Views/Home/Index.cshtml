@model Project_DEPI_.Models.HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<!-- Ultra-Modern Hero Section -->
<section class="relative bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-600 text-white overflow-hidden min-h-screen flex items-center">
    <!-- Animated Gradient Background -->
    <div class="absolute inset-0 holographic-bg opacity-30"></div>
    
    <!-- Floating Orbs -->
    <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-20 left-10 w-72 h-72 bg-gradient-to-br from-emerald-400 to-teal-400 rounded-full filter blur-3xl opacity-40 animate-pulse morph-shape"></div>
        <div class="absolute top-40 right-20 w-96 h-96 bg-gradient-to-br from-sky-400 to-blue-400 rounded-full filter blur-3xl opacity-40 animate-pulse morph-shape" style="animation-delay: 1.5s;"></div>
        <div class="absolute bottom-20 left-1/3 w-80 h-80 bg-gradient-to-br from-amber-400 to-orange-400 rounded-full filter blur-3xl opacity-40 animate-pulse morph-shape" style="animation-delay: 3s;"></div>
        <div class="absolute top-1/2 right-1/4 w-64 h-64 bg-gradient-to-br from-pink-400 to-rose-400 rounded-full filter blur-3xl opacity-40 animate-pulse morph-shape" style="animation-delay: 4.5s;"></div>
    </div>

    <!-- Cyber Grid -->
    <div class="absolute inset-0 cyber-grid opacity-10"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-32 w-full">
        <div class="text-center mb-16">
            <!-- Ultra-Modern Title -->
            <div class="mb-8">
                <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-8xl font-black mb-4 animate-fade-in">
                    <span class="inline-block bg-gradient-to-r from-white via-emerald-200 to-white bg-clip-text text-transparent animate-gradient">
                        Welcome to
                    </span>
                </h1>
                <h2 class="text-6xl sm:text-7xl md:text-8xl lg:text-9xl font-black animate-slide-up">
                    <span class="inline-block bg-gradient-to-r from-emerald-300 via-teal-200 to-cyan-300 bg-clip-text text-transparent neon-text">
                        Bookify
                    </span>
                    <span class="inline-block bg-gradient-to-r from-amber-300 via-orange-200 to-pink-300 bg-clip-text text-transparent neon-text">
                        Hotel
                    </span>
                </h2>
            </div>
            
            <!-- Subtitle with Glow -->
