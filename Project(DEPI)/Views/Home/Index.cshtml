<!-- Featured Rooms -->
<section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
            <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Featured Rooms</h2>
            <p class="text-lg text-gray-600">Discover our most popular accommodations</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @if (Model?.FeaturedRooms != null && Model.FeaturedRooms.Any())
            {
                @foreach (var room in Model.FeaturedRooms.Take(6))
                {
                    <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition-shadow duration-300 group">
                        <!-- Image -->
                        <div class="relative h-64 overflow-hidden">
                            @if (!string.IsNullOrEmpty(room.ImageUrl))
                            {
                                <img src="@room.ImageUrl" 
                                     alt="Room @room.RoomNumber" 
                                     class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                            }
                            else
                            {
                                <div class="w-full h-full bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center">
                                    <i class="fas fa-bed text-6xl text-white opacity-50"></i>
                                </div>
                            }
                            
                            <!-- Price Badge -->
                            <div class="absolute top-4 right-4 bg-white rounded-lg px-4 py-2 shadow-lg">
                                <span class="text-2xl font-bold text-primary-600">$@(room.RoomType?.PricePerNight ?? 199)</span>
                                <span class="text-sm text-gray-600">/night</span>
                            </div>
                            
                            <!-- Favorite Button -->
                            @if (User.Identity?.IsAuthenticated == true)
                            {
                                <button onclick="toggleFavorite(@room.RoomId, this)" 
                                        class="absolute top-4 left-4 w-12 h-12 bg-white hover:bg-gray-50 rounded-full shadow-lg flex items-center justify-center transition-all group">
                                    <i class="far fa-heart text-2xl text-red-500 group-hover:scale-110 transition-transform"></i>
                                </button>
                            }
                        </div>

                        <!-- Content -->
                        <div class="p-6">
                            <div class="flex items-center justify-between mb-3">
                                <span class="inline-block px-3 py-1 bg-emerald-100 text-emerald-700 text-xs font-semibold rounded-full">
                                    @(room.RoomType?.Name ?? "Luxury Room")
                                </span>
                                <span class="text-sm text-gray-500">Floor @room.Floor</span>
                            </div>

                            <h3 class="text-xl font-bold text-gray-900 mb-2">Room @room.RoomNumber</h3>
                            <p class="text-gray-600 mb-4 line-clamp-2">
                                @(room.RoomType?.Description ?? "Experience comfort and luxury in this beautifully designed room.")
                            </p>

                            <!-- Amenities -->
                            <div class="flex flex-wrap gap-3 mb-4 text-sm text-gray-600">
                                <span><i class="fas fa-users text-primary-600 mr-1"></i> 2-4 Guests</span>
                                <span><i class="fas fa-wifi text-emerald-600 mr-1"></i> Free WiFi</span>
                                <span><i class="fas fa-tv text-sky-600 mr-1"></i> Smart TV</span>
                            </div>

                            <!-- Actions -->
                            <div class="flex gap-2">
                                <a asp-controller="Room" asp-action="Details" asp-route-id="@room.RoomId"
                                   class="flex-1 bg-primary-600 hover:bg-primary-700 text-white text-center py-3 rounded-lg font-medium transition-colors">
                                    View Details
                                </a>
                                <a asp-controller="BookNow" asp-action="Index" asp-route-id="@room.RoomId"
                                   class="bg-emerald-600 hover:bg-emerald-700 text-white px-4 py-3 rounded-lg transition-colors">
                                    <i class="fas fa-arrow-right"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-span-full text-center py-12">
                    <i class="fas fa-bed text-6xl text-gray-300 mb-4"></i>
                    <p class="text-xl text-gray-500">No rooms available at the moment</p>
                </div>
            }
        </div>

        <div class="text-center mt-12">
            <a asp-controller="Room" asp-action="Index" 
               class="inline-block bg-gray-900 hover:bg-gray-800 text-white font-bold py-4 px-8 rounded-lg transition-colors">
                View All Rooms
            </a>
        </div>
    </div>
</section>

