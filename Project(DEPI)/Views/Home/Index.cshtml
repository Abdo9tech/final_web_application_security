                        <label for="guests" class="flex items-center text-sm font-bold text-white mb-3">
                            <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-amber-400 to-orange-400 flex items-center justify-center mr-2 group-hover:scale-110 transition-transform shadow-lg">
                                <i class="fas fa-users text-white text-sm"></i>
                            </div>
                            <span class="bg-gradient-to-r from-amber-200 to-orange-200 bg-clip-text text-transparent">Guests</span>
                        </label>
                        <select id="guests" 
                                name="guests" 
                                class="w-full px-5 py-4 bg-white/90 backdrop-blur-sm border-2 border-white/30 rounded-xl focus:ring-4 focus:ring-amber-400/50 focus:border-amber-400 transition-all text-gray-900 font-medium shadow-lg hover:shadow-amber-400/30">
                            <option value="1">1 Guest</option>
                            <option value="2">2 Guests</option>
                            <option value="3">3 Guests</option>
                            <option value="4">4 Guests</option>
                            <option value="5">5+ Guests</option>
