@model Project_DEPI_.Models.HomeViewModel
@{
    ViewData["Title"] = "Home";
}

<!-- Booking.com Style Hero Section -->
<section class="bg-[#003580] pt-12 pb-20 relative overflow-hidden">
    <!-- Decorative background elements -->
    <div class="absolute top-0 right-0 -mt-20 -mr-20 w-96 h-96 bg-blue-500/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 left-0 -mb-20 -ml-20 w-96 h-96 bg-booking-400/10 rounded-full blur-3xl"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="mb-10 text-center md:text-left">
            <h1 class="text-5xl md:text-6xl font-black text-white mb-6 tracking-tight leading-tight">
                Find your next stay
            </h1>
            <p class="text-xl md:text-2xl text-white font-bold max-w-2xl drop-shadow-sm">
                Search deals on hotels, homes, and much more...
            </p>
        </div>

        <!-- Signature Booking.com Search Bar -->
        <div class="relative transform -translate-y-4 md:translate-y-0">
            <form asp-controller="Room" asp-action="Index" method="get" 
                  class="bg-[#febb02] p-1.5 rounded-lg shadow-2xl flex flex-col md:flex-row gap-1 border-4 border-[#febb02]">
                
                <!-- Destination -->
                <div class="flex-1 bg-white rounded-md flex items-center px-4 py-4 group focus-within:ring-2 focus-within:ring-blue-500 transition-all">
                    <i class="fas fa-bed text-gray-400 mr-3 text-lg group-focus-within:text-blue-500 transition-colors"></i>
                    <input type="text" 
                           id="location" 
                           name="location" 
                           placeholder="Where are you going?" 
                           class="w-full text-base font-medium text-gray-950 placeholder-gray-400 focus:outline-none bg-transparent">
                </div>

                <!-- Dates -->
                <div class="md:w-80 bg-white rounded-md flex items-center px-4 py-4 group focus-within:ring-2 focus-within:ring-blue-500 transition-all">
                    <i class="fas fa-calendar text-gray-400 mr-3 text-lg group-focus-within:text-blue-500 transition-colors"></i>
                    <div class="flex items-center text-sm font-bold text-gray-950 w-full">
                        <input type="date" id="checkIn" name="checkIn" 
                               min="@DateTime.Now.ToString("yyyy-MM-dd")"
                               class="focus:outline-none bg-transparent w-full">
                        <span class="mx-2 text-gray-300">—</span>
                        <input type="date" id="checkOut" name="checkOut" 
                               min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")"
                               class="focus:outline-none bg-transparent w-full">
                    </div>
                </div>

                <!-- Guests/Rooms -->
                <div class="md:w-72 bg-white rounded-md flex items-center px-4 py-4 group focus-within:ring-2 focus-within:ring-blue-500 transition-all">
                    <i class="fas fa-user text-gray-400 mr-3 text-lg group-focus-within:text-blue-500 transition-colors"></i>
                    <select id="guests" name="guests" 
                            class="w-full text-sm font-bold text-gray-950 focus:outline-none bg-transparent appearance-none">
                        <option value="1">1 adult · 0 children · 1 room</option>
                        <option value="2">2 adults · 0 children · 1 room</option>
                        <option value="3">3 adults · 0 children · 1 room</option>
                        <option value="4">4 adults · 0 children · 1 room</option>
                    </select>
                </div>

                <!-- Search Button -->
                <button type="submit" 
                        class="bg-blue-600 hover:bg-blue-700 text-white font-black px-10 py-4 rounded-md transition-all text-xl shadow-inner active:scale-95">
                    Search
                </button>
            </form>
        </div>
    </div>
</section>

<!-- Featured Section -->
<section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Trending destinations</h2>
        <p class="text-gray-600 mb-8">Most popular choices for travelers from Manchester</p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <!-- Egypt Card -->
            <div class="relative group cursor-pointer overflow-hidden rounded-lg h-64 shadow-md">
                <img src="https://images.unsplash.com/photo-1572120360610-d971b9d7767c?auto=format&fit=crop&q=80&w=800" 
                     class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="Egypt">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-4 left-4 text-white">
                    <h3 class="text-xl font-bold flex items-center">
                        Sharm El Sheikh
                        <img src="https://flagcdn.com/w20/eg.png" class="ml-2 w-5 h-auto rounded-sm" alt="Egypt Flag">
                    </h3>
                    <p class="text-sm opacity-90">Experience the Red Sea Riviera</p>
                </div>
            </div>

            <!-- London Card -->
            <div class="relative group cursor-pointer overflow-hidden rounded-lg h-64 shadow-md">
                <img src="https://images.unsplash.com/photo-1513635269975-59663e0ac1ad?auto=format&fit=crop&q=80&w=800" 
                     class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="London">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-4 left-4 text-white">
                    <h3 class="text-xl font-bold flex items-center">
                        London
                        <img src="https://flagcdn.com/w20/gb.png" class="ml-2 w-5 h-auto rounded-sm" alt="UK Flag">
                    </h3>
                    <p class="text-sm opacity-90">The historic capital awaits</p>
                </div>
            </div>

            <!-- Dubai Card -->
            <div class="relative group cursor-pointer overflow-hidden rounded-lg h-64 shadow-md">
                <img src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?auto=format&fit=crop&q=80&w=800" 
                     class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="Dubai">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-4 left-4 text-white">
                    <h3 class="text-xl font-bold flex items-center">
                        Dubai
                        <img src="https://flagcdn.com/w20/ae.png" class="ml-2 w-5 h-auto rounded-sm" alt="UAE Flag">
                    </h3>
                    <p class="text-sm opacity-90">Luxury and adventure combined</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Offers Section -->
<section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Offers</h2>
        <p class="text-gray-600 mb-6">Promotions, deals, and special offers for you</p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white border rounded-lg p-6 flex items-center shadow-sm hover:shadow-md transition-shadow">
                <div class="flex-1">
                    <h3 class="text-lg font-bold mb-2">Fly away to your dream holiday</h3>
                    <p class="text-sm text-gray-600 mb-4">Get inspired, compare and book flights with more flexibility</p>
                    <a href="/Room" class="bg-blue-600 text-white px-4 py-2 rounded-sm text-sm font-bold hover:bg-blue-700 transition-colors">Search flights</a>
                </div>
                <div class="ml-6 hidden sm:block">
                    <img src="https://images.unsplash.com/photo-1436491865332-7a61a109c0f3?auto=format&fit=crop&q=80&w=200" class="w-32 h-32 object-cover rounded-lg" alt="Offer">
                </div>
            </div>

            <div class="bg-white border rounded-lg p-6 flex items-center shadow-sm hover:shadow-md transition-shadow">
                <div class="flex-1">
                    <h3 class="text-lg font-bold mb-2">Seize the moment</h3>
                    <p class="text-sm text-gray-600 mb-4">Save 15% or more when you book and stay before 1 October 2024</p>
                    <a href="/Room" class="bg-blue-600 text-white px-4 py-2 rounded-sm text-sm font-bold hover:bg-blue-700 transition-colors">Find Getaway Deals</a>
                </div>
                <div class="ml-6 hidden sm:block">
                    <img src="https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&q=80&w=200" class="w-32 h-32 object-cover rounded-lg" alt="Offer">
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Date validation
        document.addEventListener('DOMContentLoaded', function() {
            const checkInInput = document.getElementById('checkIn');
            const checkOutInput = document.getElementById('checkOut');
            
            if (checkInInput && checkOutInput) {
                checkInInput.addEventListener('change', function() {
                    const checkInDate = new Date(this.value);
                    const minCheckOut = new Date(checkInDate);
                    minCheckOut.setDate(minCheckOut.getDate() + 1);
                    checkOutInput.min = minCheckOut.toISOString().split('T')[0];
                    
                    if (checkOutInput.value && new Date(checkOutInput.value) <= checkInDate) {
                        checkOutInput.value = '';
                    }
                });
            }
        });
    </script>
}

