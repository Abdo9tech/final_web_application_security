@model Project_DEPI_.Models.HomeViewModel
@{
    ViewData["Title"] = "Home - Bookify Hotel";
}

@section Styles {
<style>
    /* Hero Section with Beautiful Hotel Background */
    .hero-bookify-bg {
        background: linear-gradient(135deg, rgba(91, 33, 182, 0.85) 0%, rgba(79, 70, 229, 0.85) 50%, rgba(124, 58, 237, 0.85) 100%),
                    url('https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&q=80&w=2000') center/cover;
        min-height: 85vh;
        position: relative;
        overflow: hidden;
        background-attachment: fixed;
    }

    [data-theme="dark"] .hero-bookify-bg {
        background: linear-gradient(135deg, rgba(30, 27, 75, 0.9) 0%, rgba(49, 46, 129, 0.9) 50%, rgba(76, 29, 149, 0.9) 100%),
                    url('https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&q=80&w=2000') center/cover;
        background-attachment: fixed;
    }

    @@media (max-width: 768px) {
        .hero-bookify-bg {
            background-attachment: scroll;
        }
    }
</style>
}

<!-- Hero Section with Background Image -->
<section class="hero-bookify-bg flex items-center">
    <!-- Animated Background Elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute top-20 right-10 w-96 h-96 bg-white/10 rounded-full blur-3xl animate-pulse"></div>
        <div class="absolute bottom-20 left-10 w-80 h-80 bg-white/10 rounded-full blur-3xl" style="animation: pulse 3s ease-in-out infinite; animation-delay: 1s;"></div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full relative z-10">
        <div class="max-w-4xl mx-auto text-center mb-12">
            <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-white mb-6 tracking-tight leading-tight drop-shadow-2xl">
                Your Perfect Stay
                <span class="block bg-gradient-to-r from-pink-300 to-purple-200 bg-clip-text text-transparent">
                    Awaits
                </span>
            </h1>
            <p class="text-xl md:text-2xl text-white font-medium max-w-2xl mx-auto drop-shadow-lg">
                Discover extraordinary accommodations tailored to your journey
            </p>
        </div>

        <!-- Modern Search Card -->
        <div class="max-w-5xl mx-auto">
            <div class="bg-white/95 dark:bg-gray-900/90 backdrop-blur-xl p-6 md:p-8 rounded-2xl shadow-2xl border border-white/20">
                <form asp-controller="Room" asp-action="Index" method="get">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                        <!-- Destination -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">
                                <i class="fas fa-map-marker-alt mr-2 text-purple-600"></i>
                                Destination
                            </label>
                            <input type="text" 
                                   name="location" 
                                   placeholder="Where would you like to go?" 
                                   class="w-full px-4 py-3 rounded-lg border-2 border-gray-200 focus:border-purple-600 focus:ring-2 focus:ring-purple-200 outline-none transition-all text-sm">
                        </div>

                        <!-- Guests -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">
                                <i class="fas fa-users mr-2 text-purple-600"></i>
                                Guests
                            </label>
                            <select name="guests" class="w-full px-4 py-3 rounded-lg border-2 border-gray-200 focus:border-purple-600 focus:ring-2 focus:ring-purple-200 outline-none transition-all text-sm">
                                <option value="1">1 Guest</option>
                                <option value="2">2 Guests</option>
                                <option value="3">3 Guests</option>
                                <option value="4">4 Guests</option>
                                <option value="5">5+ Guests</option>
                            </select>
                        </div>

                        <!-- Check-in -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">
                                <i class="fas fa-calendar-check mr-2 text-purple-600"></i>
                                Check-in
                            </label>
                            <input type="date" 
                                   id="checkIn"
                                   name="checkIn" 
                                   min="@DateTime.Now.ToString("yyyy-MM-dd")"
                                   class="w-full px-4 py-3 rounded-lg border-2 border-gray-200 focus:border-purple-600 focus:ring-2 focus:ring-purple-200 outline-none transition-all text-sm">
                        </div>

                        <!-- Check-out -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-900 dark:text-white mb-2">
                                <i class="fas fa-calendar-times mr-2 text-purple-600"></i>
                                Check-out
                            </label>
                            <input type="date" 
                                   id="checkOut"
                                   name="checkOut" 
                                   min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")"
                                   class="w-full px-4 py-3 rounded-lg border-2 border-gray-200 focus:border-purple-600 focus:ring-2 focus:ring-purple-200 outline-none transition-all text-sm">
                        </div>
                    </div>

                    <!-- Search Button -->
                    <button type="submit" class="btn-bookify w-full text-base py-4 group">
                        <span>Search Available Rooms</span>
                        <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform"></i>
                    </button>
                </form>
            </div>
        </div>
    </div>
</section>

<!-- Featured Section -->
<section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-6">Trending destinations</h2>
        <p class="text-gray-600 mb-8">Most popular choices for travelers from Manchester</p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            <!-- Egypt Card -->
            <div class="relative group cursor-pointer overflow-hidden rounded-lg h-64 shadow-md">
                <img src="https://images.unsplash.com/photo-1572120360610-d971b9d7767c?auto=format&fit=crop&q=80&w=800" 
                     class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="Egypt">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-4 left-4 text-white">
                    <h3 class="text-xl font-bold flex items-center">
                        Sharm El Sheikh
                        <img src="https://flagcdn.com/w20/eg.png" class="ml-2 w-5 h-auto rounded-sm" alt="Egypt Flag">
                    </h3>
                    <p class="text-sm opacity-90">Experience the Red Sea Riviera</p>
                </div>
            </div>

            <!-- London Card -->
            <div class="relative group cursor-pointer overflow-hidden rounded-lg h-64 shadow-md">
                <img src="https://images.unsplash.com/photo-1513635269975-59663e0ac1ad?auto=format&fit=crop&q=80&w=800" 
                     class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="London">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-4 left-4 text-white">
                    <h3 class="text-xl font-bold flex items-center">
                        London
                        <img src="https://flagcdn.com/w20/gb.png" class="ml-2 w-5 h-auto rounded-sm" alt="UK Flag">
                    </h3>
                    <p class="text-sm opacity-90">The historic capital awaits</p>
                </div>
            </div>

            <!-- Dubai Card -->
            <div class="relative group cursor-pointer overflow-hidden rounded-lg h-64 shadow-md">
                <img src="https://images.unsplash.com/photo-1512453979798-5ea266f8880c?auto=format&fit=crop&q=80&w=800" 
                     class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="Dubai">
                <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                <div class="absolute bottom-4 left-4 text-white">
                    <h3 class="text-xl font-bold flex items-center">
                        Dubai
                        <img src="https://flagcdn.com/w20/ae.png" class="ml-2 w-5 h-auto rounded-sm" alt="UAE Flag">
                    </h3>
                    <p class="text-sm opacity-90">Luxury and adventure combined</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Offers Section -->
<section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-2xl font-bold text-gray-900 mb-2">Offers</h2>
        <p class="text-gray-600 mb-6">Promotions, deals, and special offers for you</p>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="bg-white border rounded-lg p-6 flex items-center shadow-sm hover:shadow-md transition-shadow">
                <div class="flex-1">
                    <h3 class="text-lg font-bold mb-2">Fly away to your dream holiday</h3>
                    <p class="text-sm text-gray-600 mb-4">Get inspired, compare and book flights with more flexibility</p>
                    <a href="/Room" class="btn-bookify text-sm">Search flights</a>
                </div>
                <div class="ml-6 hidden sm:block">
                    <img src="https://images.unsplash.com/photo-1436491865332-7a61a109c0f3?auto=format&fit=crop&q=80&w=200" class="w-32 h-32 object-cover rounded-lg" alt="Offer">
                </div>
            </div>

            <div class="bg-white border rounded-lg p-6 flex items-center shadow-sm hover:shadow-md transition-shadow">
                <div class="flex-1">
                    <h3 class="text-lg font-bold mb-2">Seize the moment</h3>
                    <p class="text-sm text-gray-600 mb-4">Save 15% or more when you book and stay before 1 October 2024</p>
                    <a href="/Room" class="btn-bookify text-sm">Find Getaway Deals</a>
                </div>
                <div class="ml-6 hidden sm:block">
                    <img src="https://images.unsplash.com/photo-1542314831-068cd1dbfeeb?auto=format&fit=crop&q=80&w=200" class="w-32 h-32 object-cover rounded-lg" alt="Offer">
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Date validation
        document.addEventListener('DOMContentLoaded', function() {
            const checkInInput = document.getElementById('checkIn');
            const checkOutInput = document.getElementById('checkOut');
            
            if (checkInInput && checkOutInput) {
                checkInInput.addEventListener('change', function() {
                    const checkInDate = new Date(this.value);
                    const minCheckOut = new Date(checkInDate);
                    minCheckOut.setDate(minCheckOut.getDate() + 1);
                    checkOutInput.min = minCheckOut.toISOString().split('T')[0];
                    
                    if (checkOutInput.value && new Date(checkOutInput.value) <= checkInDate) {
                        checkOutInput.value = '';
                    }
                });
            }
        });
    </script>
}

