@model List<BookifyHotel.Model.Room>
@{
    ViewData["Title"] = "Available Rooms";
}

<!-- Modern Bookify Hero Section -->
<div class="bg-gradient-hero py-16 relative overflow-hidden border-b border-white/10">
    <!-- Background Pattern -->
    <div class="absolute inset-0 opacity-10">
        <div class="absolute inset-0" style="background-image: url('data:image/svg+xml,%3Csvg width="60" height="60" viewBox="0 0 60 60" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="none" fill-rule="evenodd"%3E%3Cg fill="%23ffffff" fill-opacity="0.4"%3E%3Cpath d="M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z"/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    </div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="text-center">
            <h1 class="text-4xl md:text-5xl font-black text-white mb-4 tracking-tight">
                Available Rooms
            </h1>
            <p class="text-xl text-white font-bold max-w-3xl mx-auto drop-shadow-sm">
                Discover our carefully curated selection of rooms designed for your comfort and convenience
            </p>
        </div>
    </div>
</div>

<!-- Modern Bookify Search Section -->
<div class="bg-gradient-primary py-4 shadow-md -mt-8 relative z-20 mx-4 lg:mx-auto max-w-7xl rounded-md">
    <div class="px-4">
        <form asp-action="Index" method="get" class="flex flex-col md:flex-row gap-1">
            <div class="flex-1 bg-white rounded-sm flex items-center px-3 py-2 border border-transparent focus-within:border-bookify-600">
                <i class="fas fa-bed text-gray-400 mr-2 text-sm"></i>
                <input type="text" name="location" value="@Context.Request.Query["location"]" 
                       placeholder="Where are you going?" 
                       class="w-full text-sm text-gray-900 placeholder-gray-500 focus:outline-none bg-transparent">
            </div>
            
            <div class="md:w-64 bg-white rounded-sm flex items-center px-3 py-2 border border-transparent focus-within:border-bookify-600">
                <i class="fas fa-calendar text-gray-400 mr-2 text-sm"></i>
                <div class="flex items-center text-xs text-gray-500 w-full">
                    <input type="date" name="checkIn" value="@Context.Request.Query["checkIn"]"
                           class="focus:outline-none bg-transparent w-full">
                    <span class="mx-1">—</span>
                    <input type="date" name="checkOut" value="@Context.Request.Query["checkOut"]"
                           class="focus:outline-none bg-transparent w-full">
                </div>
            </div>
            
            <div class="md:w-48 bg-white rounded-sm flex items-center px-3 py-2 border border-transparent focus-within:border-bookify-600">
                <i class="fas fa-user text-gray-400 mr-2 text-sm"></i>
                <select name="guests" class="w-full text-xs text-gray-900 focus:outline-none bg-transparent appearance-none">
                    <option value="">Guests</option>
                    <option value="1" selected='@(Context.Request.Query["guests"] == "1")'>1 adult</option>
                    <option value="2" selected='@(Context.Request.Query["guests"] == "2")'>2 adults</option>
                    <option value="3" selected='@(Context.Request.Query["guests"] == "3")'>3 adults</option>
                    <option value="4" selected='@(Context.Request.Query["guests"] == "4")'>4 adults</option>
                </select>
            </div>
            
            <button type="submit" 
                    class="btn-bookify text-sm px-8 py-2">
                Search
            </button>
        </form>
    </div>
</div>

<!-- Advanced Filters (Hidden by default) -->
<div id="advancedFilters" class="bg-gray-50 border-b border-gray-200 py-6 hidden">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <div>
                <h3 class="font-semibold text-gray-900 mb-3">Price Range</h3>
                <div class="space-y-2">
                    <input type="number" name="minPrice" placeholder="Min price" 
                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-bookify-500">
                    <input type="number" name="maxPrice" placeholder="Max price" 
                           class="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-2 focus:ring-bookify-500">
                </div>
            </div>
            
            <div>
                <h3 class="font-semibold text-gray-900 mb-3">Room Type</h3>
                <div class="space-y-2">
                    <label class="flex items-center">
                        <input type="checkbox" name="roomType" value="standard" class="mr-2 text-bookify-500 focus:ring-bookify-500">
                        <span class="text-gray-700">Standard Room</span>
                    </label>
                    <label class="flex items-center">
                        <input type="checkbox" name="roomType" value="deluxe" class="mr-2 text-bookify-500 focus:ring-bookify-500">
                        <span class="text-gray-700">Deluxe Room</span>
                    </label>
                    <label class="flex items-center">
                        <input type="checkbox" name="roomType" value="suite" class="mr-2 text-bookify-500 focus:ring-bookify-500">
                        <span class="text-gray-700">Suite</span>
                    </label>
                </div>
            </div>
            
            <div>
                <h3 class="font-semibold text-gray-900 mb-3">Amenities</h3>
                <div class="space-y-2">
                    <label class="flex items-center">
                        <input type="checkbox" name="wifi" class="mr-2 text-bookify-500 focus:ring-bookify-500">
                        <span class="text-gray-700">Free WiFi</span>
                    </label>
                    <label class="flex items-center">
                        <input type="checkbox" name="breakfast" class="mr-2 text-bookify-500 focus:ring-bookify-500">
                        <span class="text-gray-700">Breakfast Included</span>
                    </label>
                    <label class="flex items-center">
                        <input type="checkbox" name="parking" class="mr-2 text-bookify-500 focus:ring-bookify-500">
                        <span class="text-gray-700">Free Parking</span>
                    </label>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Results Section with Sidebar -->
<div class="py-6 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex flex-col lg:flex-row gap-6">
            
            <!-- Sidebar Filters -->
            <aside class="lg:w-72 flex-shrink-0">
                <!-- Search/Filter Map Placeholder -->
                <div class="bg-white border rounded-md p-4 mb-4 shadow-sm cursor-pointer hover:bg-gray-50 flex items-center justify-center space-x-2">
                    <i class="fas fa-map-marked-alt text-blue-600 text-lg"></i>
                    <span class="text-blue-600 font-bold text-sm">Show on map</span>
                </div>

                <form id="filterForm" method="get" asp-action="Index" class="bg-white border rounded-md shadow-sm overflow-hidden">
                    <div class="p-4 border-b">
                        <h3 class="font-bold text-sm text-gray-900">Filter by:</h3>
                    </div>

                    <!-- Filter Groups -->
                    <div class="p-4 border-b space-y-3">
                        <h4 class="text-sm font-bold text-gray-900">Your budget (per night)</h4>
                        <div class="space-y-2">
                            <label class="flex items-center text-xs text-gray-900 cursor-pointer hover:text-blue-600">
                                <input type="checkbox" name="budget" value="0-50" class="rounded-sm border-gray-300 text-blue-600 mr-2" onchange="this.form.submit()" @(Context.Request.Query["budget"].Contains("0-50") ? "checked" : "")>
                                <span>$0 – $50</span>
                                <span class="ml-auto text-gray-400">12</span>
                            </label>
                            <label class="flex items-center text-xs text-gray-900 cursor-pointer hover:text-blue-600">
                                <input type="checkbox" name="budget" value="50-100" class="rounded-sm border-gray-300 text-blue-600 mr-2" onchange="this.form.submit()" @(Context.Request.Query["budget"].Contains("50-100") ? "checked" : "")>
                                <span>$50 – $100</span>
                                <span class="ml-auto text-gray-400">45</span>
                            </label>
                            <label class="flex items-center text-xs text-gray-900 cursor-pointer hover:text-blue-600">
                                <input type="checkbox" name="budget" value="100-150" class="rounded-sm border-gray-300 text-blue-600 mr-2" onchange="this.form.submit()" @(Context.Request.Query["budget"].Contains("100-150") ? "checked" : "")>
                                <span>$100 – $150</span>
                                <span class="ml-auto text-gray-400">28</span>
                            </label>
                        </div>
                    </div>

                    <div class="p-4 border-b space-y-3">
                        <h4 class="text-sm font-bold text-gray-900">Popular filters</h4>
                        <div class="space-y-2">
                            <label class="flex items-center text-xs text-gray-900 cursor-pointer hover:text-blue-600">
                                <input type="checkbox" name="amenity" value="breakfast" class="rounded-sm border-gray-300 text-blue-600 mr-2" onchange="this.form.submit()" @(Context.Request.Query["amenity"].Contains("breakfast") ? "checked" : "")>
                                <span>Breakfast Included</span>
                            </label>
                            <label class="flex items-center text-xs text-gray-900 cursor-pointer hover:text-blue-600">
                                <input type="checkbox" name="amenity" value="wifi" class="rounded-sm border-gray-300 text-blue-600 mr-2" onchange="this.form.submit()" @(Context.Request.Query["amenity"].Contains("wifi") ? "checked" : "")>
                                <span>Free WiFi</span>
                            </label>
                            <label class="flex items-center text-xs text-gray-900 cursor-pointer hover:text-blue-600">
                                <input type="checkbox" name="amenity" value="pool" class="rounded-sm border-gray-300 text-blue-600 mr-2" onchange="this.form.submit()" @(Context.Request.Query["amenity"].Contains("pool") ? "checked" : "")>
                                <span>Pool</span>
                            </label>
                        </div>
                    </div>

                    <div class="p-4 space-y-3">
                        <h4 class="text-sm font-bold text-gray-900">Star rating</h4>
                        <div class="space-y-2">
                            <label class="flex items-center text-xs text-gray-900 cursor-pointer hover:text-blue-600">
                                <input type="checkbox" name="stars" value="5" class="rounded-sm border-gray-300 text-blue-600 mr-2" onchange="this.form.submit()">
                                <span class="font-medium text-gray-900">5 stars</span>
                            </label>
                            <label class="flex items-center text-xs text-gray-900 cursor-pointer hover:text-blue-600">
                                <input type="checkbox" name="stars" value="4" class="rounded-sm border-gray-300 text-blue-600 mr-2" onchange="this.form.submit()">
                                <span class="font-medium text-gray-900">4 stars</span>
                            </label>
                            <label class="flex items-center text-xs text-gray-900 cursor-pointer hover:text-blue-600">
                                <input type="checkbox" name="stars" value="3" class="rounded-sm border-gray-300 text-blue-600 mr-2" onchange="this.form.submit()">
                                <span class="font-medium text-gray-900">3 stars</span>
                            </label>
                        </div>
                    </div>
                    
                    <!-- Preserve existing search params -->
                    <input type="hidden" name="location" value="@Context.Request.Query["location"]">
                    <input type="hidden" name="checkIn" value="@Context.Request.Query["checkIn"]">
                    <input type="hidden" name="checkOut" value="@Context.Request.Query["checkOut"]">
                    <input type="hidden" name="guests" value="@Context.Request.Query["guests"]">
                </form>
            </aside>

            <!-- Property List -->
            <div class="flex-1">
                @if (Model != null && Model.Any())
                {
                    <div class="mb-4">
                        <h2 class="text-xl font-bold text-gray-900">
                            @if (!string.IsNullOrEmpty(Context.Request.Query["location"]))
                            {
                                <span>@Context.Request.Query["location"]: @Model.Count properties found</span>
                            }
                            else
                            {
                                <span>@Model.Count properties found</span>
                            }
                        </h2>
                    </div>

                    <div class="space-y-4">
                        @foreach (var room in Model)
                        {
                            <div class="bg-white border rounded-lg overflow-hidden flex flex-col md:flex-row shadow-sm hover:shadow-md transition-shadow p-4 gap-4">
                                <!-- Property Image -->
                                <div class="w-full md:w-64 h-52 flex-shrink-0 relative">
                                    <img src="@(string.IsNullOrEmpty(room.ImageUrl) ? "https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&q=80&w=800" : room.ImageUrl)" 
                                         class="w-full h-full object-cover rounded-md" alt="Room @room.RoomNumber">
                                    
                                    <!-- Favorite -->
                                    <button onclick="toggleFavorite('@room.RoomId', this)" class="absolute top-2 right-2 p-2 bg-white/80 rounded-full hover:bg-white transition-colors">
                                        <i class="far fa-heart text-blue-600"></i>
                                    </button>
                                </div>

                                <!-- Property Content -->
                                <div class="flex-1 flex flex-col justify-between">
                                    <div>
                                        <div class="flex justify-between items-start mb-2">
                                            <div>
                                                <h3 class="text-xl font-bold text-blue-600 hover:text-orange-700 cursor-pointer">
                                                    Room @room.RoomNumber - @(room.RoomType?.Name ?? "Standard Room")
                                                </h3>
                                                <div class="flex items-center text-xs text-blue-600 underline mt-1 cursor-pointer">
                                                    Manchester, City Centre • Show on map
                                                </div>
                                            </div>
                                            <div class="flex flex-col items-end">
                                                <div class="flex items-center space-x-2">
                                                    <div class="text-right">
                                                        <div class="text-sm font-bold text-gray-900">Exceptional</div>
                                                        <div class="text-[10px] text-gray-500">1,234 reviews</div>
                                                    </div>
                                                    <div class="w-8 h-8 bg-bookify-900 rounded-tr-lg rounded-bl-lg rounded-tl-lg flex items-center justify-center text-white font-bold text-sm">
                                                        9.5
                                                    </div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="text-xs text-gray-700 space-y-1 mb-4">
                                            <div class="flex items-center">
                                                <span class="font-bold mr-2 text-green-700">Free cancellation</span>
                                                <span class="text-gray-500">• No prepayment needed</span>
                                            </div>
                                            <div class="text-gray-600">@(room.RoomType?.Description ?? "Experience luxury and comfort in our modern rooms.")</div>
                                            <div class="flex items-center text-green-700 font-bold">
                                                <i class="fas fa-check mr-2"></i>
                                                Only 2 rooms left at this price on our site
                                            </div>
                                        </div>
                                    </div>

                                    <div class="flex justify-end items-end">
                                        <div class="text-right">
                                            <div class="text-[10px] text-gray-500">1 night, 2 adults</div>
                                            <div class="text-2xl font-bold text-gray-900">US$@(room.RoomType?.PricePerNight ?? 0)</div>
                                            <div class="text-[10px] text-gray-500 mb-2">+US$22 taxes and charges</div>
                                            <a asp-action="Details" asp-route-id="@room.RoomId" 
                                               class="btn-bookify text-sm py-2.5 px-4">
                                                See availability <i class="fas fa-chevron-right ml-1 text-[10px]"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="text-center py-20 bg-white border rounded-lg">
                        <div class="w-24 h-24 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
                            <i class="fas fa-search text-gray-400 text-3xl"></i>
                        </div>
                        <h3 class="text-2xl font-bold text-gray-900 mb-3">No properties found</h3>
                        <p class="text-gray-600 mb-8 max-w-md mx-auto">
                            We couldn't find any rooms matching your criteria.
                        </p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        // Load favorite states on page load
        document.addEventListener('DOMContentLoaded', async () => {
            if (!@(User.Identity?.IsAuthenticated == true ? "true" : "false")) return;

            try {
                // We'll fetch the favorites from the Index endpoint of FavoriteController 
                // but since it returns a View, we might need a JSON endpoint.
                // For now, let's assume we can't easily fetch it without a dedicated API.
                // As a fallback, the heart will toggle normally when clicked.
            } catch (e) {}
        });

        async function toggleFavorite(roomId, button) {
            if (!@(User.Identity?.IsAuthenticated == true ? "true" : "false")) {
                window.location.href = '/Login/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                return;
            }

            try {
                const response = await fetch('/Favorite/Toggle', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify(roomId)
                });

                const result = await response.json();
                
                if (result.success) {
                    const icon = button.querySelector('i');
                    if (result.action === 'added') {
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                        // Show success message
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'success',
                                title: 'Added to Favorites!',
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000
                            });
                        }
                    } else {
                        icon.classList.remove('fas');
                        icon.classList.add('far');
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'info',
                                title: 'Removed from Favorites',
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000
                            });
                        }
                    }
                }
            } catch (error) {
                console.error('Error toggling favorite:', error);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Failed to update favorites. Please try again.',
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 3000
                    });
                }
            }
        }
    </script>
}
