@model List<BookifyHotel.Model.Room>
@{
    ViewData["Title"] = "Available Rooms";
}

<!-- Hero Section -->
<div class="relative bg-gradient-to-br from-indigo-600 via-purple-600 to-pink-500 text-white py-20">
    <div class="absolute inset-0 bg-black/20"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">Discover Your Perfect Room</h1>
        <p class="text-xl text-indigo-100 max-w-2xl mx-auto">Luxury accommodations designed for your comfort</p>
    </div>
</div>

<!-- Search Filters -->
<div class="bg-white shadow-md -mt-8 relative z-10 max-w-7xl mx-auto rounded-xl p-6 mb-12" x-data="{ showAdvanced: false }">
    <form asp-action="Index" method="get">
        <!-- Basic Search -->
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4 mb-4">
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    <i class="fas fa-map-marker-alt text-emerald-500 mr-1"></i>Location
                </label>
                <input type="text" name="location" value="@Context.Request.Query["location"]" placeholder="City or Hotel" 
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    <i class="fas fa-calendar-check text-sky-500 mr-1"></i>Check-in
                </label>
                <input type="date" name="checkIn" value="@Context.Request.Query["checkIn"]"
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    <i class="fas fa-calendar-times text-purple-500 mr-1"></i>Check-out
                </label>
                <input type="date" name="checkOut" value="@Context.Request.Query["checkOut"]"
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
            </div>
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-2">
                    <i class="fas fa-users text-amber-500 mr-1"></i>Guests
                </label>
                <input type="number" name="guests" value="@Context.Request.Query["guests"]" min="1" placeholder="Number of guests"
                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
            </div>
        </div>

        <!-- Advanced Filters Toggle -->
        <div class="flex items-center justify-between mb-4">
            <button type="button" @@click="showAdvanced = !showAdvanced" 
                    class="flex items-center gap-2 text-indigo-600 hover:text-indigo-700 font-medium transition">
                <i class="fas fa-sliders-h"></i>
                <span x-text="showAdvanced ? 'Hide Advanced Filters' : 'Show Advanced Filters'"></span>
                <i class="fas fa-chevron-down transition-transform duration-300" :class="showAdvanced ? 'rotate-180' : ''"></i>
            </button>
            <div class="flex gap-2">
                <button type="button" onclick="clearFilters()" 
                        class="px-4 py-2 text-gray-600 hover:text-gray-800 font-medium transition">
                    <i class="fas fa-times-circle mr-1"></i>Clear Filters
                </button>
                <button type="submit" class="bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-semibold py-2 px-8 rounded-lg transition duration-200 shadow-lg hover:shadow-xl">
                    <i class="fas fa-search mr-2"></i>Search Rooms
                </button>
            </div>
        </div>

        <!-- Advanced Filters Panel -->
        <div x-show="showAdvanced" 
             x-transition:enter="transition ease-out duration-300"
             x-transition:enter-start="opacity-0 transform -translate-y-2"
             x-transition:enter-end="opacity-100 transform translate-y-0"
             x-transition:leave="transition ease-in duration-200"
             x-transition:leave-start="opacity-100 transform translate-y-0"
             x-transition:leave-end="opacity-0 transform -translate-y-2"
             class="bg-gradient-to-br from-indigo-50 to-purple-50 rounded-xl p-6 border-2 border-indigo-100">
            <h3 class="text-lg font-bold text-gray-800 mb-4 flex items-center gap-2">
                <i class="fas fa-filter text-indigo-600"></i>
                Advanced Filters
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                <!-- Room Type Filter -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class="fas fa-bed text-indigo-500 mr-1"></i>Room Type
                    </label>
                    <select name="roomTypeId" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white">
                        <option value="">All Types</option>
                        @if (ViewBag.RoomTypes != null)
                        {
                            @foreach (var type in ViewBag.RoomTypes)
                            {
                                <option value="@type.RoomTypeId" selected="@(Context.Request.Query["roomTypeId"] == type.RoomTypeId.ToString())">
                                    @type.Name
                                </option>
                            }
                        }
                    </select>
                </div>

                <!-- Floor Filter -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class="fas fa-building text-emerald-500 mr-1"></i>Floor
                    </label>
                    <select name="floor" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white">
                        <option value="">All Floors</option>
                        <option value="1" selected="@(Context.Request.Query["floor"] == "1")">Floor 1</option>
                        <option value="2" selected="@(Context.Request.Query["floor"] == "2")">Floor 2</option>
                        <option value="3" selected="@(Context.Request.Query["floor"] == "3")">Floor 3</option>
                        <option value="4" selected="@(Context.Request.Query["floor"] == "4")">Floor 4</option>
                        <option value="5" selected="@(Context.Request.Query["floor"] == "5")">Floor 5</option>
                    </select>
                </div>

                <!-- Price Range Filter -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class="fas fa-dollar-sign text-amber-500 mr-1"></i>Min Price
                    </label>
                    <input type="number" name="minPrice" value="@Context.Request.Query["minPrice"]" min="0" placeholder="Min $" 
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class="fas fa-dollar-sign text-amber-500 mr-1"></i>Max Price
                    </label>
                    <input type="number" name="maxPrice" value="@Context.Request.Query["maxPrice"]" min="0" placeholder="Max $" 
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                </div>

                <!-- Availability Filter -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class="fas fa-check-circle text-emerald-500 mr-1"></i>Availability
                    </label>
                    <select name="isAvailable" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white">
                        <option value="">All Rooms</option>
                        <option value="true" selected="@(Context.Request.Query["isAvailable"] == "true")">Available Only</option>
                        <option value="false" selected="@(Context.Request.Query["isAvailable"] == "false")">Booked Only</option>
                    </select>
                </div>

                <!-- Status Filter -->
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">
                        <i class="fas fa-info-circle text-sky-500 mr-1"></i>Status
                    </label>
                    <select name="status" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent bg-white">
                        <option value="">All Status</option>
                        <option value="Available" selected="@(Context.Request.Query["status"] == "Available")">Available</option>
                        <option value="Occupied" selected="@(Context.Request.Query["status"] == "Occupied")">Occupied</option>
                        <option value="Maintenance" selected="@(Context.Request.Query["status"] == "Maintenance")">Maintenance</option>
                        <option value="Cleaning" selected="@(Context.Request.Query["status"] == "Cleaning")">Cleaning</option>
                    </select>
                </div>
            </div>
        </div>
    </form>
</div>

<script>
    function clearFilters() {
        window.location.href = '@Url.Action("Index", "Room")';
    }
</script>

<!-- Filter Results Summary -->
@{
    var hasFilters = !string.IsNullOrEmpty(Context.Request.Query["location"]) ||
                     !string.IsNullOrEmpty(Context.Request.Query["checkIn"]) ||
                     !string.IsNullOrEmpty(Context.Request.Query["checkOut"]) ||
                     !string.IsNullOrEmpty(Context.Request.Query["guests"]) ||
                     !string.IsNullOrEmpty(Context.Request.Query["roomTypeId"]) ||
                     !string.IsNullOrEmpty(Context.Request.Query["floor"]) ||
                     !string.IsNullOrEmpty(Context.Request.Query["minPrice"]) ||
                     !string.IsNullOrEmpty(Context.Request.Query["maxPrice"]) ||
                     !string.IsNullOrEmpty(Context.Request.Query["isAvailable"]) ||
                     !string.IsNullOrEmpty(Context.Request.Query["status"]);
}

@if (hasFilters)
{
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-6">
        <div class="bg-gradient-to-r from-indigo-50 to-purple-50 border-l-4 border-indigo-500 rounded-lg p-4 flex items-center justify-between">
            <div class="flex items-center gap-3">
                <i class="fas fa-filter text-indigo-600 text-xl"></i>
                <div>
                    <p class="font-semibold text-gray-800">
                        Found @(Model?.Count ?? 0) room@(Model?.Count != 1 ? "s" : "") matching your filters
                    </p>
                    <div class="flex flex-wrap gap-2 mt-2">
                        @if (!string.IsNullOrEmpty(Context.Request.Query["location"]))
                        {
                            <span class="inline-flex items-center gap-1 px-3 py-1 bg-white rounded-full text-sm text-gray-700 border border-indigo-200">
                                <i class="fas fa-map-marker-alt text-emerald-500"></i>
                                @Context.Request.Query["location"]
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(Context.Request.Query["roomTypeId"]))
                        {
                            var roomTypeIdStr = Context.Request.Query["roomTypeId"].ToString();
                            var roomTypes = ViewBag.RoomTypes as IEnumerable<BookifyHotel.Model.RoomType>;
                            var selectedType = roomTypes?.FirstOrDefault(t => t.RoomTypeId.ToString() == roomTypeIdStr);
                            if (selectedType != null)
                            {
                                <span class="inline-flex items-center gap-1 px-3 py-1 bg-white rounded-full text-sm text-gray-700 border border-indigo-200">
                                    <i class="fas fa-bed text-indigo-500"></i>
                                    @selectedType.Name
                                </span>
                            }
                        }
                        @if (!string.IsNullOrEmpty(Context.Request.Query["floor"]))
                        {
                            <span class="inline-flex items-center gap-1 px-3 py-1 bg-white rounded-full text-sm text-gray-700 border border-indigo-200">
                                <i class="fas fa-building text-emerald-500"></i>
                                Floor @Context.Request.Query["floor"]
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(Context.Request.Query["minPrice"]) || !string.IsNullOrEmpty(Context.Request.Query["maxPrice"]))
                        {
                            <span class="inline-flex items-center gap-1 px-3 py-1 bg-white rounded-full text-sm text-gray-700 border border-indigo-200">
                                <i class="fas fa-dollar-sign text-amber-500"></i>
                                $@(Context.Request.Query["minPrice"]) - $@(Context.Request.Query["maxPrice"])
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(Context.Request.Query["isAvailable"]))
                        {
                            <span class="inline-flex items-center gap-1 px-3 py-1 bg-white rounded-full text-sm text-gray-700 border border-indigo-200">
                                <i class="fas fa-check-circle text-emerald-500"></i>
                                @(Context.Request.Query["isAvailable"] == "true" ? "Available" : "Booked")
                            </span>
                        }
                        @if (!string.IsNullOrEmpty(Context.Request.Query["status"]))
                        {
                            <span class="inline-flex items-center gap-1 px-3 py-1 bg-white rounded-full text-sm text-gray-700 border border-indigo-200">
                                <i class="fas fa-info-circle text-sky-500"></i>
                                @Context.Request.Query["status"]
                            </span>
                        }
                    </div>
                </div>
            </div>
            <button onclick="clearFilters()" class="text-indigo-600 hover:text-indigo-700 font-medium transition">
                <i class="fas fa-times-circle mr-1"></i>Clear All
            </button>
        </div>
    </div>
}

<!-- Rooms Grid -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    @if (Model != null && Model.Any())
    {
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            @foreach (var room in Model)
            {
                <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition duration-300">
                    <div class="relative h-64">
                        <img src="@(room.ImageUrl ?? "/images/default-room.jpg")" 
                             alt="Room @room.RoomNumber" 
                             class="w-full h-full object-cover">
                        @if (room.IsAvailable)
                        {
                            <span class="absolute top-4 right-4 bg-emerald-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                                Available
                            </span>
                        }
                        else
                        {
                            <span class="absolute top-4 right-4 bg-red-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                                Booked
                            </span>
                        }
                        @if (User.Identity.IsAuthenticated)
                        {
                            <button onclick="toggleFavorite(@room.RoomId, this)" class="absolute top-4 left-4 bg-white/90 hover:bg-white p-2 rounded-full transition" title="Add to favorites">
                                <i class="@(ViewBag.FavoriteRoomIds != null && ViewBag.FavoriteRoomIds.Contains(room.RoomId) ? "fas" : "far") fa-heart text-red-500"></i>
                            </button>
                        }
                    </div>
                    <div class="p-6">
                        <div class="flex justify-between items-start mb-3">
                            <h3 class="text-xl font-bold text-gray-900">Room @room.RoomNumber</h3>
                            <span class="text-sm text-gray-500">Floor @room.Floor</span>
                        </div>
                        <p class="text-indigo-600 font-semibold mb-2">@(room.RoomType?.Name ?? "Standard")</p>
                        <p class="text-gray-600 text-sm mb-4">@(room.RoomType?.Description ?? "Comfortable room with modern amenities")</p>
                        <div class="flex items-center justify-between">
                            <div>
                                <span class="text-3xl font-bold text-gray-900">$@(room.RoomType?.PricePerNight ?? 0)</span>
                                <span class="text-gray-500 text-sm">/night</span>
                            </div>
                            <a asp-action="Details" asp-route-id="@room.RoomId" 
                               class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-6 rounded-lg transition duration-200">
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-16">
            <i class="fas fa-bed text-gray-300 text-6xl mb-4"></i>
            <h3 class="text-2xl font-semibold text-gray-700 mb-2">No Rooms Available</h3>
            <p class="text-gray-500">Try adjusting your search criteria</p>
        </div>
    }
</div>


@section Scripts {
    <script>
        async function toggleFavorite(roomId, button) {
            if (!@(User.Identity?.IsAuthenticated == true ? "true" : "false")) {
                window.location.href = '/Login/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                return;
            }

            try {
                const response = await fetch('/Favorite/Toggle', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify(roomId)
                });

                const result = await response.json();
                
                if (result.success) {
                    const icon = button.querySelector('i');
                    if (result.action === 'added') {
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                        // Show success message
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'success',
                                title: 'Added to Favorites!',
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000
                            });
                        }
                    } else {
                        icon.classList.remove('fas');
                        icon.classList.add('far');
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'info',
                                title: 'Removed from Favorites',
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000
                            });
                        }
                    }
                }
            } catch (error) {
                console.error('Error toggling favorite:', error);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Failed to update favorites. Please try again.',
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 3000
                    });
                }
            }
        }
    </script>
}
