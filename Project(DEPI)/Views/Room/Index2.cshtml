@model IEnumerable<BookifyHotel.Model.Room>
@{
    ViewData["Title"] = "Manage Rooms";
}

<div class="bg-gray-50 min-h-screen">
    <!-- Admin Top Bar -->
    <div class="bg-bookify-900 text-white py-3 border-b border-white/10">
        <div class="max-w-7xl mx-auto px-4 flex justify-between items-center">
            <div class="flex items-center space-x-4">
                <span class="text-lg font-bold">Bookify Partners</span>
                <span class="text-xs bg-blue-600 px-2 py-0.5 rounded-sm">Extranet</span>
            </div>
            <div class="flex items-center space-x-6 text-sm">
                <a asp-controller="Home" asp-action="Index" class="hover:underline">View my property</a>
                <div class="flex items-center space-x-2">
                    <div class="w-8 h-8 bg-gray-600 rounded-full flex items-center justify-center text-xs">AD</div>
                    <span>Administrator</span>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 py-8">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Manage Rooms</h1>
            <a asp-action="Add" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-sm text-sm transition-colors shadow-sm">
                <i class="fas fa-plus mr-2"></i>Add new room
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="bg-green-100 border border-green-200 text-green-800 px-4 py-3 rounded-sm mb-6 text-sm flex items-center">
                <i class="fas fa-check-circle mr-2"></i> @TempData["Success"]
            </div>
        }

        <!-- Filter Bar -->
        <div class="bg-white border rounded-sm p-4 mb-6 shadow-sm">
            <form asp-action="Index2" method="get" class="flex flex-wrap gap-4 items-end">
                <div class="flex-1 min-w-[120px]">
                    <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Room Number</label>
                    <input type="number" name="roomNumber" value="@Context.Request.Query["roomNumber"]" 
                           class="w-full px-3 py-1.5 border border-gray-300 rounded-sm text-sm focus:border-blue-600 outline-none">
                </div>
                <div class="flex-1 min-w-[150px]">
                    <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Room Type</label>
                    <select name="roomTypeId" class="w-full px-3 py-1.5 border border-gray-300 rounded-sm text-sm bg-white outline-none">
                        <option value="">All Types</option>
                        @if (ViewBag.RoomTypes != null)
                        {
                            @foreach (var type in ViewBag.RoomTypes)
                            {
                                <option value="@type.RoomTypeId" selected="@(Context.Request.Query["roomTypeId"] == type.RoomTypeId.ToString())">
                                    @type.Name
                                </option>
                            }
                        }
                    </select>
                </div>
                <div class="flex-1 min-w-[120px]">
                    <label class="block text-[10px] font-bold text-gray-500 uppercase mb-1">Status</label>
                    <select name="status" class="w-full px-3 py-1.5 border border-gray-300 rounded-sm text-sm bg-white outline-none">
                        <option value="">All</option>
                        <option value="Available" selected="@(Context.Request.Query["status"] == "Available")">Available</option>
                        <option value="Occupied" selected="@(Context.Request.Query["status"] == "Occupied")">Occupied</option>
                        <option value="Maintenance" selected="@(Context.Request.Query["status"] == "Maintenance")">Maintenance</option>
                    </select>
                </div>
                <div class="flex space-x-2">
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-1.5 px-6 rounded-sm text-sm transition-colors">
                        Filter
                    </button>
                    <a asp-action="Index2" class="bg-gray-100 hover:bg-gray-200 text-gray-600 font-bold py-1.5 px-4 rounded-sm text-sm transition-colors">
                        Reset
                    </a>
                </div>
            </form>
        </div>

        <!-- Rooms Table -->
        <div class="bg-white border rounded-sm shadow-sm overflow-hidden">
            <table class="w-full text-left text-sm">
                <thead class="bg-gray-50 border-b text-gray-500 uppercase text-[10px] font-bold">
                    <tr>
                        <th class="px-6 py-4">Room</th>
                        <th class="px-6 py-4">Type</th>
                        <th class="px-6 py-4">Floor</th>
                        <th class="px-6 py-4">Price/Night</th>
                        <th class="px-6 py-4">Status</th>
                        <th class="px-6 py-4">Availability</th>
                        <th class="px-6 py-4 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y">
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var room in Model)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4">
                                    <div class="flex items-center space-x-3">
                                        <div class="w-10 h-10 flex-shrink-0">
                                            <img src="@(string.IsNullOrEmpty(room.ImageUrl) ? "https://images.unsplash.com/photo-1631049307264-da0ec9d70304?q=80&w=1000&auto=format&fit=crop" : room.ImageUrl)" 
                                                 class="w-full h-full object-cover rounded-sm border" alt="Room">
                                        </div>
                                        <div class="font-bold text-blue-600">Room @room.RoomNumber</div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 text-gray-600 font-medium">@(room.RoomType?.Name ?? "Standard")</td>
                                <td class="px-6 py-4 text-gray-600">@room.Floor</td>
                                <td class="px-6 py-4 font-bold">US$@(room.RoomType?.PricePerNight.ToString("F2") ?? "0.00")</td>
                                <td class="px-6 py-4">
                                    @{
                                        var statusClass = room.Status switch {
                                            "Available" => "bg-green-100 text-green-700",
                                            "Occupied" => "bg-blue-100 text-blue-700",
                                            "Maintenance" => "bg-red-100 text-red-700",
                                            _ => "bg-gray-100 text-gray-700"
                                        };
                                    }
                                    <span class="px-2 py-0.5 rounded-sm text-[10px] font-bold @statusClass">@room.Status</span>
                                </td>
                                <td class="px-6 py-4">
                                    @if (room.IsAvailable)
                                    {
                                        <span class="flex items-center text-green-600 font-bold text-[11px]">
                                            <span class="w-1.5 h-1.5 bg-green-600 rounded-full mr-1.5"></span>
                                            Ready
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="flex items-center text-gray-400 font-bold text-[11px]">
                                            <span class="w-1.5 h-1.5 bg-gray-400 rounded-full mr-1.5"></span>
                                            Booked
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex justify-end space-x-2">
                                        <a asp-action="Edit" asp-route-id="@room.RoomId" class="text-blue-600 hover:bg-blue-50 p-1.5 rounded-sm transition-colors" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@room.RoomId" method="post" onsubmit="return confirm('Delete room @room.RoomNumber?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="text-red-600 hover:bg-red-50 p-1.5 rounded-sm transition-colors" title="Delete">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="px-6 py-12 text-center">
                                <div class="text-gray-400 mb-2"><i class="fas fa-bed text-4xl"></i></div>
                                <div class="text-sm font-bold text-gray-500">No rooms found matching your criteria.</div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
