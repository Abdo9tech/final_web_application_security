@model IEnumerable<BookifyHotel.Model.Room>
@{
    ViewData["Title"] = "Manage Rooms";
}

<div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-4xl font-bold bg-gradient-to-r from-indigo-600 to-purple-600 bg-clip-text text-transparent mb-2">Manage Rooms</h1>
                <p class="text-gray-600 flex items-center gap-2">
                    <i class="fas fa-hotel text-indigo-500"></i>
                    View and manage all hotel rooms
                </p>
            </div>
            <a asp-action="Add" class="group relative bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-bold py-3 px-6 rounded-xl transition-all duration-300 shadow-lg hover:shadow-xl hover:shadow-indigo-500/50 hover:scale-105">
                <i class="fas fa-plus mr-2"></i>Add New Room
            </a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="bg-gradient-to-r from-emerald-50 to-teal-50 border-l-4 border-emerald-500 text-emerald-700 px-6 py-4 rounded-lg mb-6 shadow-md">
                <i class="fas fa-check-circle mr-2"></i>@TempData["Success"]
            </div>
        }

        @if (TempData["Error"] != null)
        {
            <div class="bg-gradient-to-r from-red-50 to-rose-50 border-l-4 border-red-500 text-red-700 px-6 py-4 rounded-lg mb-6 shadow-md">
                <i class="fas fa-exclamation-circle mr-2"></i>@TempData["Error"]
            </div>
        }

        <!-- Simple Search Bar -->
        <div class="bg-white shadow-md rounded-xl p-4 mb-6">
            <form asp-action="Index2" method="get" class="flex flex-wrap gap-3 items-end">
                <!-- Room Number -->
                <div class="flex-1 min-w-[150px]">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Room #</label>
                    <input type="number" name="roomNumber" value="@Context.Request.Query["roomNumber"]" placeholder="Room number" 
                           class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500">
                </div>

                <!-- Room Type -->
                <div class="flex-1 min-w-[150px]">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Type</label>
                    <select name="roomTypeId" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 bg-white">
                        <option value="">All Types</option>
                        @if (ViewBag.RoomTypes != null)
                        {
                            @foreach (var type in ViewBag.RoomTypes)
                            {
                                <option value="@type.RoomTypeId" selected="@(Context.Request.Query["roomTypeId"] == type.RoomTypeId.ToString())">
                                    @type.Name
                                </option>
                            }
                        }
                    </select>
                </div>

                <!-- Floor -->
                <div class="flex-1 min-w-[120px]">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Floor</label>
                    <select name="floor" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 bg-white">
                        <option value="">All</option>
                        <option value="1" selected="@(Context.Request.Query["floor"] == "1")">1</option>
                        <option value="2" selected="@(Context.Request.Query["floor"] == "2")">2</option>
                        <option value="3" selected="@(Context.Request.Query["floor"] == "3")">3</option>
                        <option value="4" selected="@(Context.Request.Query["floor"] == "4")">4</option>
                        <option value="5" selected="@(Context.Request.Query["floor"] == "5")">5</option>
                    </select>
                </div>

                <!-- Status -->
                <div class="flex-1 min-w-[150px]">
                    <label class="block text-sm font-medium text-gray-700 mb-1">Status</label>
                    <select name="status" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 bg-white">
                        <option value="">All</option>
                        <option value="Available" selected="@(Context.Request.Query["status"] == "Available")">Available</option>
                        <option value="Occupied" selected="@(Context.Request.Query["status"] == "Occupied")">Occupied</option>
                        <option value="Maintenance" selected="@(Context.Request.Query["status"] == "Maintenance")">Maintenance</option>
                        <option value="Cleaning" selected="@(Context.Request.Query["status"] == "Cleaning")">Cleaning</option>
                    </select>
                </div>

                <!-- Buttons -->
                <div class="flex gap-2">
                    <button type="submit" class="bg-indigo-600 hover:bg-indigo-700 text-white px-6 py-2 rounded-lg font-medium transition">
                        <i class="fas fa-search mr-1"></i>Search
                    </button>
                    <a href="@Url.Action("Index2", "Room")" class="bg-gray-200 hover:bg-gray-300 text-gray-700 px-4 py-2 rounded-lg font-medium transition">
                        <i class="fas fa-times"></i>
                    </a>
                </div>
            </form>
        </div>

        @{
            var hasFilters = !string.IsNullOrEmpty(Context.Request.Query["roomNumber"]) ||
                             !string.IsNullOrEmpty(Context.Request.Query["roomTypeId"]) ||
                             !string.IsNullOrEmpty(Context.Request.Query["floor"]) ||
                             !string.IsNullOrEmpty(Context.Request.Query["status"]);
        }

        @if (hasFilters)
        {
            <div class="bg-indigo-50 border border-indigo-200 rounded-lg p-3 mb-6 flex items-center justify-between">
                <span class="text-sm text-gray-700">
                    <i class="fas fa-filter text-indigo-600 mr-2"></i>
                    <strong>@(Model?.Count() ?? 0)</strong> room@(Model?.Count() != 1 ? "s" : "") found
                </span>
                <a href="@Url.Action("Index2", "Room")" class="text-indigo-600 hover:text-indigo-700 text-sm font-medium">
                    Clear filters
                </a>
            </div>
        }

        @if (Model != null && Model.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var room in Model)
                {
                    <div class="bg-white rounded-xl shadow-md overflow-hidden hover:shadow-lg transition">
                        <div class="relative h-48">
                            <img src="@(room.ImageUrl ?? "/images/default-room.jpg")" 
                                 alt="Room @room.RoomNumber" 
                                 class="w-full h-full object-cover">
                            
                            @if (room.IsAvailable)
                            {
                                <span class="absolute top-3 right-3 bg-emerald-500 text-white px-3 py-1 rounded-full text-xs font-semibold">
                                    Available
                                </span>
                            }
                            else
                            {
                                <span class="absolute top-3 right-3 bg-red-500 text-white px-3 py-1 rounded-full text-xs font-semibold">
                                    Booked
                                </span>
                            }
                            
                            <span class="absolute top-3 left-3 bg-white/90 text-gray-700 px-3 py-1 rounded-full text-xs font-semibold">
                                @room.Status
                            </span>
                        </div>
                        
                        <div class="p-5">
                            <div class="flex justify-between items-start mb-3">
                                <div>
                                    <h3 class="text-lg font-bold text-gray-900">Room @room.RoomNumber</h3>
                                    <p class="text-sm text-gray-500">Floor @room.Floor</p>
                                </div>
                                <div class="text-right">
                                    <div class="text-xl font-bold text-indigo-600">$@(room.RoomType?.PricePerNight ?? 0)</div>
                                    <span class="text-xs text-gray-500">/night</span>
                                </div>
                            </div>
                            
                            <p class="text-sm text-indigo-600 font-medium mb-4">@(room.RoomType?.Name ?? "Standard")</p>
                            
                            <div class="flex gap-2">
                                <a asp-action="DetailsToAdmin" asp-route-id="@room.RoomId" 
                                   class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-3 rounded-lg transition text-center text-sm">
                                    <i class="fas fa-eye"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@room.RoomId" 
                                   class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-medium py-2 px-3 rounded-lg transition text-center text-sm">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@room.RoomId" method="post" class="flex-1" onsubmit="return confirm('Delete Room @room.RoomNumber?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-medium py-2 px-3 rounded-lg transition text-sm">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-xl shadow-md p-12 text-center">
                <i class="fas fa-bed text-gray-300 text-5xl mb-4"></i>
                <h3 class="text-2xl font-bold text-gray-700 mb-2">No Rooms Found</h3>
                <p class="text-gray-500 mb-6">
                    @if (hasFilters)
                    {
                        <span>No rooms match your filters.</span>
                    }
                    else
                    {
                        <span>Add your first room to get started.</span>
                    }
                </p>
                @if (hasFilters)
                {
                    <a href="@Url.Action("Index2", "Room")" class="inline-block bg-gray-600 hover:bg-gray-700 text-white font-medium py-2 px-6 rounded-lg transition mr-2">
                        Clear Filters
                    </a>
                }
                <a asp-action="Add" class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-medium py-2 px-6 rounded-lg transition">
                    <i class="fas fa-plus mr-2"></i>Add Room
                </a>
            </div>
        }
    </div>
</div>
