@model BookifyHotel.Model.Room
@{
    ViewData["Title"] = $"Room {Model.RoomNumber} - Admin View";
}

<div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8">
            <a asp-action="Index2" class="inline-flex items-center text-indigo-600 hover:text-indigo-700 mb-4">
                <i class="fas fa-arrow-left mr-2"></i>Back to Rooms
            </a>
            <h1 class="text-4xl font-bold text-gray-900 mb-2">Room @Model.RoomNumber Details</h1>
            <p class="text-gray-600">Administrative view</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Main Details -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Room Image -->
                <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
                    <img src="@(Model.ImageUrl ?? "/images/default-room.jpg")" 
                         alt="Room @Model.RoomNumber" 
                         class="w-full h-96 object-cover">
                </div>

                <!-- Room Information -->
                <div class="bg-white rounded-2xl shadow-xl p-6">
                    <h2 class="text-2xl font-bold text-gray-900 mb-6">Room Information</h2>
                    <div class="grid grid-cols-2 gap-6">
                        <div>
                            <div class="text-sm text-gray-500 mb-1">Room Number</div>
                            <div class="text-xl font-bold text-gray-900">@Model.RoomNumber</div>
                        </div>
                        <div>
                            <div class="text-sm text-gray-500 mb-1">Floor</div>
                            <div class="text-xl font-bold text-gray-900">@Model.Floor</div>
                        </div>
                        <div>
                            <div class="text-sm text-gray-500 mb-1">Room Type</div>
                            <div class="text-xl font-bold text-indigo-600">@(Model.RoomType?.Name ?? "N/A")</div>
                        </div>
                        <div>
                            <div class="text-sm text-gray-500 mb-1">Price per Night</div>
                            <div class="text-xl font-bold text-gray-900">$@(Model.RoomType?.PricePerNight ?? 0)</div>
                        </div>
                        <div>
                            <div class="text-sm text-gray-500 mb-1">Status</div>
                            <div class="text-lg font-semibold">
                                <span class="px-3 py-1 rounded-full text-sm
                                    @(Model.Status == "Available" ? "bg-emerald-100 text-emerald-700" :
                                      Model.Status == "Booked" ? "bg-amber-100 text-amber-700" :
                                      Model.Status == "Maintenance" ? "bg-blue-100 text-blue-700" :
                                      "bg-red-100 text-red-700")">
                                    @Model.Status
                                </span>
                            </div>
                        </div>
                        <div>
                            <div class="text-sm text-gray-500 mb-1">Availability</div>
                            <div class="text-lg font-semibold">
                                @if (Model.IsAvailable)
                                {
                                    <span class="text-emerald-600"><i class="fas fa-check-circle mr-1"></i>Available</span>
                                }
                                else
                                {
                                    <span class="text-red-600"><i class="fas fa-times-circle mr-1"></i>Not Available</span>
                                }
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Room Type Details -->
                @if (Model.RoomType != null)
                {
                    <div class="bg-white rounded-2xl shadow-xl p-6">
                        <h2 class="text-2xl font-bold text-gray-900 mb-4">Room Type Details</h2>
                        <p class="text-gray-600">@(Model.RoomType.Description ?? "No description available")</p>
                    </div>
                }
            </div>

            <!-- Actions Sidebar -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-2xl shadow-xl p-6 sticky top-6">
                    <h3 class="text-xl font-bold text-gray-900 mb-6">Actions</h3>
                    
                    <div class="space-y-3">
                        <a asp-action="Edit" asp-route-id="@Model.RoomId" 
                           class="block w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-200 text-center">
                            <i class="fas fa-edit mr-2"></i>Edit Room
                        </a>
                        
                        <a asp-controller="Room" asp-action="Details" asp-route-id="@Model.RoomId" 
                           class="block w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-200 text-center">
                            <i class="fas fa-eye mr-2"></i>View Public Page
                        </a>
                        
                        <form asp-action="Delete" asp-route-id="@Model.RoomId" method="post" onsubmit="return confirm('Are you sure you want to delete this room?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-200">
                                <i class="fas fa-trash mr-2"></i>Delete Room
                            </button>
                        </form>
                    </div>

                    <div class="mt-6 pt-6 border-t border-gray-200">
                        <h4 class="font-semibold text-gray-900 mb-3">Quick Stats</h4>
                        <div class="space-y-2 text-sm">
                            <div class="flex justify-between">
                                <span class="text-gray-600">Room ID</span>
                                <span class="font-semibold">@Model.RoomId</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-600">Type ID</span>
                                <span class="font-semibold">@Model.RoomTypeId</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
