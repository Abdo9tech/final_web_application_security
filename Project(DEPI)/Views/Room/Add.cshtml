@model BookifyHotel.Model.Room
@{
    ViewData["Title"] = "Add New Room";
}

<div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8">
            <a asp-action="Index2" class="inline-flex items-center text-indigo-600 hover:text-indigo-700 mb-4">
                <i class="fas fa-arrow-left mr-2"></i>Back to Rooms
            </a>
            <h1 class="text-4xl font-bold text-gray-900 mb-2">Add New Room</h1>
            <p class="text-gray-600">Create a new room in the system</p>
        </div>

        <div class="bg-white rounded-2xl shadow-xl p-8">
            <form asp-action="AddSave" method="post">
                <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6"></div>

                <div class="space-y-6">
                    <!-- Room Number -->
                    <div>
                        <label asp-for="RoomNumber" class="block text-sm font-medium text-gray-700 mb-2">Room Number</label>
                        <input asp-for="RoomNumber" type="number" min="1" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                        <span asp-validation-for="RoomNumber" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Floor -->
                    <div>
                        <label asp-for="Floor" class="block text-sm font-medium text-gray-700 mb-2">Floor</label>
                        <input asp-for="Floor" type="number" min="0" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                        <span asp-validation-for="Floor" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Room Type -->
                    <div>
                        <label asp-for="RoomTypeId" class="block text-sm font-medium text-gray-700 mb-2">Room Type</label>
                        <select asp-for="RoomTypeId" asp-items="@(new SelectList(ViewBag.RoomTypes, "RoomTypeId", "Name"))" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                            <option value="">Select a room type</option>
                        </select>
                        <span asp-validation-for="RoomTypeId" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Status -->
                    <div>
                        <label asp-for="Status" class="block text-sm font-medium text-gray-700 mb-2">Status</label>
                        <select asp-for="Status" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                            <option value="Available">Available</option>
                            <option value="Booked">Booked</option>
                            <option value="Maintenance">Maintenance</option>
                            <option value="Out of Service">Out of Service</option>
                        </select>
                        <span asp-validation-for="Status" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Is Available -->
                    <div class="flex items-center">
                        <input asp-for="IsAvailable" type="checkbox" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                        <label asp-for="IsAvailable" class="ml-2 block text-sm text-gray-700">Room is available for booking</label>
                    </div>

                    <!-- Image URL -->
                    <div>
                        <label asp-for="ImageUrl" class="block text-sm font-medium text-gray-700 mb-2">Image URL (Optional)</label>
                        <input asp-for="ImageUrl" type="text" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent" placeholder="/images/room.jpg">
                        <span asp-validation-for="ImageUrl" class="text-red-500 text-sm"></span>
                        <p class="text-sm text-gray-500 mt-1">Leave empty to use default image</p>
                    </div>
                </div>

                <div class="mt-8 flex gap-4">
                    <button type="submit" class="flex-1 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-bold py-3 px-6 rounded-lg transition duration-200">
                        <i class="fas fa-save mr-2"></i>Create Room
                    </button>
                    <a asp-action="Index2" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-3 px-6 rounded-lg transition duration-200 text-center">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
