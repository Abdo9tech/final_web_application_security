@model BookifyHotel.Model.Room
@{
    ViewData["Title"] = $"Room {Model.RoomNumber} Details";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Back Button -->
    <a asp-action="Index" class="inline-flex items-center text-indigo-600 hover:text-indigo-700 mb-6">
        <i class="fas fa-arrow-left mr-2"></i>Back to Rooms
    </a>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Image Gallery -->
        <div>
            <div class="relative rounded-2xl overflow-hidden shadow-2xl mb-4">
                <img src="@(Model.ImageUrl ?? "/images/default-room.jpg")" 
                     alt="Room @Model.RoomNumber" 
                     class="w-full h-96 object-cover">
                @if (Model.IsAvailable)
                {
                    <span class="absolute top-4 right-4 bg-emerald-500 text-white px-4 py-2 rounded-full text-sm font-semibold">
                        Available Now
                    </span>
                }
                @if (User.Identity.IsAuthenticated)
                {
                    <button onclick="toggleFavorite(@Model.RoomId, this)" class="absolute top-4 left-4 bg-white/90 hover:bg-white p-3 rounded-full transition" title="@(ViewBag.IsFavorited ? "Remove from favorites" : "Add to favorites")">
                        <i class="@(ViewBag.IsFavorited ? "fas" : "far") fa-heart text-red-500 text-xl"></i>
                    </button>
                }
            </div>
        </div>

        <!-- Room Details -->
        <div>
            <div class="flex justify-between items-start mb-4">
                <div>
                    <h1 class="text-4xl font-bold text-gray-900 mb-2">Room @Model.RoomNumber</h1>
                    <p class="text-xl text-indigo-600 font-semibold">@(Model.RoomType?.Name ?? "Standard Room")</p>
                </div>
                <div class="text-right">
                    <div class="text-4xl font-bold text-gray-900">$@(Model.RoomType?.PricePerNight ?? 0)</div>
                    <div class="text-gray-500">per night</div>
                </div>
            </div>

            <div class="border-t border-b border-gray-200 py-6 my-6">
                <div class="grid grid-cols-2 gap-4">
                    <div class="flex items-center">
                        <i class="fas fa-layer-group text-indigo-600 text-xl mr-3"></i>
                        <div>
                            <div class="text-sm text-gray-500">Floor</div>
                            <div class="font-semibold">@Model.Floor</div>
                        </div>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-door-open text-indigo-600 text-xl mr-3"></i>
                        <div>
                            <div class="text-sm text-gray-500">Status</div>
                            <div class="font-semibold">@Model.Status</div>
                        </div>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-users text-indigo-600 text-xl mr-3"></i>
                        <div>
                            <div class="text-sm text-gray-500">Capacity</div>
                            <div class="font-semibold">2 Guests</div>
                        </div>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-bed text-indigo-600 text-xl mr-3"></i>
                        <div>
                            <div class="text-sm text-gray-500">Bed Type</div>
                            <div class="font-semibold">Queen Bed</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mb-8">
                <h3 class="text-xl font-bold text-gray-900 mb-4">Description</h3>
                <p class="text-gray-600 leading-relaxed">
                    @(Model.RoomType?.Description ?? "Experience luxury and comfort in this beautifully appointed room. Featuring modern amenities and elegant decor, this space is perfect for both business and leisure travelers.")
                </p>
            </div>

            <div class="mb-8">
                <h3 class="text-xl font-bold text-gray-900 mb-4">Amenities</h3>
                <div class="grid grid-cols-2 gap-3">
                    <div class="flex items-center text-gray-700">
                        <i class="fas fa-wifi text-indigo-600 mr-2"></i>Free WiFi
                    </div>
                    <div class="flex items-center text-gray-700">
                        <i class="fas fa-tv text-indigo-600 mr-2"></i>Smart TV
                    </div>
                    <div class="flex items-center text-gray-700">
                        <i class="fas fa-snowflake text-indigo-600 mr-2"></i>Air Conditioning
                    </div>
                    <div class="flex items-center text-gray-700">
                        <i class="fas fa-coffee text-indigo-600 mr-2"></i>Coffee Maker
                    </div>
                    <div class="flex items-center text-gray-700">
                        <i class="fas fa-bath text-indigo-600 mr-2"></i>Private Bathroom
                    </div>
                    <div class="flex items-center text-gray-700">
                        <i class="fas fa-concierge-bell text-indigo-600 mr-2"></i>Room Service
                    </div>
                </div>
            </div>

            @if (Model.IsAvailable)
            {
                <div class="bg-gradient-to-r from-indigo-600 to-purple-600 rounded-xl p-6 text-white">
                    <h3 class="text-xl font-bold mb-4">Ready to Book?</h3>
                    <p class="mb-4">This room is available for immediate booking</p>
                    <a asp-controller="BookNow" asp-action="Index" asp-route-roomId="@Model.RoomId" 
                       class="inline-block bg-white text-indigo-600 font-bold py-3 px-8 rounded-lg hover:bg-gray-100 transition duration-200">
                        Book Now
                    </a>
                </div>
            }
            else
            {
                <div class="bg-gray-100 rounded-xl p-6">
                    <h3 class="text-xl font-bold text-gray-900 mb-2">Currently Unavailable</h3>
                    <p class="text-gray-600">This room is currently booked. Please check other available rooms.</p>
                </div>
            }
        </div>
    </div>
</div>


@section Scripts {
    <script>
        async function toggleFavorite(roomId, button) {
            if (!@(User.Identity?.IsAuthenticated == true ? "true" : "false")) {
                window.location.href = '/Login/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                return;
            }

            try {
                const response = await fetch('/Favorite/Toggle', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify(roomId)
                });

                const result = await response.json();
                
                if (result.success) {
                    const icon = button.querySelector('i');
                    if (result.action === 'added') {
                        icon.classList.remove('far');
                        icon.classList.add('fas');
                        button.title = 'Remove from favorites';
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'success',
                                title: 'Added to Favorites!',
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000
                            });
                        }
                    } else {
                        icon.classList.remove('fas');
                        icon.classList.add('far');
                        button.title = 'Add to favorites';
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'info',
                                title: 'Removed from Favorites',
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000
                            });
                        }
                    }
                }
            } catch (error) {
                console.error('Error toggling favorite:', error);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Failed to update favorites. Please try again.',
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 3000
                    });
                }
            }
        }
    </script>
}
