@model BookifyHotel.Model.Room
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    ViewData["Title"] = $"Room {Model.RoomNumber} Details";
}

<div class="bg-gray-50 border-b glass-card">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
        <nav class="flex text-xs text-blue-600 mb-4" aria-label="Breadcrumb">
            <ol class="inline-flex items-center space-x-1 md:space-x-3">
                <li><a href="/" class="hover:underline">Home</a></li>
                <li class="flex items-center"><i class="fas fa-chevron-right text-[8px] mx-1 text-gray-400"></i><a href="/Room" class="hover:underline">Hotels</a></li>
                <li class="flex items-center"><i class="fas fa-chevron-right text-[8px] mx-1 text-gray-400"></i><span class="text-gray-500">Room @Model.RoomNumber</span></li>
            </ol>
        </nav>

        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
            <div>
                <div class="flex items-center space-x-2 mb-1">
                    <span class="bg-gray-500 text-white text-[10px] font-bold px-1 rounded-sm">HOTEL</span>
                    <div class="flex text-yellow-400 text-xs">
                        <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                    </div>
                </div>
                <h1 class="text-2xl font-bold text-gray-900">Room @Model.RoomNumber - @(Model.RoomType?.Name ?? "Luxury Suite")</h1>
                <p class="text-sm text-blue-600 flex items-center mt-1">
                    <i class="fas fa-map-marker-alt mr-1"></i> @(string.IsNullOrEmpty(Model.Location) ? "Manchester, United Kingdom" : Model.Location) – <a href="#map-section" class="underline cursor-pointer font-bold hover:text-blue-850">Excellent location – show map</a>
                </p>
            </div>
            <div class="flex items-center space-x-4">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <button onclick="toggleFavorite('@Model.RoomId', this)" class="text-blue-600 hover:text-red-500 transition-colors">
                        <i class="@(ViewBag.IsFavorited ? "fas" : "far") fa-heart text-2xl"></i>
                    </button>
                }
                <a href="#booking-section" class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-6 rounded-sm transition-colors shadow-sm">
                    Reserve
                </a>
            </div>
        </div>
    </div>
</div>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <div class="lg:col-span-2">
            <!-- Image Grid -->
            <div class="grid grid-cols-4 gap-2 mb-8 h-[400px]">
                <div class="col-span-3 row-span-2 relative overflow-hidden rounded-l-md">
                    <img src="@(Model.ImageUrl ?? "https://images.unsplash.com/photo-1590490360182-c33d57733427?auto=format&fit=crop&q=80&w=1200")" 
                         class="w-full h-full object-cover hover:scale-105 transition-transform duration-700" alt="Room View">
                </div>
                <div class="col-span-1 relative overflow-hidden rounded-tr-md">
                    <img src="https://images.unsplash.com/photo-1584132967334-10e028bd69f7?auto=format&fit=crop&q=80&w=400" 
                         class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" alt="Detail 1">
                </div>
                <div class="col-span-1 relative overflow-hidden rounded-br-md">
                    <img src="https://images.unsplash.com/photo-1590490359683-658d3d23f972?auto=format&fit=crop&q=80&w=400" 
                         class="w-full h-full object-cover hover:scale-110 transition-transform duration-500" alt="Detail 2">
                    <div class="absolute inset-0 bg-black/40 flex items-center justify-center">
                        <span class="text-white font-bold">+15 photos</span>
                    </div>
                </div>
            </div>

            <!-- Description -->
            <div class="prose prose-sm max-w-none text-gray-700 mb-8">
                <p class="text-base leading-relaxed">
                    @(Model.RoomType?.Description ?? "Located in the heart of Manchester, this room offers unparalleled luxury and convenience. Featuring state-of-the-art facilities and elegant interior design, it provides the perfect sanctuary for both leisure and business travelers.")
                </p>
                <div class="bg-blue-50 border-l-4 border-blue-600 p-4 my-6">
                    <p class="text-sm font-bold text-gray-900 mb-1">Most popular facilities</p>
                    <div class="flex flex-wrap gap-4 text-green-700 text-xs">
                        <span class="flex items-center"><i class="fas fa-wifi mr-1"></i> Free WiFi</span>
                        <span class="flex items-center"><i class="fas fa-parking mr-1"></i> Free parking</span>
                        <span class="flex items-center"><i class="fas fa-swimmer mr-1"></i> Swimming pool</span>
                        <span class="flex items-center"><i class="fas fa-dumbbell mr-1"></i> Fitness centre</span>
                        <span class="flex items-center"><i class="fas fa-utensils mr-1"></i> Restaurant</span>
                    </div>
                </div>
            </div>

            <!-- Map Location Card -->
            <div id="map-section" class="bg-white border rounded-sm p-6 mb-8 scroll-mt-24 glass-card">
                <h3 class="text-lg font-bold text-gray-900 mb-4">Location</h3>
                <p class="text-sm text-gray-600 mb-4">
                    <i class="fas fa-map-marker-alt text-red-500 mr-2"></i>@(string.IsNullOrEmpty(Model.Location) ? "Manchester, United Kingdom" : Model.Location)
                </p>
                <div id="map" class="w-full h-80 rounded-sm border" style="min-height: 320px; z-index: 10;"></div>
            </div>
        </div>

        <!-- Sticky Sidebar Booking Box -->
        <div class="lg:col-span-1">
            <div id="booking-section" class="bg-blue-50 border border-blue-200 rounded-md p-4 sticky top-24 glass-card">
                <h3 class="font-bold text-gray-900 mb-4">Property Highlights</h3>
                <div class="space-y-4 mb-6">
                    <div class="flex items-start">
                        <i class="fas fa-heart text-gray-400 mt-1 mr-3"></i>
                        <p class="text-sm font-bold text-gray-700">Perfect for a 1-night stay!</p>
                    </div>
                    <div class="flex items-start">
                        <i class="fas fa-map-marker-alt text-gray-400 mt-1 mr-3"></i>
                        <p class="text-sm text-gray-700">Top location: Highly rated by recent guests (9.5)</p>
                    </div>
                    <div class="flex items-start">
                        <i class="fas fa-bed text-gray-400 mt-1 mr-3"></i>
                        <p class="text-sm text-gray-700">Want a great night's sleep? This hotel was highly rated for its very comfy beds.</p>
                    </div>
                </div>

                <div class="border-t border-blue-200 pt-4 mb-6">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-lg font-bold">US$@(Model.RoomType?.PricePerNight ?? 0)</span>
                        <span class="text-xs text-gray-500">per night</span>
                    </div>
                    <p class="text-[10px] text-gray-500 mb-4">Includes taxes and charges</p>
                    
                    @if (Model.IsAvailable)
                    {
                        <a asp-controller="BookNow" asp-action="Index" asp-route-roomId="@Model.RoomId" 
                           class="block w-full bg-blue-600 hover:bg-blue-700 text-white text-center font-bold py-3 rounded-sm transition-colors mb-3">
                            Reserve
                        </a>
                    }
                    else
                    {
                        <div class="bg-red-100 text-red-700 text-sm p-3 rounded-sm text-center font-bold mb-3">
                            Currently Unavailable
                        </div>
                    }
                    <button onclick="toggleFavorite('@Model.RoomId', this)" 
                            class="w-full border border-blue-600 text-blue-600 font-bold py-2 rounded-sm text-sm hover:bg-blue-50 transition-colors">
                        <i class="@(ViewBag.IsFavorited == true ? "fas" : "far") fa-heart mr-2"></i> 
                        <span class="favorite-text">@(ViewBag.IsFavorited == true ? "Saved" : "Save to list")</span>
                    </button>
                </div>

                <div class="text-center">
                    <p class="text-[10px] text-gray-500">You won't be charged yet</p>
                </div>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://maps.googleapis.com/maps/api/js?key=@(Configuration["GoogleMaps:ApiKey"] ?? "YOUR_GOOGLE_MAPS_API_KEY")&libraries=places"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            var locationText = "@(Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(string.IsNullOrEmpty(Model.Location) ? "Manchester, United Kingdom" : Model.Location)))";
            
            var defaultLat = 53.4808;
            var defaultLng = -2.2426;

            var mapDiv = document.getElementById('map');
            if (mapDiv && typeof google !== 'undefined') {
                var mapOptions = {
                    zoom: 13,
                    center: { lat: defaultLat, lng: defaultLng }
                };
                var map = new google.maps.Map(mapDiv, mapOptions);
                var marker = new google.maps.Marker({
                    position: { lat: defaultLat, lng: defaultLng },
                    map: map,
                    title: "Room Location"
                });
                var infoWindow = new google.maps.InfoWindow({
                    content: "<b>Room Location</b><br>" + locationText
                });
                
                marker.addListener('click', function() {
                    infoWindow.open(map, marker);
                });
                
                infoWindow.open(map, marker);

                var geocoder = new google.maps.Geocoder();
                geocoder.geocode({ 'address': locationText }, function(results, status) {
                    if (status === 'OK' && results[0]) {
                        var loc = results[0].geometry.location;
                        map.setCenter(loc);
                        map.setZoom(14);
                        marker.setPosition(loc);
                    } else {
                        console.log("Google Geocoding failed, status: " + status);
                    }
                });
            } else {
                console.log("Google Maps API not loaded or map container not found.");
            }
        });

        async function toggleFavorite(roomId, button) {
            if (!@(User.Identity?.IsAuthenticated == true ? "true" : "false")) {
                window.location.href = '/Login/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                return;
            }

            try {
                const response = await fetch('/Favorite/Toggle', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify(roomId)
                });

                const result = await response.json();
                
                if (result.success) {
                    const icon = button.querySelector('i');
                    const textSpan = button.querySelector('.favorite-text');
                    
                    if (result.action === 'added') {
                        icon?.classList.remove('far');
                        icon?.classList.add('fas');
                        if (textSpan) textSpan.textContent = 'Saved';
                        
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'success',
                                title: 'Added to Favorites!',
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000
                            });
                        }
                    } else {
                        icon?.classList.remove('fas');
                        icon?.classList.add('far');
                        if (textSpan) textSpan.textContent = 'Save to list';
                        
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'info',
                                title: 'Removed from Favorites',
                                toast: true,
                                position: 'top-end',
                                showConfirmButton: false,
                                timer: 2000
                            });
                        }
                    }
                }
            } catch (error) {
                console.error('Error toggling favorite:', error);
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error',
                        text: 'Failed to update favorites. Please try again.',
                        toast: true,
                        position: 'top-end',
                        showConfirmButton: false,
                        timer: 3000
                    });
                }
            }
        }
    </script>
}
