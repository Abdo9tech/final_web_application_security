@model IEnumerable<BookifyHotel.Model.RoomType>
@{
    ViewData["Title"] = "Manage Room Types";
}

<div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-4xl font-bold text-gray-900 mb-2">Manage Room Types</h1>
                <p class="text-gray-600">Configure room categories and pricing</p>
            </div>
            <a asp-action="Create" class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-200">
                <i class="fas fa-plus mr-2"></i>Add Room Type
            </a>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var roomType in Model)
                {
                    <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition duration-300">
                        <div class="bg-gradient-to-r from-indigo-600 to-purple-600 p-6 text-white">
                            <h3 class="text-2xl font-bold mb-2">@roomType.Name</h3>
                            <div class="text-3xl font-bold">$@roomType.PricePerNight</div>
                            <div class="text-indigo-100 text-sm">per night</div>
                        </div>
                        <div class="p-6">
                            <p class="text-gray-600 mb-6 min-h-[60px]">@(roomType.Description ?? "No description available")</p>
                            
                            <div class="mb-4 p-3 bg-gray-50 rounded-lg">
                                <div class="text-sm text-gray-500 mb-1">Total Rooms</div>
                                <div class="text-xl font-bold text-gray-900">@(roomType.Rooms?.Count ?? 0)</div>
                            </div>

                            <div class="flex gap-2">
                                <a asp-action="Details" asp-route-id="@roomType.RoomTypeId" 
                                   class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-200 text-center text-sm">
                                    <i class="fas fa-eye mr-1"></i>View
                                </a>
                                <a asp-action="Edit" asp-route-id="@roomType.RoomTypeId" 
                                   class="flex-1 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-200 text-center text-sm">
                                    <i class="fas fa-edit mr-1"></i>Edit
                                </a>
                                <a asp-action="Delete" asp-route-id="@roomType.RoomTypeId" 
                                   onclick="return confirm('Are you sure you want to delete this room type?')"
                                   class="flex-1 bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-200 text-center text-sm">
                                    <i class="fas fa-trash mr-1"></i>Delete
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl shadow-lg p-12 text-center">
                <i class="fas fa-tags text-gray-300 text-6xl mb-4"></i>
                <h3 class="text-2xl font-semibold text-gray-700 mb-2">No Room Types Found</h3>
                <p class="text-gray-500 mb-6">Create room types to categorize your rooms</p>
                <a asp-action="Create" class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-8 rounded-lg transition duration-200">
                    Create First Room Type
                </a>
            </div>
        }
    </div>
</div>
