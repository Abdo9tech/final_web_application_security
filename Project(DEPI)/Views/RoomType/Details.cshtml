@model BookifyHotel.Model.RoomType
@{
    ViewData["Title"] = $"{Model.Name} Details";
}

<div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8">
            <a asp-action="Index" class="inline-flex items-center text-indigo-600 hover:text-indigo-700 mb-4">
                <i class="fas fa-arrow-left mr-2"></i>Back to Room Types
            </a>
            <h1 class="text-4xl font-bold text-gray-900 mb-2">@Model.Name</h1>
            <p class="text-gray-600">Room type details and statistics</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Main Details -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Pricing Card -->
                <div class="bg-gradient-to-r from-indigo-600 to-purple-600 rounded-2xl shadow-xl p-8 text-white">
                    <h2 class="text-2xl font-bold mb-4">Pricing</h2>
                    <div class="flex items-baseline">
                        <span class="text-5xl font-bold">$@Model.PricePerNight</span>
                        <span class="text-2xl ml-2 text-indigo-100">/ night</span>
                    </div>
                </div>

                <!-- Description Card -->
                <div class="bg-white rounded-2xl shadow-xl p-8">
                    <h2 class="text-2xl font-bold text-gray-900 mb-4">Description</h2>
                    <p class="text-gray-600 leading-relaxed">
                        @(Model.Description ?? "No description available for this room type.")
                    </p>
                </div>

                <!-- Rooms List -->
                @if (Model.Rooms != null && Model.Rooms.Any())
                {
                    <div class="bg-white rounded-2xl shadow-xl p-8">
                        <h2 class="text-2xl font-bold text-gray-900 mb-6">Rooms with this Type</h2>
                        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
                            @foreach (var room in Model.Rooms)
                            {
                                <div class="border border-gray-200 rounded-lg p-4 hover:border-indigo-500 transition">
                                    <div class="text-lg font-bold text-gray-900 mb-1">Room @room.RoomNumber</div>
                                    <div class="text-sm text-gray-500">Floor @room.Floor</div>
                                    <div class="mt-2">
                                        @if (room.IsAvailable)
                                        {
                                            <span class="text-xs px-2 py-1 bg-emerald-100 text-emerald-700 rounded-full">Available</span>
                                        }
                                        else
                                        {
                                            <span class="text-xs px-2 py-1 bg-red-100 text-red-700 rounded-full">Booked</span>
                                        }
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>

            <!-- Actions Sidebar -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-2xl shadow-xl p-6 sticky top-6">
                    <h3 class="text-xl font-bold text-gray-900 mb-6">Actions</h3>
                    
                    <div class="space-y-3">
                        <a asp-action="Edit" asp-route-id="@Model.RoomTypeId" 
                           class="block w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-200 text-center">
                            <i class="fas fa-edit mr-2"></i>Edit Room Type
                        </a>
                        
                        <a asp-controller="Room" asp-action="Add" 
                           class="block w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-200 text-center">
                            <i class="fas fa-plus mr-2"></i>Add Room
                        </a>
                        
                        <a asp-action="Delete" asp-route-id="@Model.RoomTypeId" 
                           onclick="return confirm('Are you sure you want to delete this room type? This will affect all associated rooms.')"
                           class="block w-full bg-red-600 hover:bg-red-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-200 text-center">
                            <i class="fas fa-trash mr-2"></i>Delete Room Type
                        </a>
                    </div>

                    <div class="mt-6 pt-6 border-t border-gray-200">
                        <h4 class="font-semibold text-gray-900 mb-3">Statistics</h4>
                        <div class="space-y-3">
                            <div class="flex justify-between">
                                <span class="text-gray-600">Total Rooms</span>
                                <span class="font-semibold">@(Model.Rooms?.Count ?? 0)</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-600">Available</span>
                                <span class="font-semibold text-emerald-600">@(Model.Rooms?.Count(r => r.IsAvailable) ?? 0)</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-600">Booked</span>
                                <span class="font-semibold text-red-600">@(Model.Rooms?.Count(r => !r.IsAvailable) ?? 0)</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
