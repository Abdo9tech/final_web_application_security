@{
    ViewData["Title"] = "About Us";
}

<!-- Hero Section -->
<section class="relative bg-[#003580] text-white py-24 overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')]"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
        <h1 class="text-5xl md:text-6xl font-black mb-6 tracking-tight">About Bookify Hotel</h1>
        <p class="text-xl md:text-2xl text-white font-bold opacity-90">Experience luxury and comfort since 1995</p>
    </div>
</section>

<!-- Story Section -->
<section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
            <!-- Text -->
            <div>
                <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-6">Our Story</h2>
                <p class="text-lg text-gray-600 mb-4">
                    Founded in 1995, Bookify Hotel has been a beacon of hospitality excellence for nearly three decades. 
                    What started as a vision of refined living has matured into a premier destination for travelers seeking 
                    the perfect blend of comfort and luxury.
                </p>
                <p class="text-lg text-gray-600 mb-4">
                    Located in the heart of Manchester, we offer a sanctuary where modern elegance meets timeless sophistication. 
                    Every guest who walks through our doors becomes part of our prestigious legacy.
                </p>
                <p class="text-lg text-gray-600">
                    We take immense pride in exceeding expectations, crafting moments that linger long after the stay concludes.
                </p>
            </div>

            <!-- Image -->
            <div class="relative">
                <img src="https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&w=1200&q=80" 
                     alt="Bookify Hotel" 
                     class="rounded-2xl shadow-2xl">
            </div>
        </div>
    </div>
</section>

<!-- Stats Section -->
<section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
            <div>
                <div class="text-4xl font-bold text-primary-600 mb-2">150+</div>
                <div class="text-gray-600">Luxury Suites</div>
            </div>
            <div>
                <div class="text-4xl font-bold text-emerald-600 mb-2">50K+</div>
                <div class="text-gray-600">Happy Guests</div>
            </div>
            <div>
                <div class="text-4xl font-bold text-amber-600 mb-2">12</div>
                <div class="text-gray-600">Awards Won</div>
            </div>
            <div>
                <div class="text-4xl font-bold text-sky-600 mb-2">24/7</div>
                <div class="text-gray-600">Concierge</div>
            </div>
        </div>
    </div>
</section>

<!-- Values Section -->
<section class="py-16 sm:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-12">
            <h2 class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4">Our Values</h2>
            <p class="text-lg text-gray-600">What makes us different</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
            <div class="text-center">
                <div class="w-16 h-16 bg-gradient-to-br from-primary-500 to-primary-600 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-award text-3xl text-white"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Excellence</h3>
                <p class="text-gray-600">Committed to the highest standards of service</p>
            </div>

            <div class="text-center">
                <div class="w-16 h-16 bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-leaf text-3xl text-white"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Sustainability</h3>
                <p class="text-gray-600">Eco-friendly practices throughout</p>
            </div>

            <div class="text-center">
                <div class="w-16 h-16 bg-gradient-to-br from-amber-500 to-amber-600 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-heart text-3xl text-white"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Hospitality</h3>
                <p class="text-gray-600">Warm, personalized service for every guest</p>
            </div>

            <div class="text-center">
                <div class="w-16 h-16 bg-gradient-to-br from-sky-500 to-sky-600 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-lightbulb text-3xl text-white"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">Innovation</h3>
                <p class="text-gray-600">Constantly evolving to serve you better</p>
            </div>
        </div>
    </div>
</section>
