@model BookifyHotel.Model.Booking
@{
    ViewData["Title"] = "Edit Booking";
}

<div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8">
            <a asp-action="Details" asp-route-id="@Model.BookingId" class="inline-flex items-center text-indigo-600 hover:text-indigo-700 mb-4">
                <i class="fas fa-arrow-left mr-2"></i>Back to Details
            </a>
            <h1 class="text-4xl font-bold text-gray-900 mb-2">Edit Booking #@Model.BookingId</h1>
            <p class="text-gray-600">Update booking information</p>
        </div>

        <div class="bg-white rounded-2xl shadow-xl p-8">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="BookingId" />
                <input type="hidden" asp-for="BookingDate" />
                <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6"></div>

                <div class="space-y-6">
                    <!-- Guest Selection -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Guest</label>
                        <select asp-for="UserProfileId" asp-items="ViewBag.Users" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                            <option value="">Select a guest</option>
                        </select>
                        <span asp-validation-for="UserProfileId" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Room Selection -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Room</label>
                        <select asp-for="RoomId" asp-items="ViewBag.Rooms" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent" id="roomSelect">
                            <option value="">Select a room</option>
                        </select>
                        <span asp-validation-for="RoomId" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Date Selection -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label asp-for="CheckInDate" class="block text-sm font-medium text-gray-700 mb-2">Check-in Date</label>
                            <input asp-for="CheckInDate" type="date" min="@ViewBag.TodayDate" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent" id="checkInDate">
                            <span asp-validation-for="CheckInDate" class="text-red-500 text-sm"></span>
                        </div>
                        <div>
                            <label asp-for="CheckOutDate" class="block text-sm font-medium text-gray-700 mb-2">Check-out Date</label>
                            <input asp-for="CheckOutDate" type="date" min="@ViewBag.TodayDate" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent" id="checkOutDate">
                            <span asp-validation-for="CheckOutDate" class="text-red-500 text-sm"></span>
                        </div>
                    </div>

                    <!-- Status Selection -->
                    <div>
                        <label asp-for="Status" class="block text-sm font-medium text-gray-700 mb-2">Status</label>
                        <select asp-for="Status" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                            <option value="Pending">Pending</option>
                            <option value="Confirmed">Confirmed</option>
                            <option value="Cancelled">Cancelled</option>
                            <option value="Completed">Completed</option>
                        </select>
                        <span asp-validation-for="Status" class="text-red-500 text-sm"></span>
                    </div>

                    <!-- Total Price Display -->
                    <div class="bg-indigo-50 rounded-lg p-4">
                        <div class="flex justify-between items-center">
                            <span class="text-gray-700 font-medium">Total Price</span>
                            <span class="text-2xl font-bold text-indigo-600" id="totalPrice">$@Model.TotalPrice</span>
                        </div>
                        <p class="text-sm text-gray-600 mt-2">Price will be recalculated based on changes</p>
                    </div>
                </div>

                <div class="mt-8 flex gap-4">
                    <button type="submit" class="flex-1 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-bold py-3 px-6 rounded-lg transition duration-200">
                        Save Changes
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.BookingId" class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-3 px-6 rounded-lg transition duration-200 text-center">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const roomsData = @Html.Raw(Json.Serialize(ViewBag.RoomsData));
        
        function calculateTotal() {
            const roomId = document.getElementById('roomSelect').value;
            const checkIn = document.getElementById('checkInDate').value;
            const checkOut = document.getElementById('checkOutDate').value;
            
            if (roomId && checkIn && checkOut && roomsData[roomId]) {
                const checkInDate = new Date(checkIn);
                const checkOutDate = new Date(checkOut);
                const nights = Math.ceil((checkOutDate - checkInDate) / (1000 * 60 * 60 * 24));
                
                if (nights > 0) {
                    const pricePerNight = roomsData[roomId].PricePerNight;
                    const total = pricePerNight * nights;
                    document.getElementById('totalPrice').textContent = '$' + total.toFixed(2);
                }
            }
        }
        
        document.getElementById('roomSelect').addEventListener('change', calculateTotal);
        document.getElementById('checkInDate').addEventListener('change', calculateTotal);
        document.getElementById('checkOutDate').addEventListener('change', calculateTotal);
    </script>
}
