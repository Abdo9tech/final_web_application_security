@model IEnumerable<BookifyHotel.Model.Booking>
@{
    ViewData["Title"] = "Manage Bookings";
}

<div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-4xl font-bold text-gray-900 mb-2">Manage Bookings</h1>
                <p class="text-gray-600">View and manage all hotel reservations</p>
            </div>
            <a asp-action="Create" class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-200">
                <i class="fas fa-plus mr-2"></i>New Booking
            </a>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-200">
                        <thead class="bg-gray-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Guest</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Room</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Check-in</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Check-out</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Total</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-gray-200">
                            @foreach (var booking in Model)
                            {
                                <tr class="hover:bg-gray-50">
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">#@booking.BookingId</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">@(booking.UserProfile?.FullName ?? "N/A")</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">Room @(booking.Room?.RoomNumber ?? 0)</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@booking.CheckInDate.ToString("MMM dd, yyyy")</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">@booking.CheckOutDate.ToString("MMM dd, yyyy")</td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-semibold text-gray-900">$@booking.TotalPrice</td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full
                                            @(booking.Status == "Confirmed" ? "bg-emerald-100 text-emerald-800" :
                                              booking.Status == "Pending" ? "bg-amber-100 text-amber-800" :
                                              booking.Status == "Cancelled" ? "bg-red-100 text-red-800" :
                                              "bg-gray-100 text-gray-800")">
                                            @booking.Status
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm font-medium space-x-2">
                                        <a asp-action="Details" asp-route-id="@booking.BookingId" class="text-indigo-600 hover:text-indigo-900">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit" asp-route-id="@booking.BookingId" class="text-blue-600 hover:text-blue-900">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <form asp-action="Delete" asp-route-id="@booking.BookingId" method="post" class="inline" onsubmit="return confirm('Are you sure you want to delete this booking?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="text-red-600 hover:text-red-900">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl shadow-lg p-12 text-center">
                <i class="fas fa-calendar-times text-gray-300 text-6xl mb-4"></i>
                <h3 class="text-2xl font-semibold text-gray-700 mb-2">No Bookings Found</h3>
                <p class="text-gray-500 mb-6">There are no bookings in the system yet</p>
                <a asp-action="Create" class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-8 rounded-lg transition duration-200">
                    Create First Booking
                </a>
            </div>
        }
    </div>
</div>
