@model List<BookifyHotel.Model.Booking>
@{
    ViewData["Title"] = "My Bookings";
}

<div class="bg-gray-50 min-h-screen py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="flex items-center justify-between mb-6">
            <h1 class="text-2xl font-bold text-gray-900">Bookings & Trips</h1>
            <a asp-controller="Room" asp-action="Index" class="text-sm font-bold text-blue-600 hover:underline">
                Make a new booking
            </a>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="space-y-4">
                @foreach (var booking in Model)
                {
                    <div class="bg-white border rounded-md overflow-hidden flex flex-col md:flex-row shadow-sm">
                        <!-- Room Image -->
                        <div class="md:w-64 h-48 flex-shrink-0">
                            <img src="@(booking.Room?.ImageUrl ?? "https://images.unsplash.com/photo-1566073771259-6a8506099945?auto=format&fit=crop&q=80&w=600")" 
                                 class="w-full h-full object-cover" alt="Property Image">
                        </div>

                        <!-- Booking Details -->
                        <div class="flex-1 p-5 flex flex-col justify-between">
                            <div>
                                <div class="flex justify-between items-start">
                                    <div>
                                        <h3 class="text-lg font-bold text-gray-900">Room @booking.Room?.RoomNumber - @(booking.Room?.RoomType?.Name ?? "Standard Room")</h3>
                                        <p class="text-sm text-gray-500 mt-1">Manchester, United Kingdom</p>
                                    </div>
                                    <span class="px-3 py-1 rounded-sm text-xs font-bold
                                        @(booking.Status == "Confirmed" ? "bg-green-100 text-green-700" : 
                                          booking.Status == "Pending" ? "bg-yellow-100 text-yellow-800" : 
                                          booking.Status == "Cancelled" ? "bg-red-100 text-red-700" : 
                                          "bg-gray-100 text-gray-700")">
                                        @booking.Status
                                    </span>
                                </div>

                                <div class="mt-4 flex flex-wrap gap-6 text-sm">
                                    <div class="flex items-center text-gray-700">
                                        <i class="far fa-calendar-alt mr-2 text-gray-400"></i>
                                        <span class="font-bold">Check-in:</span>
                                        <span class="ml-1">@booking.CheckInDate.ToString("ddd, dd MMM yyyy")</span>
                                    </div>
                                    <div class="flex items-center text-gray-700">
                                        <i class="far fa-calendar-check mr-2 text-gray-400"></i>
                                        <span class="font-bold">Check-out:</span>
                                        <span class="ml-1">@booking.CheckOutDate.ToString("ddd, dd MMM yyyy")</span>
                                    </div>
                                </div>
                            </div>

                            <div class="mt-6 flex items-center justify-between border-t pt-4">
                                <div>
                                    <p class="text-xs text-gray-500">Total Price</p>
                                    <p class="text-xl font-bold text-gray-900">US$@booking.TotalPrice</p>
                                </div>
                                <div class="flex gap-2">
                                    <a asp-action="Details" asp-route-id="@booking.BookingId" 
                                       class="px-4 py-2 border border-blue-600 text-blue-600 font-bold rounded-sm text-sm hover:bg-blue-50 transition-colors">
                                        View Details
                                    </a>
                                    @if (booking.Status == "Pending")
                                    {
                                        <a asp-controller="Payment" asp-action="Index" asp-route-bookingId="@booking.BookingId" 
                                           class="px-4 py-2 bg-blue-600 text-white font-bold rounded-sm text-sm hover:bg-blue-700 transition-colors">
                                            Manage Booking
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white border rounded-md p-12 text-center shadow-sm">
                <div class="w-20 h-20 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-6">
                    <i class="fas fa-suitcase-rolling text-gray-400 text-3xl"></i>
                </div>
                <h3 class="text-xl font-bold text-gray-900 mb-2">No bookings yet</h3>
                <p class="text-gray-600 mb-8 max-w-sm mx-auto">
                    Your upcoming trips will appear here. Start planning your next getaway!
                </p>
                <a asp-controller="Room" asp-action="Index" 
                   class="inline-block bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-sm transition-colors text-sm">
                    Search for hotels
                </a>
            </div>
        }
    </div>
</div>
