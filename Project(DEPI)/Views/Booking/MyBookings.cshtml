@model List<BookifyHotel.Model.Booking>
@{
    ViewData["Title"] = "My Bookings";
}

<div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-gray-900 mb-2">My Bookings</h1>
            <p class="text-gray-600">View and manage your hotel reservations</p>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="space-y-6">
                @foreach (var booking in Model)
                {
                    <div class="bg-white rounded-2xl shadow-lg overflow-hidden hover:shadow-xl transition duration-300">
                        <div class="md:flex">
                            <!-- Room Image -->
                            <div class="md:w-1/3">
                                <img src="@(booking.Room?.ImageUrl ?? "/images/default-room.jpg")" 
                                     alt="Room @booking.Room?.RoomNumber" 
                                     class="w-full h-full object-cover">
                            </div>

                            <!-- Booking Details -->
                            <div class="md:w-2/3 p-6">
                                <div class="flex justify-between items-start mb-4">
                                    <div>
                                        <h3 class="text-2xl font-bold text-gray-900 mb-1">Room @booking.Room?.RoomNumber</h3>
                                        <p class="text-indigo-600 font-semibold">@(booking.Room?.RoomType?.Name ?? "Standard")</p>
                                    </div>
                                    <span class="px-4 py-2 rounded-full text-sm font-semibold
                                        @(booking.Status == "Confirmed" ? "bg-emerald-100 text-emerald-700" : 
                                          booking.Status == "Pending" ? "bg-amber-100 text-amber-700" : 
                                          booking.Status == "Cancelled" ? "bg-red-100 text-red-700" : 
                                          "bg-gray-100 text-gray-700")">
                                        @booking.Status
                                    </span>
                                </div>

                                <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                                    <div>
                                        <div class="text-sm text-gray-500 mb-1">Check-in</div>
                                        <div class="font-semibold text-gray-900">@booking.CheckInDate.ToString("MMM dd, yyyy")</div>
                                    </div>
                                    <div>
                                        <div class="text-sm text-gray-500 mb-1">Check-out</div>
                                        <div class="font-semibold text-gray-900">@booking.CheckOutDate.ToString("MMM dd, yyyy")</div>
                                    </div>
                                    <div>
                                        <div class="text-sm text-gray-500 mb-1">Total Price</div>
                                        <div class="font-semibold text-gray-900">$@booking.TotalPrice</div>
                                    </div>
                                </div>

                                <div class="flex gap-3">
                                    <a asp-action="Details" asp-route-id="@booking.BookingId" 
                                       class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-6 rounded-lg transition duration-200">
                                        View Details
                                    </a>
                                    @if (booking.Status == "Pending")
                                    {
                                        <a asp-controller="Payment" asp-action="Index" asp-route-bookingId="@booking.BookingId" 
                                           class="bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2 px-6 rounded-lg transition duration-200">
                                            Pay Now
                                        </a>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl shadow-lg p-12 text-center">
                <i class="fas fa-calendar-times text-gray-300 text-6xl mb-4"></i>
                <h3 class="text-2xl font-semibold text-gray-700 mb-2">No Bookings Yet</h3>
                <p class="text-gray-500 mb-6">Start exploring our rooms and make your first reservation</p>
                <a asp-controller="Room" asp-action="Index" 
                   class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-8 rounded-lg transition duration-200">
                    Browse Rooms
                </a>
            </div>
        }
    </div>
</div>
