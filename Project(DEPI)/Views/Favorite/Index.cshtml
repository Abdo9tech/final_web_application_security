@model IEnumerable<BookifyHotel.Model.Room>
@{
    ViewData["Title"] = "My Favorite Rooms";
}

<div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-gray-900 mb-2">My Favorite Rooms</h1>
            <p class="text-gray-600">Rooms you've saved for later</p>
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                @foreach (var room in Model)
                {
                    <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition duration-300">
                        <div class="relative h-64">
                            <img src="@(room.ImageUrl ?? "/images/default-room.jpg")" 
                                 alt="Room @room.RoomNumber" 
                                 class="w-full h-full object-cover">
                            @if (room.IsAvailable)
                            {
                                <span class="absolute top-4 right-4 bg-emerald-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                                    Available
                                </span>
                            }
                            else
                            {
                                <span class="absolute top-4 right-4 bg-red-500 text-white px-3 py-1 rounded-full text-sm font-semibold">
                                    Booked
                                </span>
                            }
                            <button onclick="toggleFavorite(@room.RoomId, this)" 
                                    class="absolute top-4 left-4 bg-white/90 hover:bg-white p-3 rounded-full transition">
                                <i class="fas fa-heart text-red-500 text-xl"></i>
                            </button>
                        </div>
                        <div class="p-6">
                            <div class="flex justify-between items-start mb-3">
                                <h3 class="text-xl font-bold text-gray-900">Room @room.RoomNumber</h3>
                                <span class="text-sm text-gray-500">Floor @room.Floor</span>
                            </div>
                            <p class="text-indigo-600 font-semibold mb-2">@(room.RoomType?.Name ?? "Standard")</p>
                            <p class="text-gray-600 text-sm mb-4">@(room.RoomType?.Description ?? "Comfortable room with modern amenities")</p>
                            <div class="flex items-center justify-between">
                                <div>
                                    <span class="text-3xl font-bold text-gray-900">$@(room.RoomType?.PricePerNight ?? 0)</span>
                                    <span class="text-gray-500 text-sm">/night</span>
                                </div>
                                <a asp-controller="Room" asp-action="Details" asp-route-id="@room.RoomId" 
                                   class="bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-6 rounded-lg transition duration-200">
                                    View Details
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="bg-white rounded-2xl shadow-lg p-12 text-center">
                <i class="fas fa-heart text-gray-300 text-6xl mb-4"></i>
                <h3 class="text-2xl font-semibold text-gray-700 mb-2">No Favorite Rooms Yet</h3>
                <p class="text-gray-500 mb-6">Start exploring and save your favorite rooms</p>
                <a asp-controller="Room" asp-action="Index" 
                   class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-8 rounded-lg transition duration-200">
                    Browse Rooms
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        async function toggleFavorite(roomId, button) {
            try {
                const response = await fetch('@Url.Action("Toggle", "Favorite")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    },
                    body: JSON.stringify(roomId)
                });

                const result = await response.json();
                
                if (result.success) {
                    if (result.action === 'removed') {
                        // Remove the card from view with animation
                        const card = button.closest('.bg-white');
                        card.style.opacity = '0';
                        card.style.transform = 'scale(0.9)';
                        setTimeout(() => {
                            card.remove();
                            // Check if no more favorites
                            const grid = document.querySelector('.grid');
                            if (grid && grid.children.length === 0) {
                                location.reload();
                            }
                        }, 300);
                    }
                }
            } catch (error) {
                console.error('Error toggling favorite:', error);
            }
        }
    </script>
}
