@model BookifyHotel.Model.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
}

<!-- Booking.com Style Login Page -->
<div class="min-h-screen bg-transparent flex flex-col items-center pt-20 px-4 relative z-10">
    <div class="w-full max-w-md animate-fade-in">
        <div class="bg-white/95 backdrop-blur-sm p-8 border border-white/20 rounded-lg shadow-2xl">
            <h1 class="text-2xl font-black text-gray-950 mb-6">Sign in or create an account</h1>
            
            <form asp-action="Login" method="post" class="space-y-4">
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-xs mb-4"></div>

                <div>
                    <label asp-for="Email" class="block text-sm font-bold text-gray-900 mb-1">
                        Email address
                    </label>
                    <input asp-for="Email" type="email" autocomplete="email"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-md focus:border-bookify-600 focus:ring-2 focus:ring-bookify-100 outline-none text-sm font-medium transition-all placeholder:text-gray-400"
                           placeholder="Enter your email address">
                    <span asp-validation-for="Email" class="text-red-600 text-xs mt-1 block"></span>
                </div>

                <div>
                    <label asp-for="Password" class="block text-sm font-bold text-gray-900 mb-1">
                        Password
                    </label>
                    <input asp-for="Password" type="password" autocomplete="current-password"
                           class="w-full px-4 py-2.5 border border-gray-300 rounded-md focus:border-bookify-600 focus:ring-2 focus:ring-bookify-100 outline-none text-sm font-medium transition-all placeholder:text-gray-400"
                           placeholder="Enter your password">
                    <span asp-validation-for="Password" class="text-red-600 text-xs mt-1 block"></span>
                </div>

                <div class="flex items-center">
                    <input asp-for="RememberMe" type="checkbox" id="remember-me"
                           class="h-4 w-4 text-blue-600 border-gray-300 rounded-sm">
                    <label for="remember-me" class="ml-2 block text-sm text-gray-700">
                        Keep me signed in
                    </label>
                </div>

                <button type="submit" 
                        class="w-full bg-bookify-600 hover:bg-bookify-700 text-white font-black py-4 rounded-md transition-all text-base shadow-lg hover:shadow-bookify-200/50 active:scale-95">
                    Sign in
                </button>
            </form>

            <div class="mt-6 border-t pt-6">
                <p class="text-center text-sm text-gray-600 mb-4">Or sign in with</p>
                <div class="grid grid-cols-3 gap-3 items-center">
                    <button type="button" class="flex justify-center items-center py-2 border border-gray-300 rounded-sm opacity-50 cursor-not-allowed bg-gray-50">
                        <i class="fab fa-facebook text-blue-600 text-lg"></i>
                    </button>
                    
                    <form asp-action="ExternalLogin" asp-route-returnUrl="@Context.Request.Query["ReturnUrl"]" method="post" class="w-full h-full flex items-center justify-center">
                        <button type="submit" name="provider" value="Google" class="flex justify-center items-center py-2 border border-gray-300 rounded-sm hover:bg-gray-50 w-full h-full">
                            <i class="fab fa-google text-red-500 text-lg"></i>
                        </button>
                    </form>
                    
                    <button type="button" class="flex justify-center items-center py-2 border border-gray-300 rounded-sm opacity-50 cursor-not-allowed bg-gray-50">
                        <i class="fab fa-apple text-black text-lg"></i>
                    </button>
                </div>
            </div>

            <div class="mt-8 text-center text-xs text-gray-500">
                <p>By signing in or creating an account, you agree with our <span class="text-blue-600 underline cursor-pointer">Terms & Conditions</span> and <span class="text-blue-600 underline cursor-pointer">Privacy Statement</span></p>
                <div class="mt-6 border-t pt-4">
                    <p>All rights reserved.</p>
                    <p>Copyright (2006-2024) - Bookify.com™</p>
                </div>
            </div>
        </div>

        <div class="mt-6 text-center">
            <a asp-controller="Register" asp-action="Register" class="text-sm font-bold text-blue-600 hover:underline">
                Create an account
            </a>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Remove any existing animations or effects
        document.addEventListener('DOMContentLoaded', function() {
            // Clean up any conflicting styles
            const body = document.body;
            body.className = body.className.replace(/bg-gradient-to-br|from-indigo-600|via-purple-600|to-pink-500/g, 'bg-gray-50');
        });
    </script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
