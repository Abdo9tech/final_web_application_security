@model Project_DEPI.ViewModels.BookNowViewModel
@{
    ViewData["Title"] = "Book Your Room";
}

<!-- Booking Form Section -->
<!-- Booking Progress Steps -->
<div class="bg-white border-b py-4 mb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between max-w-3xl mx-auto">
            <div class="flex items-center text-blue-600 font-bold text-sm">
                <span class="w-6 h-6 rounded-full bg-blue-600 text-white flex items-center justify-center mr-2 text-xs">1</span>
                Your selection
            </div>
            <div class="h-[1px] flex-1 bg-gray-200 mx-4"></div>
            <div class="flex items-center text-gray-400 font-bold text-sm">
                <span class="w-6 h-6 rounded-full border border-gray-400 flex items-center justify-center mr-2 text-xs">2</span>
                Your details
            </div>
            <div class="h-[1px] flex-1 bg-gray-200 mx-4"></div>
            <div class="flex items-center text-gray-400 font-bold text-sm">
                <span class="w-6 h-6 rounded-full border border-gray-400 flex items-center justify-center mr-2 text-xs">3</span>
                Final step
            </div>
        </div>
    </div>
</div>

<section class="bg-gray-50 min-h-screen py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        @if (TempData["Error"] != null)
        {
            <div class="mb-6 bg-red-100 border-l-4 border-red-600 p-4 text-red-700 text-sm">
                @TempData["Error"]
            </div>
        }

        <div class="flex flex-col lg:flex-row gap-6">
            <!-- Sidebar Summary (Top on mobile) -->
            <aside class="lg:w-80 flex-shrink-0 order-1 lg:order-1">
                <div class="bg-white border rounded-sm overflow-hidden shadow-sm">
                    <div class="p-4 border-b">
                        <h3 class="font-bold text-sm">Your booking details</h3>
                    </div>
                    <div class="p-4">
                        <div class="flex gap-4 mb-4">
                            <div class="w-20 h-20 flex-shrink-0">
                                <img src="https://images.unsplash.com/photo-1590490360182-c33d57733427?auto=format&fit=crop&q=80&w=200" class="w-full h-full object-cover rounded-sm" alt="Room">
                            </div>
                            <div>
                                <h4 class="font-bold text-sm text-gray-900">Room @Model.RoomNumber</h4>
                                <p class="text-xs text-gray-500">@Model.RoomType</p>
                                <div class="flex text-yellow-400 text-[8px] mt-1">
                                    <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-3 py-4 border-t text-sm">
                            <div class="flex justify-between">
                                <span class="font-bold">Check-in</span>
                                <span id="summaryCheckIn" class="text-gray-600">Select date</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="font-bold">Check-out</span>
                                <span id="summaryCheckOut" class="text-gray-600">Select date</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="font-bold">Total stay:</span>
                                <span id="summaryNights" class="text-gray-600">- nights</span>
                            </div>
                        </div>

                        <div class="bg-blue-50 p-4 -mx-4 -mb-4 mt-4">
                            <div class="flex justify-between items-end">
                                <div>
                                    <p class="text-lg font-bold">Price</p>
                                    <p class="text-[10px] text-gray-500">Includes taxes and charges</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-2xl font-bold text-gray-900" id="summaryTotal">US$0</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white border rounded-sm p-4 mt-4 shadow-sm">
                    <h4 class="font-bold text-xs mb-3">Your price summary</h4>
                    <div class="space-y-2 text-xs">
                        <div class="flex justify-between text-gray-600">
                            <span>Room price</span>
                            <span id="priceBase">US$0</span>
                        </div>
                        <div class="flex justify-between text-gray-600">
                            <span>10% Tax</span>
                            <span id="priceTax">US$0</span>
                        </div>
                    </div>
                </div>
            </aside>

            <!-- Main Form -->
            <div class="flex-1 order-2 lg:order-2">
                <div class="bg-white border rounded-sm p-6 shadow-sm mb-6">
                    <h2 class="text-xl font-bold text-gray-900 mb-6">Enter your details</h2>
                    
                    <form asp-action="ProcessBooking" method="post" id="bookingForm" class="space-y-6">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="RoomId" />
                        <input type="hidden" asp-for="RoomNumber" />
                        <input type="hidden" asp-for="RoomType" />
                        <input type="hidden" asp-for="PricePerNight" />
                        <input type="hidden" asp-for="PublishableKey" />

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <label asp-for="CheckInDate" class="block text-sm font-bold text-gray-700 mb-2">Check-in Date</label>
                                <input asp-for="CheckInDate" type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")"
                                       class="w-full px-3 py-2 border border-gray-400 rounded-sm focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none text-sm" required />
                                <span asp-validation-for="CheckInDate" class="text-red-600 text-[10px]"></span>
                            </div>

                            <div>
                                <label asp-for="CheckOutDate" class="block text-sm font-bold text-gray-700 mb-2">Check-out Date</label>
                                <input asp-for="CheckOutDate" type="date" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                                       class="w-full px-3 py-2 border border-gray-400 rounded-sm focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none text-sm" required />
                                <span asp-validation-for="CheckOutDate" class="text-red-600 text-[10px]"></span>
                            </div>

                            <div>
                                <label asp-for="NumberOfGuests" class="block text-sm font-bold text-gray-700 mb-2">Guests</label>
                                <select asp-for="NumberOfGuests" class="w-full px-3 py-2 border border-gray-400 rounded-sm text-sm">
                                    @for(int i=1; i<=6; i++) { <option value="@i">@i Adults</option> }
                                </select>
                            </div>
                        </div>

                        <div>
                            <label asp-for="SpecialRequests" class="block text-sm font-bold text-gray-700 mb-2">Special Requests (Optional)</label>
                            <textarea asp-for="SpecialRequests" rows="3" placeholder="Please write your requests in English or Arabic"
                                      class="w-full px-3 py-2 border border-gray-400 rounded-sm focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none text-sm resize-none"></textarea>
                            <p class="text-[10px] text-gray-500 mt-1">Special requests cannot be guaranteed – but the property will do its best to meet your needs.</p>
                        </div>

                        <div class="pt-6 border-t flex justify-end">
                            <button type="submit" id="submitButton"
                                    class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 px-8 rounded-sm transition-colors text-sm flex items-center space-x-2 shadow-sm">
                                <span id="buttonText">Next: Final details</span>
                                <i id="buttonIcon" class="fas fa-chevron-right text-[10px] ml-2"></i>
                                <span id="loadingSpinner" class="hidden"><i class="fas fa-spinner fa-spin"></i></span>
                            </button>
                        </div>
                    </form>
                </div>

                <div class="bg-blue-50 border border-blue-200 rounded-sm p-4 flex items-start space-x-4">
                    <i class="fas fa-info-circle text-blue-600 mt-1"></i>
                    <div class="text-xs text-gray-700">
                        <p class="font-bold mb-1">Your data is safe</p>
                        <p>We use encrypted transmission to protect your personal information.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const checkInInput = document.querySelector('input[name="CheckInDate"]');
            const checkOutInput = document.querySelector('input[name="CheckOutDate"]');
            const pricePerNight = @Model.PricePerNight;

            function calculatePrice() {
                const checkIn = new Date(checkInInput.value);
                const checkOut = new Date(checkOutInput.value);

                if (checkInInput.value) {
                    document.getElementById('summaryCheckIn').textContent = checkIn.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
                }
                if (checkOutInput.value) {
                    document.getElementById('summaryCheckOut').textContent = checkOut.toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
                }

                if (checkIn && checkOut && checkOut > checkIn) {
                    const nights = Math.ceil((checkOut - checkIn) / (1000 * 60 * 60 * 24));
                    const roomTotal = nights * pricePerNight;
                    const tax = roomTotal * 0.1;
                    const grandTotal = roomTotal + tax;

                    document.getElementById('summaryNights').textContent = nights + (nights === 1 ? ' night' : ' nights');
                    document.getElementById('priceBase').textContent = 'US$' + roomTotal.toLocaleString();
                    document.getElementById('priceTax').textContent = 'US$' + tax.toLocaleString();
                    document.getElementById('summaryTotal').textContent = 'US$' + grandTotal.toLocaleString();
                } else {
                    document.getElementById('summaryNights').textContent = '- nights';
                    document.getElementById('priceBase').textContent = 'US$0';
                    document.getElementById('priceTax').textContent = 'US$0';
                    document.getElementById('summaryTotal').textContent = 'US$0';
                }
            }

            checkInInput.addEventListener('change', function() {
                const checkInDate = new Date(this.value);
                const minCheckOut = new Date(checkInDate);
                minCheckOut.setDate(minCheckOut.getDate() + 1);
                checkOutInput.min = minCheckOut.toISOString().split('T')[0];
                
                if (checkOutInput.value && new Date(checkOutInput.value) <= checkInDate) {
                    checkOutInput.value = '';
                }
                calculatePrice();
            });

            checkOutInput.addEventListener('change', calculatePrice);
            calculatePrice();

            const bookingForm = document.getElementById('bookingForm');
            const submitButton = document.getElementById('submitButton');
            const buttonText = document.getElementById('buttonText');
            const buttonIcon = document.getElementById('buttonIcon');
            const loadingSpinner = document.getElementById('loadingSpinner');

            bookingForm.addEventListener('submit', function(e) {
                if (!checkInInput.value || !checkOutInput.value) {
                    e.preventDefault();
                    return false;
                }
                
                submitButton.disabled = true;
                buttonText.textContent = 'Processing...';
                buttonIcon.classList.add('hidden');
                loadingSpinner.classList.remove('hidden');
                return true;
            });
        });
    </script>
}
}
