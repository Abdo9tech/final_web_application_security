@model Project_DEPI.ViewModels.PaymentViewModel
@{
    ViewData["Title"] = "Payment";
}

<!-- Payment Section -->
<!-- Booking Progress Steps -->
<div class="bg-white border-b py-4 mb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between max-w-3xl mx-auto">
            <div class="flex items-center text-green-600 font-bold text-sm">
                <span class="w-6 h-6 rounded-full bg-green-600 text-white flex items-center justify-center mr-2 text-xs"><i class="fas fa-check"></i></span>
                Your selection
            </div>
            <div class="h-[1px] flex-1 bg-green-200 mx-4"></div>
            <div class="flex items-center text-blue-600 font-bold text-sm">
                <span class="w-6 h-6 rounded-full bg-blue-600 text-white flex items-center justify-center mr-2 text-xs">2</span>
                Final details
            </div>
            <div class="h-[1px] flex-1 bg-gray-200 mx-4"></div>
            <div class="flex items-center text-gray-400 font-bold text-sm">
                <span class="w-6 h-6 rounded-full border border-gray-400 flex items-center justify-center mr-2 text-xs">3</span>
                Confirmation
            </div>
        </div>
    </div>
</div>

<section class="bg-gray-50 min-h-screen py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="flex flex-col lg:flex-row gap-6">
            <!-- Sidebar Summary -->
            <aside class="lg:w-80 flex-shrink-0 order-1 lg:order-1">
                <div class="bg-white border rounded-sm overflow-hidden shadow-sm">
                    <div class="p-4 border-b">
                        <h3 class="font-bold text-sm">Your booking summary</h3>
                    </div>
                    <div class="p-4">
                        <div class="mb-4">
                            <h4 class="font-bold text-sm text-gray-900">Room @Model.RoomNumber</h4>
                            <p class="text-xs text-gray-500">@Model.RoomType</p>
                        </div>

                        <div class="space-y-3 py-4 border-t text-xs">
                            <div class="flex justify-between">
                                <span class="font-bold">Check-in:</span>
                                <span class="text-gray-600">@Model.CheckInDate.ToString("ddd, dd MMM yyyy")</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="font-bold">Check-out:</span>
                                <span class="text-gray-600">@Model.CheckOutDate.ToString("ddd, dd MMM yyyy")</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="font-bold">Total stay:</span>
                                <span class="text-gray-600">@Model.NumberOfNights night(s)</span>
                            </div>
                        </div>

                        <div class="bg-blue-50 p-4 -mx-4 -mb-4 mt-4">
                            <div class="flex justify-between items-end">
                                <div>
                                    <p class="text-lg font-bold">Total Price</p>
                                    <p class="text-[10px] text-gray-500">Includes taxes and charges</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-2xl font-bold text-gray-900">US$@Model.Amount.ToString("F2")</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="bg-white border rounded-sm p-4 mt-4 shadow-sm text-xs text-gray-600">
                    <h4 class="font-bold text-gray-900 mb-2">Cancellation Policy</h4>
                    <p class="text-green-700 font-bold mb-2"><i class="fas fa-check mr-1"></i> Free cancellation anytime!</p>
                    <p>Risk-free: You can cancel later, so lock in this great price today.</p>
                </div>
            </aside>

            <!-- Payment Content -->
            <div class="flex-1 order-2 lg:order-2">
                <div class="bg-white border rounded-sm p-6 shadow-sm mb-6">
                    <h2 class="text-xl font-bold text-gray-900 mb-6">How do you want to pay?</h2>
                    
                    <div class="flex items-center space-x-4 mb-8 bg-gray-50 p-3 rounded-sm">
                        <i class="fas fa-lock text-gray-400"></i>
                        <span class="text-xs text-gray-600">Your payment is secure and your card details are protected.</span>
                    </div>

                    <!-- Stripe Payment Form -->
                    <div class="max-w-xl">
                        <form id="payment-form">
                            <div id="payment-element" class="mb-6">
                                <!-- Stripe.js injects the Payment Element here -->
                            </div>

                            <div id="payment-message" class="hidden mb-6 p-4 rounded-sm text-xs font-bold"></div>

                            <div class="pt-6 border-t">
                                <button type="submit" id="submit-button"
                                        class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-4 px-8 rounded-sm transition-colors text-sm flex items-center justify-center space-x-2 w-full md:w-auto shadow-sm">
                                    <i class="fas fa-lock text-[10px]"></i>
                                    <span id="button-text">Book and Pay US$@Model.Amount.ToString("F2")</span>
                                    <div id="spinner" class="hidden"><i class="fas fa-spinner fa-spin"></i></div>
                                </button>
                                <p class="text-[10px] text-gray-500 mt-4">
                                    By clicking "Book and Pay", you agree to our <span class="text-blue-600 underline">Terms and Conditions</span> and <span class="text-blue-600 underline">Privacy Policy</span>.
                                </p>
                            </div>
                        </form>
                    </div>

                    <!-- Test Card Info -->
                    <div class="mt-12 p-4 border border-blue-200 bg-blue-50 rounded-sm">
                        <h4 class="font-bold text-sm text-blue-900 mb-2">Test Card Information</h4>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-xs text-blue-800">
                            <div>
                                <p class="font-bold">Success:</p>
                                <p>4242 4242 4242 4242</p>
                            </div>
                            <div>
                                <p class="font-bold">Declined:</p>
                                <p>4000 0000 0000 9995</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://js.stripe.com/v3/"></script>
    <script>
        const stripe = Stripe('@Model.PublishableKey');
        const options = {
            clientSecret: '@Model.ClientSecret',
            appearance: {
                theme: 'stripe',
                variables: {
                    colorPrimary: '#6366f1',
                    colorBackground: '#ffffff',
                    colorText: '#1f2937',
                    colorDanger: '#ef4444',
                    fontFamily: 'Inter, system-ui, sans-serif',
                    spacingUnit: '4px',
                    borderRadius: '8px'
                }
            }
        };

        const elements = stripe.elements(options);
        const paymentElement = elements.create('payment');
        paymentElement.mount('#payment-element');

        const form = document.getElementById('payment-form');
        const submitButton = document.getElementById('submit-button');
        const buttonText = document.getElementById('button-text');
        const spinner = document.getElementById('spinner');
        const messageContainer = document.getElementById('payment-message');

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            setLoading(true);

            const { error } = await stripe.confirmPayment({
                elements,
                confirmParams: {
                    return_url: window.location.origin + '/BookNow/Success/@Model.BookingId',
                },
            });

            if (error) {
                showMessage(error.message, 'error');
                setLoading(false);
            }
        });

        function setLoading(isLoading) {
            submitButton.disabled = isLoading;
            if (isLoading) {
                spinner.classList.remove('hidden');
                buttonText.classList.add('hidden');
            } else {
                spinner.classList.add('hidden');
                buttonText.classList.remove('hidden');
            }
        }

        function showMessage(message, type = 'error') {
            messageContainer.textContent = message;
            messageContainer.classList.remove('hidden');
            
            if (type === 'error') {
                messageContainer.classList.add('bg-red-50', 'text-red-800', 'border', 'border-red-200');
                messageContainer.classList.remove('bg-emerald-50', 'text-emerald-800', 'border-emerald-200');
            } else {
                messageContainer.classList.add('bg-emerald-50', 'text-emerald-800', 'border', 'border-emerald-200');
                messageContainer.classList.remove('bg-red-50', 'text-red-800', 'border-red-200');
            }

            setTimeout(() => {
                messageContainer.classList.add('hidden');
            }, 5000);
        }
    </script>
}
