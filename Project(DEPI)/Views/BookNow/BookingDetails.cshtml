@model BookifyHotel.Model.Booking
@{
    ViewData["Title"] = "Booking Details";
}

<!-- Booking Details Section -->
<section class="min-h-screen bg-gray-50 py-12">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8">
            <a asp-controller="Booking" asp-action="MyBookings" 
               class="inline-flex items-center text-primary-600 hover:text-primary-700 mb-4">
                <i class="fas fa-arrow-left mr-2"></i> Back to My Bookings
            </a>
            <h1 class="text-4xl font-bold text-gray-900">Booking Details</h1>
        </div>

        <!-- Status Banner -->
        <div class="mb-8">
            @{
                var statusClass = Model.Status.ToLower() switch
                {
                    "confirmed" => "bg-emerald-100 text-emerald-800 border-emerald-200",
                    "pending" => "bg-amber-100 text-amber-800 border-amber-200",
                    "cancelled" => "bg-red-100 text-red-800 border-red-200",
                    _ => "bg-gray-100 text-gray-800 border-gray-200"
                };
                var statusIcon = Model.Status.ToLower() switch
                {
                    "confirmed" => "fa-check-circle",
                    "pending" => "fa-clock",
                    "cancelled" => "fa-times-circle",
                    _ => "fa-info-circle"
                };
            }
            <div class="@statusClass border-2 rounded-xl p-6 flex items-center justify-between">
                <div class="flex items-center">
                    <i class="fas @statusIcon text-3xl mr-4"></i>
                    <div>
                        <h2 class="text-2xl font-bold">Booking #@Model.BookingId</h2>
                        <p class="text-sm">Status: <span class="font-semibold capitalize">@Model.Status</span></p>
                    </div>
                </div>
                <div class="text-right">
                    <div class="text-3xl font-bold">$@Model.TotalPrice.ToString("F2")</div>
                    <div class="text-sm">Total Amount</div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Main Details -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Room Information -->
                <div class="bg-white rounded-xl shadow-lg p-6">
                    <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
                        <i class="fas fa-bed text-primary-600 mr-2"></i> Room Information
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="text-sm text-gray-600">Room Number</label>
                            <p class="font-medium text-gray-900">@Model.Room.RoomNumber</p>
                        </div>
                        <div>
                            <label class="text-sm text-gray-600">Room Type</label>
                            <p class="font-medium text-gray-900">@(Model.Room.RoomType?.Name ?? "Standard")</p>
                        </div>
                        <div>
                            <label class="text-sm text-gray-600">Floor</label>
                            <p class="font-medium text-gray-900">@Model.Room.Floor</p>
                        </div>
                        <div>
                            <label class="text-sm text-gray-600">Price per Night</label>
                            <p class="font-medium text-gray-900">$@(Model.Room.RoomType?.PricePerNight ?? 0)</p>
                        </div>
                    </div>
                </div>

                <!-- Stay Information -->
                <div class="bg-white rounded-xl shadow-lg p-6">
                    <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
                        <i class="fas fa-calendar-alt text-emerald-600 mr-2"></i> Stay Information
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <label class="text-sm text-gray-600">Check-in Date</label>
                            <p class="font-medium text-gray-900">@Model.CheckInDate.ToString("MMMM dd, yyyy")</p>
                            <p class="text-sm text-gray-500">After 3:00 PM</p>
                        </div>
                        <div>
                            <label class="text-sm text-gray-600">Check-out Date</label>
                            <p class="font-medium text-gray-900">@Model.CheckOutDate.ToString("MMMM dd, yyyy")</p>
                            <p class="text-sm text-gray-500">Before 11:00 AM</p>
                        </div>
                        <div>
                            <label class="text-sm text-gray-600">Number of Nights</label>
                            <p class="font-medium text-gray-900">@((Model.CheckOutDate - Model.CheckInDate).Days) night(s)</p>
                        </div>
                        <div>
                            <label class="text-sm text-gray-600">Booking Date</label>
                            <p class="font-medium text-gray-900">@Model.BookingDate.ToString("MMM dd, yyyy")</p>
                        </div>
                    </div>
                </div>

                <!-- Payment Information -->
                @if (Model.Payments != null && Model.Payments.Any())
                {
                    <div class="bg-white rounded-xl shadow-lg p-6">
                        <h3 class="text-xl font-bold text-gray-900 mb-4 flex items-center">
                            <i class="fas fa-credit-card text-sky-600 mr-2"></i> Payment Information
                        </h3>
                        @foreach (var payment in Model.Payments)
                        {
                            <div class="border-b border-gray-200 pb-4 mb-4 last:border-0 last:pb-0 last:mb-0">
                                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                    <div>
                                        <label class="text-sm text-gray-600">Amount Paid</label>
                                        <p class="font-medium text-gray-900">$@payment.Amount.ToString("F2")</p>
                                    </div>
                                    <div>
                                        <label class="text-sm text-gray-600">Payment Method</label>
                                        <p class="font-medium text-gray-900 capitalize">@payment.PaymentMethod</p>
                                    </div>
                                    <div>
                                        <label class="text-sm text-gray-600">Payment Status</label>
                                        <p class="font-medium text-emerald-600 capitalize">@payment.PaymentStatus</p>
                                    </div>
                                    <div>
                                        <label class="text-sm text-gray-600">Payment Date</label>
                                        <p class="font-medium text-gray-900">@payment.PaymentDate.ToString("MMM dd, yyyy")</p>
                                    </div>
                                    @if (!string.IsNullOrEmpty(payment.TransactionRefrence))
                                    {
                                        <div class="md:col-span-2">
                                            <label class="text-sm text-gray-600">Transaction Reference</label>
                                            <p class="font-mono text-sm text-gray-900 break-all">@payment.TransactionRefrence</p>
                                        </div>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>

            <!-- Sidebar -->
            <div class="lg:col-span-1 space-y-6">
                <!-- Quick Actions -->
                <div class="bg-white rounded-xl shadow-lg p-6">
                    <h3 class="text-lg font-bold text-gray-900 mb-4">Quick Actions</h3>
                    <div class="space-y-3">
                        @if (Model.Status.ToLower() == "pending")
                        {
                            <a asp-controller="BookNow" asp-action="Payment" asp-route-bookingId="@Model.BookingId"
                               class="block w-full bg-emerald-600 hover:bg-emerald-700 text-white text-center py-3 rounded-lg font-medium transition-colors">
                                <i class="fas fa-credit-card mr-2"></i> Complete Payment
                            </a>
                        }
                        <a asp-controller="Room" asp-action="Details" asp-route-id="@Model.RoomId"
                           class="block w-full bg-primary-600 hover:bg-primary-700 text-white text-center py-3 rounded-lg font-medium transition-colors">
                            <i class="fas fa-eye mr-2"></i> View Room
                        </a>
                        @if (Model.Status.ToLower() == "confirmed" && Model.CheckInDate > DateTime.Now.AddDays(1))
                        {
                            <button onclick="cancelBooking(@Model.BookingId)"
                                    class="block w-full bg-red-600 hover:bg-red-700 text-white text-center py-3 rounded-lg font-medium transition-colors">
                                <i class="fas fa-times mr-2"></i> Cancel Booking
                            </button>
                        }
                    </div>
                </div>

                <!-- Contact Support -->
                <div class="bg-gradient-to-br from-primary-600 to-primary-700 rounded-xl shadow-lg p-6 text-white">
                    <h3 class="text-lg font-bold mb-4">Need Help?</h3>
                    <p class="text-primary-100 text-sm mb-4">Our support team is here to assist you 24/7</p>
                    <div class="space-y-3">
                        <a href="tel:+1234567890" class="flex items-center text-white hover:text-primary-100 transition-colors">
                            <i class="fas fa-phone mr-2"></i> +1 (234) 567-890
                        </a>
                        <a href="mailto:support@bookifyhotel.com" class="flex items-center text-white hover:text-primary-100 transition-colors">
                            <i class="fas fa-envelope mr-2"></i> support@bookifyhotel.com
                        </a>
                    </div>
                </div>

                <!-- Important Info -->
                <div class="bg-amber-50 border-2 border-amber-200 rounded-xl p-6">
                    <h3 class="text-lg font-bold text-amber-900 mb-3 flex items-center">
                        <i class="fas fa-info-circle mr-2"></i> Important Info
                    </h3>
                    <ul class="space-y-2 text-sm text-amber-800">
                        <li class="flex items-start">
                            <i class="fas fa-check text-amber-600 mr-2 mt-1"></i>
                            <span>Check-in: 3:00 PM</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check text-amber-600 mr-2 mt-1"></i>
                            <span>Check-out: 11:00 AM</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check text-amber-600 mr-2 mt-1"></i>
                            <span>Free cancellation up to 24 hours before check-in</span>
                        </li>
                        <li class="flex items-start">
                            <i class="fas fa-check text-amber-600 mr-2 mt-1"></i>
                            <span>Valid ID required at check-in</span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        function cancelBooking(bookingId) {
            Swal.fire({
                title: 'Cancel Booking?',
                text: "Are you sure you want to cancel this booking? This action cannot be undone.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#6b7280',
                confirmButtonText: 'Yes, cancel it',
                cancelButtonText: 'No, keep it'
            }).then((result) => {
                if (result.isConfirmed) {
                    // TODO: Implement cancel booking logic
                    Swal.fire(
                        'Cancelled!',
                        'Your booking has been cancelled.',
                        'success'
                    );
                }
            });
        }
    </script>
}
