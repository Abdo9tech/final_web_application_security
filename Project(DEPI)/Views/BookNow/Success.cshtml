@model BookifyHotel.Model.Booking
@{
    ViewData["Title"] = "Booking Confirmed";
}

<!-- Success Section -->
<section class="min-h-screen bg-gradient-to-br from-emerald-50 to-sky-50 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Success Icon -->
        <div class="text-center mb-8">
            <div class="inline-flex items-center justify-center w-24 h-24 bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-full mb-6 animate-bounce">
                <i class="fas fa-check text-5xl text-white"></i>
            </div>
            <h1 class="text-4xl font-bold text-gray-900 mb-2">Booking Confirmed!</h1>
            <p class="text-xl text-gray-600">Thank you for choosing Bookify Hotel</p>
        </div>

        <!-- Booking Details Card -->
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden mb-8">
            <!-- Header -->
            <div class="bg-gradient-to-r from-primary-600 to-primary-700 px-8 py-6">
                <div class="flex items-center justify-between text-white">
                    <div>
                        <h2 class="text-2xl font-bold mb-1">Booking #@Model.BookingId</h2>
                        <p class="text-primary-100">Confirmation Number</p>
                    </div>
                    <div class="text-right">
                        <div class="text-3xl font-bold">$@Model.TotalPrice.ToString("F2")</div>
                        <div class="text-primary-100">Total Paid</div>
                    </div>
                </div>
            </div>

            <!-- Details -->
            <div class="p-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
                    <!-- Room Information -->
                    <div>
                        <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                            <i class="fas fa-bed text-primary-600 mr-2"></i> Room Information
                        </h3>
                        <div class="space-y-3">
                            <div class="flex justify-between">
                                <span class="text-gray-600">Room Number:</span>
                                <span class="font-medium text-gray-900">@Model.Room.RoomNumber</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-600">Room Type:</span>
                                <span class="font-medium text-gray-900">@(Model.Room.RoomType?.Name ?? "Standard")</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-600">Floor:</span>
                                <span class="font-medium text-gray-900">@Model.Room.Floor</span>
                            </div>
                        </div>
                    </div>

                    <!-- Stay Information -->
                    <div>
                        <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                            <i class="fas fa-calendar-alt text-emerald-600 mr-2"></i> Stay Information
                        </h3>
                        <div class="space-y-3">
                            <div class="flex justify-between">
                                <span class="text-gray-600">Check-in:</span>
                                <span class="font-medium text-gray-900">@Model.CheckInDate.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-600">Check-out:</span>
                                <span class="font-medium text-gray-900">@Model.CheckOutDate.ToString("MMM dd, yyyy")</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-600">Duration:</span>
                                <span class="font-medium text-gray-900">@((Model.CheckOutDate - Model.CheckInDate).Days) night(s)</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Payment Information -->
                @if (Model.Payments != null && Model.Payments.Any())
                {
                    var payment = Model.Payments.First();
                    <div class="pt-6 border-t border-gray-200">
                        <h3 class="text-lg font-bold text-gray-900 mb-4 flex items-center">
                            <i class="fas fa-credit-card text-sky-600 mr-2"></i> Payment Information
                        </h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <div class="flex justify-between">
                                <span class="text-gray-600">Payment Method:</span>
                                <span class="font-medium text-gray-900 capitalize">@payment.PaymentMethod</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-600">Payment Status:</span>
                                <span class="inline-flex items-center px-3 py-1 bg-emerald-100 text-emerald-700 text-sm font-semibold rounded-full capitalize">
                                    <i class="fas fa-check-circle mr-1"></i> @payment.PaymentStatus
                                </span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-600">Transaction ID:</span>
                                <span class="font-medium text-gray-900 text-sm">@payment.TransactionRefrence?.Substring(0, Math.Min(20, payment.TransactionRefrence.Length))...</span>
                            </div>
                            <div class="flex justify-between">
                                <span class="text-gray-600">Payment Date:</span>
                                <span class="font-medium text-gray-900">@payment.PaymentDate.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Next Steps -->
        <div class="bg-white rounded-2xl shadow-xl p-8 mb-8">
            <h3 class="text-2xl font-bold text-gray-900 mb-6">What's Next?</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div class="text-center">
                    <div class="w-16 h-16 bg-primary-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-envelope text-2xl text-primary-600"></i>
                    </div>
                    <h4 class="font-bold text-gray-900 mb-2">Check Your Email</h4>
                    <p class="text-sm text-gray-600">We've sent a confirmation email with all the details</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-mobile-alt text-2xl text-emerald-600"></i>
                    </div>
                    <h4 class="font-bold text-gray-900 mb-2">Download Our App</h4>
                    <p class="text-sm text-gray-600">Get mobile check-in and room key access</p>
                </div>
                <div class="text-center">
                    <div class="w-16 h-16 bg-sky-100 rounded-full flex items-center justify-center mx-auto mb-4">
                        <i class="fas fa-concierge-bell text-2xl text-sky-600"></i>
                    </div>
                    <h4 class="font-bold text-gray-900 mb-2">Contact Concierge</h4>
                    <p class="text-sm text-gray-600">Need special arrangements? We're here to help</p>
                </div>
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <a asp-controller="Booking" asp-action="MyBookings" 
               class="inline-flex items-center justify-center px-8 py-4 bg-primary-600 hover:bg-primary-700 text-white font-bold rounded-lg shadow-lg hover:shadow-xl transition-all">
                <i class="fas fa-list mr-2"></i> View My Bookings
            </a>
            <a asp-controller="Home" asp-action="Index" 
               class="inline-flex items-center justify-center px-8 py-4 bg-white hover:bg-gray-50 text-gray-900 font-bold rounded-lg shadow-lg hover:shadow-xl border-2 border-gray-300 transition-all">
                <i class="fas fa-home mr-2"></i> Back to Home
            </a>
        </div>

        <!-- Support Info -->
        <div class="mt-8 text-center text-gray-600">
            <p class="mb-2">Need help? Contact us at:</p>
            <div class="flex flex-wrap justify-center gap-6">
                <a href="tel:+1234567890" class="flex items-center hover:text-primary-600 transition-colors">
                    <i class="fas fa-phone mr-2"></i> +1 (234) 567-890
                </a>
                <a href="mailto:support@bookifyhotel.com" class="flex items-center hover:text-primary-600 transition-colors">
                    <i class="fas fa-envelope mr-2"></i> support@bookifyhotel.com
                </a>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Confetti animation on page load
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Booking confirmed successfully!');
        });
    </script>
}
