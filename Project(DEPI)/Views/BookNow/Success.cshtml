@model BookifyHotel.Model.Booking
@{
    ViewData["Title"] = "Booking Confirmed";
}

<!-- Success Section -->
<!-- Booking Progress Steps -->
<div class="bg-white border-b py-4 mb-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between max-w-3xl mx-auto">
            <div class="flex items-center text-green-600 font-bold text-sm">
                <span class="w-6 h-6 rounded-full bg-green-600 text-white flex items-center justify-center mr-2 text-xs"><i class="fas fa-check"></i></span>
                Your selection
            </div>
            <div class="h-[1px] flex-1 bg-green-200 mx-4"></div>
            <div class="flex items-center text-green-600 font-bold text-sm">
                <span class="w-6 h-6 rounded-full bg-green-600 text-white flex items-center justify-center mr-2 text-xs"><i class="fas fa-check"></i></span>
                Final details
            </div>
            <div class="h-[1px] flex-1 bg-green-200 mx-4"></div>
            <div class="flex items-center text-blue-600 font-bold text-sm">
                <span class="w-6 h-6 rounded-full bg-blue-600 text-white flex items-center justify-center mr-2 text-xs">3</span>
                Confirmation
            </div>
        </div>
    </div>
</div>

<section class="bg-gray-50 min-h-screen py-4">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="bg-green-100 border border-green-200 rounded-sm p-6 mb-8 flex items-center space-x-4">
            <div class="w-12 h-12 bg-green-600 rounded-full flex items-center justify-center text-white text-2xl flex-shrink-0">
                <i class="fas fa-check"></i>
            </div>
            <div>
                <h1 class="text-xl font-bold text-green-900">Your booking is confirmed in Manchester!</h1>
                <p class="text-sm text-green-800">A confirmation email has been sent to your inbox.</p>
            </div>
        </div>

        <div class="flex flex-col lg:flex-row gap-6">
            <!-- Left Side: Property & Stay Info -->
            <div class="flex-1">
                <div class="bg-white border rounded-sm p-6 shadow-sm mb-6">
                    <div class="flex flex-col md:flex-row gap-6">
                        <div class="md:w-1/3">
                            <img src="@(string.IsNullOrEmpty(Model.Room?.ImageUrl) ? "https://images.unsplash.com/photo-1590490360182-c33d57733427?auto=format&fit=crop&q=80&w=400" : Model.Room.ImageUrl)" 
                                 class="w-full h-48 object-cover rounded-sm" alt="Room">
                        </div>
                        <div class="md:w-2/3">
                            <h2 class="text-xl font-bold text-gray-900 mb-2">Room @(Model.Room?.RoomNumber.ToString() ?? "N/A") - @(Model.Room?.RoomType?.Name ?? "Standard Room")</h2>
                            <div class="flex text-yellow-400 text-xs mb-4">
                                <i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i><i class="fas fa-star"></i>
                            </div>
                            
                            <div class="grid grid-cols-2 gap-4 text-sm mb-6">
                                <div>
                                    <p class="font-bold text-gray-700">Check-in</p>
                                    <p class="text-gray-600">@Model.CheckInDate.ToString("ddd, dd MMM yyyy")</p>
                                    <p class="text-xs text-gray-500">From 15:00</p>
                                </div>
                                <div>
                                    <p class="font-bold text-gray-700">Check-out</p>
                                    <p class="text-gray-600">@Model.CheckOutDate.ToString("ddd, dd MMM yyyy")</p>
                                    <p class="text-xs text-gray-500">Until 11:00</p>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="mt-8 pt-8 border-t">
                        <h3 class="font-bold text-gray-900 mb-4">Total Price</h3>
                        <div class="flex justify-between items-end">
                            <div>
                                <p class="text-2xl font-bold text-gray-900">US$@Model.TotalPrice.ToString("F2")</p>
                                <p class="text-xs text-gray-500">Paid in full via Stripe</p>
                            </div>
                            <button class="text-blue-600 font-bold text-sm hover:underline"><i class="fas fa-print mr-2"></i> Print confirmation</button>
                        </div>
                    </div>
                </div>

                <div class="bg-white border rounded-sm p-6 shadow-sm">
                    <h3 class="font-bold text-gray-900 mb-6">What happens next?</h3>
                    <div class="space-y-6">
                        <div class="flex items-start space-x-4">
                            <div class="w-8 h-8 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center flex-shrink-0"><i class="far fa-envelope"></i></div>
                            <div>
                                <p class="text-sm font-bold">Check your email</p>
                                <p class="text-xs text-gray-600">You'll find your confirmation email in your inbox. It contains all the details of your stay.</p>
                            </div>
                        </div>
                        <div class="flex items-start space-x-4">
                            <div class="w-8 h-8 bg-blue-50 text-blue-600 rounded-full flex items-center justify-center flex-shrink-0"><i class="fas fa-mobile-alt"></i></div>
                            <div>
                                <p class="text-sm font-bold">Manage your booking</p>
                                <p class="text-xs text-gray-600">You can change or cancel your booking at any time in your account settings.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side: Navigation Actions -->
            <div class="lg:w-80">
                <div class="bg-white border rounded-sm p-6 shadow-sm mb-6">
                    <h3 class="font-bold text-sm mb-4">Need help with your booking?</h3>
                    <div class="space-y-3">
                        <a asp-controller="Booking" asp-action="MyBookings" class="block w-full text-center bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 rounded-sm text-sm transition-colors">
                            Manage your booking
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="block w-full text-center border border-blue-600 text-blue-600 hover:bg-blue-50 font-bold py-2.5 rounded-sm text-sm transition-colors">
                            Make another booking
                        </a>
                    </div>
                </div>

                <div class="bg-blue-900 rounded-sm p-6 text-white shadow-sm">
                    <h3 class="font-bold text-sm mb-2">Save on your next stay</h3>
                    <p class="text-xs text-blue-100 mb-4">Sign in to see Secret Deals and save up to 15% on properties worldwide.</p>
                    <button class="w-full bg-white text-blue-900 font-bold py-2 rounded-sm text-sm hover:bg-gray-100 transition-colors">Sign in now</button>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Confetti animation on page load
        document.addEventListener('DOMContentLoaded', function() {
            console.log('Booking confirmed successfully!');
        });
    </script>
}
