@model BookifyHotel.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<!-- Booking.com Style Register Page -->
<div class="min-h-screen bg-transparent flex flex-col items-center pt-20 px-4 relative z-10">
    <div class="w-full max-w-md animate-fade-in">
        <div class="bg-white/95 backdrop-blur-sm p-8 border border-white/20 rounded-lg shadow-2xl">
            <h1 class="text-2xl font-black text-gray-950 mb-6">Create an account</h1>
            
            <form asp-action="Register" method="post" class="space-y-4">
                <div asp-validation-summary="ModelOnly" class="text-red-600 text-xs mb-4"></div>

                <div class="space-y-4">
                    <div>
                        <label asp-for="FullName" class="block text-sm font-bold text-gray-900 mb-1">
                            Full Name
                        </label>
                        <input asp-for="FullName" 
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-md focus:border-booking-600 focus:ring-2 focus:ring-booking-100 outline-none text-sm font-medium transition-all placeholder:text-gray-400"
                               placeholder="Enter your full name">
                        <span asp-validation-for="FullName" class="text-red-600 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="PhoneNumber" class="block text-sm font-bold text-gray-900 mb-1">
                            Phone Number
                        </label>
                        <input asp-for="PhoneNumber" type="tel"
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-md focus:border-booking-600 focus:ring-2 focus:ring-booking-100 outline-none text-sm font-medium transition-all placeholder:text-gray-400"
                               placeholder="Enter your phone number">
                        <span asp-validation-for="PhoneNumber" class="text-red-600 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Email" class="block text-sm font-bold text-gray-900 mb-1">
                            Email address
                        </label>
                        <input asp-for="Email" type="email" autocomplete="email"
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-md focus:border-booking-600 focus:ring-2 focus:ring-booking-100 outline-none text-sm font-medium transition-all placeholder:text-gray-400"
                               placeholder="Enter your email address">
                        <span asp-validation-for="Email" class="text-red-600 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="Password" class="block text-sm font-bold text-gray-900 mb-1">
                            Password
                        </label>
                        <input asp-for="Password" type="password" autocomplete="new-password"
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-md focus:border-booking-600 focus:ring-2 focus:ring-booking-100 outline-none text-sm font-medium transition-all placeholder:text-gray-400"
                               placeholder="Create a password">
                        <span asp-validation-for="Password" class="text-red-600 text-xs mt-1 block"></span>
                    </div>

                    <div>
                        <label asp-for="ConfirmPassword" class="block text-sm font-bold text-gray-900 mb-1">
                            Confirm password
                        </label>
                        <input asp-for="ConfirmPassword" type="password" autocomplete="new-password"
                               class="w-full px-4 py-2.5 border border-gray-300 rounded-md focus:border-booking-600 focus:ring-2 focus:ring-booking-100 outline-none text-sm font-medium transition-all placeholder:text-gray-400"
                               placeholder="Confirm your password">
                        <span asp-validation-for="ConfirmPassword" class="text-red-600 text-xs mt-1 block"></span>
                    </div>

                    <div class="flex items-start">
                        <div class="flex items-center h-5">
                            <input asp-for="AgreeToTerms" type="checkbox" id="agree-terms"
                                   class="h-4 w-4 text-blue-600 border-gray-300 rounded-sm">
                        </div>
                        <label for="agree-terms" class="ml-2 block text-xs text-gray-700">
                            I agree to the <span class="text-blue-600 underline cursor-pointer">Terms and Conditions</span> and <span class="text-blue-600 underline cursor-pointer">Privacy Statement</span>
                        </label>
                    </div>
                </div>

                <div class="mt-8">
                    <button type="submit" 
                            class="w-full bg-booking-600 hover:bg-booking-700 text-white font-black py-4 rounded-md transition-all text-base shadow-lg hover:shadow-booking-200/50 active:scale-95">
                        Create account
                    </button>
                </div>
            </form>

            <div class="mt-8 text-center text-xs text-gray-500">
                <p>Copyright (2006-2024) - Bookify.com™</p>
                <p class="mt-1">All rights reserved.</p>
            </div>
        </div>

        <div class="mt-6 text-center">
            <p class="text-sm text-gray-600">
                Already have an account? 
                <a asp-controller="Login" asp-action="Login" class="font-bold text-blue-600 hover:underline">
                    Sign in
                </a>
            </p>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
