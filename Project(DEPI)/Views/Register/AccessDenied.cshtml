@{
    ViewData["Title"] = "Access Denied";
}

<div class="min-h-screen bg-gradient-to-br from-red-50 via-white to-pink-50 flex items-center justify-center py-12 px-4">
    <div class="max-w-2xl w-full text-center">
        <div class="bg-white rounded-2xl shadow-2xl p-12">
            <div class="mb-8">
                <i class="fas fa-lock text-red-500 text-6xl mb-4"></i>
                <h1 class="text-4xl font-bold text-gray-900 mb-4">Access Denied</h1>
                <p class="text-gray-600 text-lg">You don't have permission to access this page.</p>
            </div>

            <div class="space-y-4">
                <a asp-controller="Home" asp-action="Index" 
                   class="inline-block bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-8 rounded-lg transition duration-200">
                    <i class="fas fa-home mr-2"></i>Back to Home
                </a>
                <p class="text-gray-500 text-sm">
                    If you believe this is an error, please contact the administrator.
                </p>
            </div>
        </div>
    </div>
</div>
