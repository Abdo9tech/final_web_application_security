@model DAL.ViewModels.SecurityViewModel
@{
    ViewData["Title"] = "Security Settings";
}

<div class="bg-gray-50 min-h-screen py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900">Manage account</h1>
        </div>

        <div class="flex flex-col lg:flex-row gap-8">
            <!-- Settings Sidebar -->
            <aside class="lg:w-64 flex-shrink-0">
                <nav class="bg-white border rounded-sm overflow-hidden">
                    <a asp-controller="Profile" asp-action="Index" class="flex items-center px-4 py-3 text-gray-700 hover:bg-gray-50 text-sm border-l-4 border-transparent">
                        <i class="far fa-user mr-3 w-5"></i> Personal details
                    </a>
                    <a asp-controller="Profile" asp-action="Security" class="flex items-center px-4 py-3 bg-blue-50 border-l-4 border-blue-600 text-blue-600 font-bold text-sm">
                        <i class="fas fa-shield-alt mr-3 w-5"></i> Security
                    </a>
                    <a href="/Booking/MyBookings" class="flex items-center px-4 py-3 text-gray-700 hover:bg-gray-50 text-sm border-l-4 border-transparent">
                        <i class="fas fa-suitcase mr-3 w-5"></i> Bookings
                    </a>
                    <a href="#" class="flex items-center px-4 py-3 text-gray-700 hover:bg-gray-50 text-sm border-l-4 border-transparent">
                        <i class="far fa-heart mr-3 w-5"></i> Saved lists
                    </a>
                </nav>
            </aside>

            <!-- Security Details -->
            <div class="flex-1 space-y-6">
                <!-- Change Password Card -->
                <div class="bg-white border rounded-sm p-6 md:p-8">
                    <h2 class="text-xl font-bold text-gray-900 mb-2">Security settings</h2>
                    <p class="text-sm text-gray-600 mb-8 border-b pb-6">Update your password and secure your account.</p>

                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="mb-6 p-4 bg-green-50 border-l-4 border-green-500 text-green-700 text-sm rounded-sm">
                            <i class="fas fa-check-circle mr-2"></i> @TempData["SuccessMessage"]
                        </div>
                    }

                    <form asp-action="ChangePassword" method="post" class="space-y-6">
                        <div asp-validation-summary="ModelOnly" class="text-red-600 text-xs mb-4"></div>

                        <div class="max-w-md space-y-6">
                            <div>
                                <label asp-for="CurrentPassword" class="block text-sm font-bold text-gray-700 mb-2">Current password</label>
                                <input asp-for="CurrentPassword" 
                                       class="w-full px-3 py-2.5 border border-gray-400 rounded-sm focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none text-sm"
                                       placeholder="Enter current password">
                                <span asp-validation-for="CurrentPassword" class="text-red-600 text-[10px]"></span>
                            </div>

                            <div>
                                <label asp-for="NewPassword" class="block text-sm font-bold text-gray-700 mb-2">New password</label>
                                <input asp-for="NewPassword" 
                                       class="w-full px-3 py-2.5 border border-gray-400 rounded-sm focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none text-sm"
                                       placeholder="Enter new password">
                                <span asp-validation-for="NewPassword" class="text-red-600 text-[10px]"></span>
                            </div>

                            <div>
                                <label asp-for="ConfirmNewPassword" class="block text-sm font-bold text-gray-700 mb-2">Confirm new password</label>
                                <input asp-for="ConfirmNewPassword" 
                                       class="w-full px-3 py-2.5 border border-gray-400 rounded-sm focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none text-sm"
                                       placeholder="Confirm new password">
                                <span asp-validation-for="ConfirmNewPassword" class="text-red-600 text-[10px]"></span>
                            </div>
                        </div>

                        <div class="pt-6 border-t flex flex-col md:flex-row gap-4">
                            <button type="submit" 
                                    class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 px-8 rounded-sm transition-colors text-sm">
                                Update Password
                            </button>
                            <a asp-controller="Profile" asp-action="Index" 
                               class="bg-white border border-blue-600 text-blue-600 hover:bg-blue-50 font-bold py-2.5 px-8 rounded-sm transition-colors text-sm text-center">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>

                <!-- Two-Factor Authentication Card -->
                <div class="bg-white border rounded-sm p-6 md:p-8">
                    <h2 class="text-xl font-bold text-gray-900 mb-2">Two-Factor Authentication (2FA)</h2>
                    <p class="text-sm text-gray-600 mb-6">Add an extra layer of security to your account by requiring more than just a password to sign in.</p>
                    
                    <div class="flex items-center justify-between border-t pt-6">
                        <div class="flex items-center space-x-3">
                            <div class="p-2 bg-gray-100 rounded-full text-gray-600">
                                <i class="fas fa-shield-alt text-lg"></i>
                            </div>
                            <div>
                                <div class="text-sm font-bold text-gray-900">Authenticator App</div>
                                <div class="text-xs text-gray-500">
                                    @(Model.Is2faEnabled ? "Currently active and protecting your account." : "Not configured yet.")
                                </div>
                            </div>
                        </div>
                        <div>
                            @if (Model.Is2faEnabled)
                            {
                                <form asp-action="Disable2fa" method="post" class="inline">
                                    <button type="submit" class="border border-red-600 text-red-600 hover:bg-red-50 text-sm font-bold py-2 px-4 rounded-sm transition-colors">
                                        Disable 2FA
                                    </button>
                                </form>
                            }
                            else
                            {
                                <a asp-action="Enable2fa" class="inline-block bg-blue-600 hover:bg-blue-700 text-white text-sm font-bold py-2 px-4 rounded-sm transition-colors text-center">
                                    Setup 2FA
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
