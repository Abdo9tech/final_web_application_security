@model DAL.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="min-h-screen bg-gradient-to-br from-indigo-50 via-white to-purple-50 py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-4xl font-bold text-gray-900 mb-2">My Profile</h1>
            <p class="text-gray-600">Manage your account information</p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Profile Sidebar -->
            <div class="lg:col-span-1">
                <div class="bg-white rounded-2xl shadow-xl p-6 text-center">
                    <div class="mb-6">
                        <div class="w-32 h-32 mx-auto bg-gradient-to-br from-indigo-600 to-purple-600 rounded-full flex items-center justify-center text-white text-4xl font-bold">
                            @(Model?.FullName?.Substring(0, 1).ToUpper() ?? "U")
                        </div>
                    </div>
                    <h3 class="text-xl font-bold text-gray-900 mb-1">@(Model?.FullName ?? "User")</h3>
                    <p class="text-gray-600 mb-6">@(Model?.Email ?? "")</p>
                    
                    <div class="space-y-2">
                        <a asp-controller="Booking" asp-action="MyBookings" 
                           class="block w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-2 px-4 rounded-lg transition duration-200">
                            My Bookings
                        </a>
                        <a asp-controller="Favorite" asp-action="Index" 
                           class="block w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-2 px-4 rounded-lg transition duration-200">
                            Favorites
                        </a>
                    </div>
                </div>
            </div>

            <!-- Profile Form -->
            <div class="lg:col-span-2">
                <div class="bg-white rounded-2xl shadow-xl p-8">
                    <h2 class="text-2xl font-bold text-gray-900 mb-6">Personal Information</h2>
                    
                    <form asp-action="Update" method="post">
                        <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg mb-6"></div>

                        <div class="space-y-6">
                            <div>
                                <label asp-for="FullName" class="block text-sm font-medium text-gray-700 mb-2">Full Name</label>
                                <input asp-for="FullName" 
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                                <span asp-validation-for="FullName" class="text-red-500 text-sm"></span>
                            </div>

                            <div>
                                <label asp-for="Email" class="block text-sm font-medium text-gray-700 mb-2">Email Address</label>
                                <input asp-for="Email" type="email"
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                                <span asp-validation-for="Email" class="text-red-500 text-sm"></span>
                            </div>

                            <div>
                                <label asp-for="PhoneNumber" class="block text-sm font-medium text-gray-700 mb-2">Phone Number</label>
                                <input asp-for="PhoneNumber" type="tel"
                                       class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-indigo-500 focus:border-transparent">
                                <span asp-validation-for="PhoneNumber" class="text-red-500 text-sm"></span>
                            </div>


                        </div>

                        <div class="mt-8 flex gap-4">
                            <button type="submit" 
                                    class="flex-1 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-700 hover:to-purple-700 text-white font-bold py-3 px-6 rounded-lg transition duration-200">
                                Save Changes
                            </button>
                            <a asp-controller="Home" asp-action="Index" 
                               class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-3 px-6 rounded-lg transition duration-200 text-center">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
