@model DAL.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
}

<div class="bg-gray-50 min-h-screen py-8">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900">Manage account</h1>
        </div>

        <div class="flex flex-col lg:flex-row gap-8">
            <aside class="lg:w-64 flex-shrink-0">
                <nav class="bg-white border rounded-sm overflow-hidden">
                    <a asp-controller="Profile" asp-action="Index" class="flex items-center px-4 py-3 bg-blue-50 border-l-4 border-blue-600 text-blue-600 font-bold text-sm">
                        <i class="far fa-user mr-3 w-5"></i> Personal details
                    </a>
                    <a asp-controller="Profile" asp-action="Security" class="flex items-center px-4 py-3 text-gray-700 hover:bg-gray-50 text-sm border-l-4 border-transparent">
                        <i class="fas fa-shield-alt mr-3 w-5"></i> Security
                    </a>
                    <a href="/Booking/MyBookings" class="flex items-center px-4 py-3 text-gray-700 hover:bg-gray-50 text-sm border-l-4 border-transparent">
                        <i class="fas fa-suitcase mr-3 w-5"></i> Bookings
                    </a>
                    <a href="#" class="flex items-center px-4 py-3 text-gray-700 hover:bg-gray-50 text-sm border-l-4 border-transparent">
                        <i class="far fa-heart mr-3 w-5"></i> Saved lists
                    </a>
                </nav>
            </aside>

            <!-- Personal Details Form -->
            <div class="flex-1">
                <div class="bg-white border rounded-sm p-6 md:p-8">
                    <h2 class="text-xl font-bold text-gray-900 mb-2">Personal details</h2>
                    <p class="text-sm text-gray-600 mb-8 border-b pb-6">Update your info and find out how it's used.</p>
                    
                    <form asp-action="Update" method="post" class="space-y-8">
                        <div asp-validation-summary="ModelOnly" class="text-red-600 text-xs mb-4"></div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <div class="col-span-1">
                                <label asp-for="FullName" class="block text-sm font-bold text-gray-700 mb-2">Full name</label>
                                <input asp-for="FullName" 
                                       class="w-full px-3 py-2.5 border border-gray-400 rounded-sm focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none text-sm"
                                       placeholder="Enter your name">
                                <span asp-validation-for="FullName" class="text-red-600 text-[10px]"></span>
                            </div>

                            <div class="col-span-1">
                                <label asp-for="Email" class="block text-sm font-bold text-gray-700 mb-2">Email address</label>
                                <input asp-for="Email" type="email"
                                       class="w-full px-3 py-2.5 border border-gray-400 rounded-sm focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none text-sm"
                                       placeholder="Enter your email">
                                <span asp-validation-for="Email" class="text-red-600 text-[10px]"></span>
                            </div>

                            <div class="col-span-1">
                                <label asp-for="PhoneNumber" class="block text-sm font-bold text-gray-700 mb-2">Phone number</label>
                                <input asp-for="PhoneNumber" type="tel"
                                       class="w-full px-3 py-2.5 border border-gray-400 rounded-sm focus:border-blue-600 focus:ring-1 focus:ring-blue-600 outline-none text-sm"
                                       placeholder="Enter your phone number">
                                <span asp-validation-for="PhoneNumber" class="text-red-600 text-[10px]"></span>
                            </div>

                            <div class="col-span-1">
                                <label class="block text-sm font-bold text-gray-700 mb-2">Date of birth</label>
                                <div class="grid grid-cols-3 gap-2">
                                    <select class="px-2 py-2 border border-gray-400 rounded-sm text-sm"><option>Day</option></select>
                                    <select class="px-2 py-2 border border-gray-400 rounded-sm text-sm"><option>Month</option></select>
                                    <select class="px-2 py-2 border border-gray-400 rounded-sm text-sm"><option>Year</option></select>
                                </div>
                            </div>
                        </div>

                        <div class="pt-8 border-t flex flex-col md:flex-row gap-4">
                            <button type="submit" 
                                    class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2.5 px-8 rounded-sm transition-colors text-sm">
                                Save
                            </button>
                            <a asp-controller="Home" asp-action="Index" 
                               class="bg-white border border-blue-600 text-blue-600 hover:bg-blue-50 font-bold py-2.5 px-8 rounded-sm transition-colors text-sm text-center">
                                Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
