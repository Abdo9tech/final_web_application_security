<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Bookify Hotel - Modern luxury hotel booking experience" />
    <title>@ViewData["Title"] - Bookify Hotel</title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Tailwind CSS Configuration -->
    <script>
        tailwind = {
            config: {
                darkMode: 'class',
                theme: {
                    extend: {
                        fontFamily: {
                            sans: ['Inter', 'system-ui', 'sans-serif'],
                        },
                        colors: {
                            // Modern Light Mode Palette
                            primary: {
                                50: '#eef2ff',
                                100: '#e0e7ff',
                                200: '#c7d2fe',
                                300: '#a5b4fc',
                                400: '#818cf8',
                                500: '#6366f1',
                                600: '#4f46e5',
                                700: '#4338ca',
                                800: '#3730a3',
                                900: '#312e81',
                                950: '#1e1b4b',
                            },
                            emerald: {
                                50: '#ecfdf5',
                                100: '#d1fae5',
                                200: '#a7f3d0',
                                300: '#6ee7b7',
                                400: '#34d399',
                                500: '#10b981',
                                600: '#059669',
                                700: '#047857',
                                800: '#065f46',
                                900: '#064e3b',
                                950: '#022c22',
                            },
                            amber: {
                                50: '#fffbeb',
                                100: '#fef3c7',
                                200: '#fde68a',
                                300: '#fcd34d',
                                400: '#fbbf24',
                                500: '#f59e0b',
                                600: '#d97706',
                                700: '#b45309',
                                800: '#92400e',
                                900: '#78350f',
                                950: '#451a03',
                            },
                            sky: {
                                50: '#f0f9ff',
                                100: '#e0f2fe',
                                200: '#bae6fd',
                                300: '#7dd3fc',
                                400: '#38bdf8',
                                500: '#0ea5e9',
                                600: '#0284c7',
                                700: '#0369a1',
                                800: '#075985',
                                900: '#0c4a6e',
                                950: '#082f49',
                            },
                        },
                        animation: {
                            'fade-in': 'fadeIn 0.5s ease-out',
                            'slide-up': 'slideUp 0.6s ease-out',
                            'slide-down': 'slideDown 0.3s ease-out',
                        },
                        keyframes: {
                            fadeIn: {
                                '0%': { opacity: '0' },
                                '100%': { opacity: '1' },
                            },
                            slideUp: {
                                '0%': { transform: 'translateY(20px)', opacity: '0' },
                                '100%': { transform: 'translateY(0)', opacity: '1' },
                            },
                            slideDown: {
                                '0%': { transform: 'translateY(-10px)', opacity: '0' },
                                '100%': { transform: 'translateY(0)', opacity: '1' },
                            }
                        }
                    }
                }
            }
        }
    </script>

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <!-- Custom Styles -->
    <style>
        body {
            font-family: 'Inter', system-ui, sans-serif;
        }
        
        /* Smooth scrolling */
        html {
            scroll-behavior: smooth;
        }
        
        /* Custom scrollbar with gradient */
        ::-webkit-scrollbar {
            width: 12px;
        }
        
        ::-webkit-scrollbar-track {
            background: linear-gradient(to bottom, #f1f5f9, #e2e8f0);
        }
        
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(to bottom, #6366f1, #8b5cf6);
            border-radius: 6px;
            border: 2px solid #f1f5f9;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(to bottom, #4f46e5, #7c3aed);
        }

        /* Gradient text animation */
        @@keyframes gradient-shift {
            0%, 100% {
                background-position: 0% 50%;
            }
            50% {
                background-position: 100% 50%;
            }
        }

        .animate-gradient {
            background-size: 200% 200%;
            animation: gradient-shift 3s ease infinite;
        }

        /* Floating animation */
        @@keyframes float {
            0%, 100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-10px);
            }
        }

        .animate-float {
            animation: float 3s ease-in-out infinite;
        }

        /* Pulse glow effect */
        @@keyframes pulse-glow {
            0%, 100% {
                box-shadow: 0 0 20px rgba(99, 102, 241, 0.4);
            }
            50% {
                box-shadow: 0 0 40px rgba(99, 102, 241, 0.8);
            }
        }

        .animate-pulse-glow {
            animation: pulse-glow 2s ease-in-out infinite;
        }

        /* Shimmer effect */
        @@keyframes shimmer {
            0% {
                background-position: -1000px 0;
            }
            100% {
                background-position: 1000px 0;
            }
        }

        .animate-shimmer {
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            background-size: 1000px 100%;
            animation: shimmer 2s infinite;
        }

        /* Hover lift effect */
        .hover-lift {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .hover-lift:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }

        /* Gradient border animation */
        @@keyframes border-spin {
            100% {
                transform: rotate(360deg);
            }
        }

        .gradient-border {
            position: relative;
            background: linear-gradient(white, white) padding-box,
                        linear-gradient(45deg, #6366f1, #8b5cf6, #ec4899) border-box;
            border: 2px solid transparent;
        }

        .gradient-border::before {
            content: '';
            position: absolute;
            inset: -2px;
            background: linear-gradient(45deg, #6366f1, #8b5cf6, #ec4899);
            border-radius: inherit;
            opacity: 0;
            transition: opacity 0.3s;
            z-index: -1;
        }

        .gradient-border:hover::before {
            opacity: 1;
        }
    </style>

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modern-animations.css" asp-append-version="true" />
</head>
<body class="min-h-screen flex flex-col bg-gradient-to-br from-gray-50 via-blue-50 to-purple-50 text-gray-900 antialiased relative overflow-x-hidden">
    <!-- Animated Background Particles -->
    <div class="fixed inset-0 pointer-events-none z-0">
        <div class="absolute top-20 left-10 w-2 h-2 bg-primary-400 rounded-full float-particle opacity-60"></div>
        <div class="absolute top-40 right-20 w-3 h-3 bg-emerald-400 rounded-full float-particle opacity-60" style="animation-delay: 1s;"></div>
        <div class="absolute bottom-40 left-1/4 w-2 h-2 bg-pink-400 rounded-full float-particle opacity-60" style="animation-delay: 2s;"></div>
        <div class="absolute top-1/3 right-1/3 w-3 h-3 bg-amber-400 rounded-full float-particle opacity-60" style="animation-delay: 3s;"></div>
        <div class="absolute bottom-20 right-10 w-2 h-2 bg-sky-400 rounded-full float-particle opacity-60" style="animation-delay: 4s;"></div>
    </div>

    <!-- Ultra-Modern Glassmorphism Header -->
    <header class="glass backdrop-blur-xl bg-white/70 shadow-lg shadow-primary-500/10 sticky top-0 z-50 border-b border-white/20" x-data="{ mobileMenuOpen: false, userMenuOpen: false }">
        <!-- Animated Top Border -->
        <div class="h-1 bg-gradient-to-r from-primary-500 via-purple-500 to-pink-500 holographic-bg"></div>
        
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-20">
                <!-- Ultra-Modern Logo -->
                <div class="flex items-center">
                    <a href="/" class="flex items-center space-x-3 group">
                        <div class="relative w-12 h-12 bg-gradient-to-br from-primary-500 via-purple-500 to-pink-500 rounded-2xl flex items-center justify-center group-hover:scale-110 group-hover:rotate-6 transition-all duration-500 shadow-lg shadow-primary-500/50 morph-shape">
                            <i class="fas fa-hotel text-white text-2xl relative z-10"></i>
                            <div class="absolute inset-0 bg-gradient-to-br from-primary-600 to-purple-600 rounded-2xl blur-xl opacity-50 group-hover:opacity-75 transition-opacity"></div>
                        </div>
                        <div class="flex flex-col">
                            <span class="text-2xl font-black bg-gradient-to-r from-primary-600 via-purple-600 to-pink-600 bg-clip-text text-transparent group-hover:scale-105 transition-transform">
                                Bookify
                            </span>
                            <span class="text-xs font-semibold text-gray-500 -mt-1">Luxury Hotels</span>
                        </div>
                    </a>
                </div>

                <!-- Ultra-Modern Desktop Navigation -->
                <nav class="hidden md:flex items-center space-x-2">
                    <a href="/" class="group relative px-5 py-2.5 rounded-xl font-semibold text-gray-700 hover:text-white transition-all duration-300 overflow-hidden">
                        <span class="relative z-10 flex items-center space-x-2">
                            <i class="fas fa-home text-sm"></i>
                            <span>Home</span>
                        </span>
                        <div class="absolute inset-0 bg-gradient-to-r from-primary-500 to-purple-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left rounded-xl"></div>
                    </a>
                    <a href="/Room" class="group relative px-5 py-2.5 rounded-xl font-semibold text-gray-700 hover:text-white transition-all duration-300 overflow-hidden">
                        <span class="relative z-10 flex items-center space-x-2">
                            <i class="fas fa-bed text-sm"></i>
                            <span>Rooms</span>
                        </span>
                        <div class="absolute inset-0 bg-gradient-to-r from-emerald-500 to-teal-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left rounded-xl"></div>
                    </a>
                    <a href="/About" class="group relative px-5 py-2.5 rounded-xl font-semibold text-gray-700 hover:text-white transition-all duration-300 overflow-hidden">
                        <span class="relative z-10 flex items-center space-x-2">
                            <i class="fas fa-info-circle text-sm"></i>
                            <span>About</span>
                        </span>
                        <div class="absolute inset-0 bg-gradient-to-r from-sky-500 to-blue-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left rounded-xl"></div>
                    </a>
                    <a href="/Contact" class="group relative px-5 py-2.5 rounded-xl font-semibold text-gray-700 hover:text-white transition-all duration-300 overflow-hidden">
                        <span class="relative z-10 flex items-center space-x-2">
                            <i class="fas fa-envelope text-sm"></i>
                            <span>Contact</span>
                        </span>
                        <div class="absolute inset-0 bg-gradient-to-r from-amber-500 to-orange-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left rounded-xl"></div>
                    </a>
                </nav>

                <!-- Ultra-Modern Desktop Actions -->
                <div class="hidden md:flex items-center space-x-3">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <!-- Neon Icon Buttons -->
                        <a asp-controller="Booking" asp-action="MyBookings" 
                           class="group relative w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-500/10 to-teal-500/10 hover:from-emerald-500 hover:to-teal-500 flex items-center justify-center transition-all duration-300 hover:scale-110 hover:-translate-y-1 hover:shadow-lg hover:shadow-emerald-500/50"
                           title="My Bookings">
                            <i class="fas fa-calendar-check text-xl text-emerald-600 group-hover:text-white transition-colors"></i>
                            <div class="absolute inset-0 rounded-xl bg-emerald-500 opacity-0 group-hover:opacity-20 blur-xl transition-opacity"></div>
                        </a>
                        
                        <a asp-controller="Favorite" asp-action="Index" 
                           class="group relative w-12 h-12 rounded-xl bg-gradient-to-br from-pink-500/10 to-rose-500/10 hover:from-pink-500 hover:to-rose-500 flex items-center justify-center transition-all duration-300 hover:scale-110 hover:-translate-y-1 hover:shadow-lg hover:shadow-pink-500/50"
                           title="Favorites">
                            <i class="fas fa-heart text-xl text-pink-600 group-hover:text-white transition-colors"></i>
                            <div class="absolute inset-0 rounded-xl bg-pink-500 opacity-0 group-hover:opacity-20 blur-xl transition-opacity"></div>
                        </a>
                        
                        <!-- Ultra-Modern User Profile Dropdown -->
                        <div class="relative" x-data="{ open: false }">
                            <button @@click="open = !open" 
                                    class="group flex items-center space-x-3 px-4 py-2 rounded-xl bg-gradient-to-r from-primary-500/10 to-purple-500/10 hover:from-primary-500/20 hover:to-purple-500/20 transition-all duration-300 border border-primary-200/50">
                                <div class="relative w-10 h-10 bg-gradient-to-br from-primary-500 via-purple-500 to-pink-500 rounded-xl flex items-center justify-center text-white font-bold text-lg shadow-lg group-hover:scale-110 transition-transform">
                                    @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U")
                                    <div class="absolute inset-0 rounded-xl bg-gradient-to-br from-primary-600 to-purple-600 blur-lg opacity-50 group-hover:opacity-75 transition-opacity"></div>
                                </div>
                                <div class="flex flex-col items-start">
                                    <span class="text-sm font-semibold text-gray-900">@(User.Identity?.Name ?? "User")</span>
                                    <span class="text-xs text-gray-500">View Profile</span>
                                </div>
                                <i class="fas fa-chevron-down text-sm text-gray-600 group-hover:text-primary-600 transition-colors"></i>
                            </button>
                            
                            <!-- Ultra-Modern Dropdown Menu -->
                            <div x-show="open" 
                                 @@click.away="open = false"
                                 x-transition:enter="transition ease-out duration-300"
                                 x-transition:enter-start="opacity-0 transform scale-95 -translate-y-2"
                                 x-transition:enter-end="opacity-100 transform scale-100 translate-y-0"
                                 x-transition:leave="transition ease-in duration-200"
                                 x-transition:leave-start="opacity-100 transform scale-100"
                                 x-transition:leave-end="opacity-0 transform scale-95"
                                 class="absolute right-0 mt-4 w-72 glass backdrop-blur-xl bg-white/90 rounded-2xl shadow-2xl shadow-primary-500/20 border border-white/20 py-3 z-50 overflow-hidden"
                                 x-cloak>
                                <!-- Animated Background -->
                                <div class="absolute inset-0 bg-gradient-to-br from-primary-500/5 to-purple-500/5"></div>
                                <div class="relative px-5 py-4 border-b border-white/20">
                                    <p class="text-base font-bold text-gray-900">@User.Identity?.Name</p>
                                    <p class="text-xs text-gray-600 truncate mt-1">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</p>
                                </div>
                                
                                <div class="relative px-2 py-2 space-y-1">
                                    <a asp-controller="Profile" asp-action="Index" 
                                       class="group flex items-center px-4 py-3 text-sm font-medium text-gray-700 hover:text-primary-600 rounded-xl hover:bg-gradient-to-r hover:from-primary-50 hover:to-purple-50 transition-all duration-300">
                                        <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-primary-500 to-purple-500 flex items-center justify-center group-hover:scale-110 transition-transform">
                                            <i class="fas fa-user text-white text-sm"></i>
                                        </div>
                                        <span class="ml-3">My Profile</span>
                                        <i class="fas fa-arrow-right ml-auto text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all"></i>
                                    </a>
                                    
                                    <a asp-controller="Booking" asp-action="MyBookings" 
                                       class="group flex items-center px-4 py-3 text-sm font-medium text-gray-700 hover:text-emerald-600 rounded-xl hover:bg-gradient-to-r hover:from-emerald-50 hover:to-teal-50 transition-all duration-300">
                                        <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-emerald-500 to-teal-500 flex items-center justify-center group-hover:scale-110 transition-transform">
                                            <i class="fas fa-calendar-check text-white text-sm"></i>
                                        </div>
                                        <span class="ml-3">My Bookings</span>
                                        <i class="fas fa-arrow-right ml-auto text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all"></i>
                                    </a>
                                    
                                    <a asp-controller="Favorite" asp-action="Index" 
                                       class="group flex items-center px-4 py-3 text-sm font-medium text-gray-700 hover:text-pink-600 rounded-xl hover:bg-gradient-to-r hover:from-pink-50 hover:to-rose-50 transition-all duration-300">
                                        <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-pink-500 to-rose-500 flex items-center justify-center group-hover:scale-110 transition-transform">
                                            <i class="fas fa-heart text-white text-sm"></i>
                                        </div>
                                        <span class="ml-3">Favorites</span>
                                        <i class="fas fa-arrow-right ml-auto text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all"></i>
                                    </a>
                                </div>
                                
                                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                {
                                    <div class="border-t border-white/20 my-2"></div>
                                    <div class="relative px-2 py-2">
                                        <a asp-controller="Dashboard" asp-action="Index" 
                                           class="group flex items-center px-4 py-3 text-sm font-medium text-gray-700 hover:text-amber-600 rounded-xl hover:bg-gradient-to-r hover:from-amber-50 hover:to-orange-50 transition-all duration-300">
                                            <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-amber-500 to-orange-500 flex items-center justify-center group-hover:scale-110 transition-transform">
                                                <i class="fas fa-tachometer-alt text-white text-sm"></i>
                                            </div>
                                            <span class="ml-3">Dashboard</span>
                                            <i class="fas fa-arrow-right ml-auto text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all"></i>
                                        </a>
                                    </div>
                                }
                                
                                <div class="border-t border-white/20 my-2"></div>
                                <div class="relative px-2 py-2">
                                    <form asp-controller="Login" asp-action="Logout" method="post" class="block">
                                        <button type="submit" 
                                                class="group w-full flex items-center px-4 py-3 text-sm font-medium text-gray-700 hover:text-red-600 rounded-xl hover:bg-gradient-to-r hover:from-red-50 hover:to-rose-50 transition-all duration-300">
                                            <div class="w-9 h-9 rounded-lg bg-gradient-to-br from-red-500 to-rose-500 flex items-center justify-center group-hover:scale-110 transition-transform">
                                                <i class="fas fa-sign-out-alt text-white text-sm"></i>
                                            </div>
                                            <span class="ml-3">Logout</span>
                                            <i class="fas fa-arrow-right ml-auto text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all"></i>
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Ultra-Modern Login Button -->
                        <a asp-controller="Login" asp-action="Login" 
                           class="group relative px-6 py-2.5 rounded-xl font-bold text-gray-700 hover:text-white transition-all duration-300 overflow-hidden border-2 border-primary-200 hover:border-transparent">
                            <span class="relative z-10 flex items-center space-x-2">
                                <i class="fas fa-sign-in-alt text-sm"></i>
                                <span>Login</span>
                            </span>
                            <div class="absolute inset-0 bg-gradient-to-r from-sky-500 via-blue-500 to-indigo-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left rounded-xl"></div>
                        </a>
                        
                        <!-- Ultra-Modern Sign Up Button -->
                        <a asp-controller="Register" asp-action="Register" 
                           class="group relative px-6 py-2.5 rounded-xl font-bold text-white overflow-hidden shadow-lg hover:shadow-2xl hover:shadow-emerald-500/50 transition-all duration-300 hover:scale-105 hover:-translate-y-0.5">
                            <span class="relative z-10 flex items-center space-x-2">
                                <i class="fas fa-user-plus text-sm"></i>
                                <span>Sign Up</span>
                            </span>
                            <div class="absolute inset-0 bg-gradient-to-r from-emerald-500 via-teal-500 to-cyan-500"></div>
                            <div class="absolute inset-0 bg-gradient-to-r from-cyan-500 to-emerald-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                            <div class="absolute inset-0 shimmer"></div>
                        </a>
                    }
                </div>

                <!-- Mobile menu button -->
                <button @@click="mobileMenuOpen = !mobileMenuOpen" class="md:hidden text-gray-700 hover:text-primary-600">
                    <i class="fas fa-bars text-xl"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div x-show="mobileMenuOpen" 
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 transform -translate-y-2"
             x-transition:enter-end="opacity-100 transform translate-y-0"
             x-transition:leave="transition ease-in duration-150"
             x-transition:leave-start="opacity-100 transform translate-y-0"
             x-transition:leave-end="opacity-0 transform -translate-y-2"
             class="md:hidden bg-white border-t border-gray-200"
             x-cloak>
            <div class="px-4 py-4 space-y-3">
                <a href="/" class="block text-gray-700 hover:text-primary-600 font-medium py-2">Home</a>
                <a href="/Room" class="block text-gray-700 hover:text-primary-600 font-medium py-2">Rooms</a>
                <a href="/About" class="block text-gray-700 hover:text-primary-600 font-medium py-2">About</a>
                <a href="/Contact" class="block text-gray-700 hover:text-primary-600 font-medium py-2">Contact</a>
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="pt-3 border-t border-gray-200 space-y-2">
                        <div class="flex items-center space-x-2 px-3 py-2 bg-gray-50 rounded-lg">
                            <div class="w-10 h-10 bg-gradient-to-br from-primary-600 to-purple-600 rounded-full flex items-center justify-center text-white font-semibold">
                                @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U")
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-gray-900">@User.Identity?.Name</p>
                                <p class="text-xs text-gray-500">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</p>
                            </div>
                        </div>
                        
                        <a asp-controller="Profile" asp-action="Index" class="flex items-center text-gray-700 hover:text-primary-600 font-medium py-2">
                            <i class="fas fa-user w-5 mr-2"></i>My Profile
                        </a>
                        <a asp-controller="Booking" asp-action="MyBookings" class="flex items-center text-gray-700 hover:text-primary-600 font-medium py-2">
                            <i class="fas fa-calendar-check w-5 mr-2"></i>My Bookings
                        </a>
                        <a asp-controller="Favorite" asp-action="Index" class="flex items-center text-gray-700 hover:text-primary-600 font-medium py-2">
                            <i class="fas fa-heart w-5 mr-2"></i>Favorites
                        </a>
                        
                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                        {
                            <a asp-controller="Dashboard" asp-action="Index" class="flex items-center text-gray-700 hover:text-primary-600 font-medium py-2">
                                <i class="fas fa-tachometer-alt w-5 mr-2"></i>Dashboard
                            </a>
                        }
                        
                        <form asp-controller="Login" asp-action="Logout" method="post" class="pt-2">
                            <button type="submit" class="w-full flex items-center text-red-600 hover:text-red-700 font-medium py-2">
                                <i class="fas fa-sign-out-alt w-5 mr-2"></i>Logout
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="pt-3 border-t border-gray-200 space-y-3">
                        <!-- Mobile Login Button -->
                        <a asp-controller="Login" asp-action="Login" 
                           class="group relative block px-6 py-3 rounded-xl font-bold text-center overflow-hidden border-2 border-sky-200 hover:border-transparent transition-all duration-300">
                            <span class="relative z-10 flex items-center justify-center space-x-2 text-gray-700 group-hover:text-white transition-colors">
                                <i class="fas fa-sign-in-alt"></i>
                                <span>Login</span>
                            </span>
                            <div class="absolute inset-0 bg-gradient-to-r from-sky-500 via-blue-500 to-indigo-500 transform scale-x-0 group-hover:scale-x-100 transition-transform origin-left"></div>
                        </a>
                        
                        <!-- Mobile Sign Up Button -->
                        <a asp-controller="Register" asp-action="Register" 
                           class="group relative block px-6 py-3 rounded-xl font-bold text-white text-center overflow-hidden shadow-lg hover:shadow-xl hover:shadow-emerald-500/50 transition-all duration-300">
                            <span class="relative z-10 flex items-center justify-center space-x-2">
                                <i class="fas fa-user-plus"></i>
                                <span>Sign Up</span>
                            </span>
                            <div class="absolute inset-0 bg-gradient-to-r from-emerald-500 via-teal-500 to-cyan-500"></div>
                            <div class="absolute inset-0 bg-gradient-to-r from-cyan-500 to-emerald-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                        </a>
                    </div>
                }
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
        @RenderBody()
    </main>

    <!-- Modern Footer with Gradient -->
    <footer class="relative bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white overflow-hidden">
        <!-- Decorative Background Elements -->
        <div class="absolute inset-0 opacity-10">
            <div class="absolute top-0 left-0 w-96 h-96 bg-primary-500 rounded-full filter blur-3xl animate-pulse"></div>
            <div class="absolute bottom-0 right-0 w-96 h-96 bg-emerald-500 rounded-full filter blur-3xl animate-pulse" style="animation-delay: 1.5s;"></div>
        </div>

        <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
                <!-- Brand Section -->
                <div class="lg:col-span-2">
                    <div class="flex items-center space-x-3 mb-6 group">
                        <div class="w-12 h-12 bg-gradient-to-br from-primary-500 via-purple-500 to-pink-500 rounded-xl flex items-center justify-center transform group-hover:scale-110 group-hover:rotate-3 transition-all duration-300 shadow-lg">
                            <i class="fas fa-hotel text-white text-2xl"></i>
                        </div>
                        <span class="text-2xl font-bold bg-gradient-to-r from-white to-gray-300 bg-clip-text text-transparent">
                            Bookify<span class="text-primary-400">Hotel</span>
                        </span>
                    </div>
                    <p class="text-gray-300 mb-6 text-lg leading-relaxed max-w-md">
                        Experience luxury and comfort at Bookify Hotel. Your perfect getaway awaits with world-class amenities and exceptional service.
                    </p>
                    
                    <!-- Social Media Links with Vibrant Colors -->
                    <div class="flex space-x-4">
                        <a href="#" class="group relative w-12 h-12 bg-gray-800 hover:bg-gradient-to-br hover:from-blue-600 hover:to-blue-700 rounded-xl flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:-translate-y-1 shadow-lg hover:shadow-blue-500/50">
                            <i class="fab fa-facebook text-xl text-gray-400 group-hover:text-white transition-colors"></i>
                        </a>
                        <a href="#" class="group relative w-12 h-12 bg-gray-800 hover:bg-gradient-to-br hover:from-sky-500 hover:to-sky-600 rounded-xl flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:-translate-y-1 shadow-lg hover:shadow-sky-500/50">
                            <i class="fab fa-twitter text-xl text-gray-400 group-hover:text-white transition-colors"></i>
                        </a>
                        <a href="#" class="group relative w-12 h-12 bg-gray-800 hover:bg-gradient-to-br hover:from-pink-600 hover:to-purple-600 rounded-xl flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:-translate-y-1 shadow-lg hover:shadow-pink-500/50">
                            <i class="fab fa-instagram text-xl text-gray-400 group-hover:text-white transition-colors"></i>
                        </a>
                        <a href="#" class="group relative w-12 h-12 bg-gray-800 hover:bg-gradient-to-br hover:from-blue-700 hover:to-blue-800 rounded-xl flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:-translate-y-1 shadow-lg hover:shadow-blue-700/50">
                            <i class="fab fa-linkedin text-xl text-gray-400 group-hover:text-white transition-colors"></i>
                        </a>
                    </div>
                </div>

                <!-- Quick Links -->
                <div>
                    <h3 class="font-bold text-xl mb-6 bg-gradient-to-r from-primary-400 to-emerald-400 bg-clip-text text-transparent">
                        Quick Links
                    </h3>
                    <ul class="space-y-3">
                        <li>
                            <a href="/" class="group flex items-center text-gray-300 hover:text-white transition-all duration-300">
                                <i class="fas fa-chevron-right text-primary-500 mr-2 text-sm group-hover:translate-x-1 transition-transform"></i>
                                <span class="group-hover:translate-x-1 transition-transform">Home</span>
                            </a>
                        </li>
                        <li>
                            <a href="/Room" class="group flex items-center text-gray-300 hover:text-white transition-all duration-300">
                                <i class="fas fa-chevron-right text-emerald-500 mr-2 text-sm group-hover:translate-x-1 transition-transform"></i>
                                <span class="group-hover:translate-x-1 transition-transform">Rooms</span>
                            </a>
                        </li>
                        <li>
                            <a href="/About" class="group flex items-center text-gray-300 hover:text-white transition-all duration-300">
                                <i class="fas fa-chevron-right text-sky-500 mr-2 text-sm group-hover:translate-x-1 transition-transform"></i>
                                <span class="group-hover:translate-x-1 transition-transform">About Us</span>
                            </a>
                        </li>
                        <li>
                            <a href="/Contact" class="group flex items-center text-gray-300 hover:text-white transition-all duration-300">
                                <i class="fas fa-chevron-right text-amber-500 mr-2 text-sm group-hover:translate-x-1 transition-transform"></i>
                                <span class="group-hover:translate-x-1 transition-transform">Contact</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <!-- Contact Info with Colorful Icons -->
                <div>
                    <h3 class="font-bold text-xl mb-6 bg-gradient-to-r from-emerald-400 to-sky-400 bg-clip-text text-transparent">
                        Get In Touch
                    </h3>
                    <ul class="space-y-4">
                        <li class="group flex items-start space-x-3 text-gray-300 hover:text-white transition-colors">
                            <div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform shadow-lg">
                                <i class="fas fa-phone text-white"></i>
                            </div>
                            <div>
                                <p class="text-sm text-gray-400">Call Us</p>
                                <p class="font-medium">+1 (555) 123-4567</p>
                            </div>
                        </li>
                        <li class="group flex items-start space-x-3 text-gray-300 hover:text-white transition-colors">
                            <div class="w-10 h-10 bg-gradient-to-br from-sky-500 to-sky-600 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform shadow-lg">
                                <i class="fas fa-envelope text-white"></i>
                            </div>
                            <div>
                                <p class="text-sm text-gray-400">Email Us</p>
                                <p class="font-medium">info@bookifyhotel.com</p>
                            </div>
                        </li>
                        <li class="group flex items-start space-x-3 text-gray-300 hover:text-white transition-colors">
                            <div class="w-10 h-10 bg-gradient-to-br from-amber-500 to-amber-600 rounded-lg flex items-center justify-center flex-shrink-0 group-hover:scale-110 transition-transform shadow-lg">
                                <i class="fas fa-map-marker-alt text-white"></i>
                            </div>
                            <div>
                                <p class="text-sm text-gray-400">Visit Us</p>
                                <p class="font-medium">123 Luxury Avenue<br>Manchester, M1 1BE</p>
                            </div>
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Newsletter Section -->
            <div class="bg-gradient-to-r from-primary-600/20 to-purple-600/20 backdrop-blur-sm rounded-2xl p-8 mb-12 border border-primary-500/20">
                <div class="max-w-2xl mx-auto text-center">
                    <h3 class="text-2xl font-bold mb-3 bg-gradient-to-r from-primary-300 to-purple-300 bg-clip-text text-transparent">
                        Subscribe to Our Newsletter
                    </h3>
                    <p class="text-gray-300 mb-6">Get exclusive deals and updates delivered to your inbox</p>
                    <form class="flex flex-col sm:flex-row gap-3">
                        <input type="email" 
                               placeholder="Enter your email" 
                               class="flex-1 px-6 py-3 bg-gray-800/50 border border-gray-700 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent text-white placeholder-gray-400 transition-all">
                        <button type="submit" 
                                class="px-8 py-3 bg-gradient-to-r from-primary-600 to-purple-600 hover:from-primary-700 hover:to-purple-700 text-white font-semibold rounded-lg transition-all duration-300 transform hover:scale-105 shadow-lg hover:shadow-primary-500/50">
                            <i class="fas fa-paper-plane mr-2"></i>Subscribe
                        </button>
                    </form>
                </div>
            </div>

            <!-- Bottom Bar -->
            <div class="border-t border-gray-800 pt-8">
                <div class="flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0">
                    <p class="text-gray-400 text-center md:text-left">
                        &copy; 2024 <span class="text-primary-400 font-semibold">Bookify Hotel</span>. All rights reserved.
                    </p>
                    <div class="flex flex-wrap justify-center gap-6 text-sm">
                        <a href="#" class="text-gray-400 hover:text-primary-400 transition-colors">Privacy Policy</a>
                        <a href="#" class="text-gray-400 hover:text-primary-400 transition-colors">Terms of Service</a>
                        <a href="#" class="text-gray-400 hover:text-primary-400 transition-colors">Cookie Policy</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Scroll to Top Button -->
        <button onclick="window.scrollTo({top: 0, behavior: 'smooth'})" 
                class="fixed bottom-8 right-8 w-12 h-12 bg-gradient-to-br from-primary-600 to-purple-600 hover:from-primary-700 hover:to-purple-700 text-white rounded-full shadow-lg hover:shadow-primary-500/50 flex items-center justify-center transition-all duration-300 transform hover:scale-110 hover:-translate-y-1 z-50"
                title="Back to top">
            <i class="fas fa-arrow-up"></i>
        </button>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Alpine.js Cloak Style -->
    <style>
        [x-cloak] { display: none !important; }
    </style>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
