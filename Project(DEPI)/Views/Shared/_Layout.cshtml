<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Bookify Hotel - Modern luxury hotel booking experience" />
    <title>@ViewData["Title"] - Bookify Hotel</title>

    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">

    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />

    <!-- Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Tailwind CSS Configuration -->
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                    },
                    colors: {
                        // Bookify Purple/Indigo Palette
                        bookify: {
                            50: '#faf5ff',
                            100: '#f3e8ff',
                            200: '#e9d5ff',
                            300: '#d8b4fe',
                            400: '#c084fc',
                            500: '#a855f7',
                            600: '#7c3aed',
                            700: '#6d28d9',
                            800: '#5b21b6',
                            900: '#4c1d95',
                            950: '#2e1065',
                        },
                        primary: {
                            50: '#faf5ff',
                            100: '#f3e8ff',
                            200: '#e9d5ff',
                            300: '#d8b4fe',
                            400: '#c084fc',
                            500: '#a855f7',
                            600: '#7c3aed',
                            700: '#6d28d9',
                            800: '#5b21b6',
                            900: '#4c1d95',
                            950: '#2e1065',
                        },
                        secondary: {
                            50: '#eef2ff',
                            100: '#e0e7ff',
                            200: '#c7d2fe',
                            300: '#a5b4fc',
                            400: '#818cf8',
                            500: '#6366f1',
                            600: '#4f46e5',
                            700: '#4338ca',
                            800: '#3730a3',
                            900: '#312e81',
                        }
                    }
                }
            }
        }
    </script>

    <!-- Alpine.js -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

    <!-- Custom Styles -->
    <style>
        body {
            font-family: 'Inter', system-ui, sans-serif;
        }
        
        /* Smooth scrolling */
        html {
            scroll-behavior: smooth;
        }
        
        /* Custom scrollbar with gradient */
        ::-webkit-scrollbar {
            width: 12px;
        }
        
        ::-webkit-scrollbar-track {
            background: linear-gradient(to bottom, #f1f5f9, #e2e8f0);
        }
        
        ::-webkit-scrollbar-thumb {
            background: linear-gradient(to bottom, #6366f1, #8b5cf6);
            border-radius: 6px;
            border: 2px solid #f1f5f9;
        }
        
        ::-webkit-scrollbar-thumb:hover {
            background: linear-gradient(to bottom, #4f46e5, #7c3aed);
        }

        /* Gradient text animation */
        @@keyframes gradient-shift {
            0%, 100% {
                background-position: 0% 50%;
            }
            50% {
                background-position: 100% 50%;
            }
        }

        .animate-gradient {
            background-size: 200% 200%;
            animation: gradient-shift 3s ease infinite;
        }

        /* Floating animation */
        @@keyframes float {
            0%, 100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-10px);
            }
        }

        .animate-float {
            animation: float 3s ease-in-out infinite;
        }

        /* Pulse glow effect */
        @@keyframes pulse-glow {
            0%, 100% {
                box-shadow: 0 0 20px rgba(99, 102, 241, 0.4);
            }
            50% {
                box-shadow: 0 0 40px rgba(99, 102, 241, 0.8);
            }
        }

        .animate-pulse-glow {
            animation: pulse-glow 2s ease-in-out infinite;
        }

        /* Shimmer effect */
        @@keyframes shimmer {
            0% {
                background-position: -1000px 0;
            }
            100% {
                background-position: 1000px 0;
            }
        }

        .animate-shimmer {
            background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
            background-size: 1000px 100%;
            animation: shimmer 2s infinite;
        }

        /* Hover lift effect */
        .hover-lift {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .hover-lift:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }

        /* Gradient border animation */
        @@keyframes border-spin {
            100% {
                transform: rotate(360deg);
            }
        }

        .gradient-border {
            position: relative;
            background: linear-gradient(white, white) padding-box,
                        linear-gradient(45deg, #6366f1, #8b5cf6, #ec4899) border-box;
            border: 2px solid transparent;
        }

        .gradient-border::before {
            content: '';
            position: absolute;
            inset: -2px;
            background: linear-gradient(45deg, #6366f1, #8b5cf6, #ec4899);
            border-radius: inherit;
            opacity: 0;
            transition: opacity 0.3s;
            z-index: -1;
        }

        .gradient-border:hover::before {
            opacity: 1;
        }
    </style>

    <!-- Design System 2026 -->
    <link rel="stylesheet" href="~/css/design-system.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/glass.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modern-animations.css" asp-append-version="true" />
    
    <!-- Theme Switcher (load early to prevent flash) -->
    <script src="~/js/theme-switcher.js" asp-append-version="true"></script>
    
    <!-- Toast Notifications -->
    <script src="~/js/toast.js" asp-append-version="true"></script>
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="min-h-screen flex flex-col transition-colors duration-200 antialiased relative overflow-x-hidden" style="background-color: var(--color-background); color: var(--color-text-primary);">
    <!-- Animated Background Particles -->
    <div class="fixed inset-0 pointer-events-none z-0">
        <div class="absolute top-20 left-10 w-2 h-2 bg-primary-400 rounded-full float-particle opacity-60"></div>
        <div class="absolute top-40 right-20 w-3 h-3 bg-emerald-400 rounded-full float-particle opacity-60" style="animation-delay: 1s;"></div>
        <div class="absolute bottom-40 left-1/4 w-2 h-2 bg-pink-400 rounded-full float-particle opacity-60" style="animation-delay: 2s;"></div>
        <div class="absolute top-1/3 right-1/3 w-3 h-3 bg-amber-400 rounded-full float-particle opacity-60" style="animation-delay: 3s;"></div>
        <div class="absolute bottom-20 right-10 w-2 h-2 bg-sky-400 rounded-full float-particle opacity-60" style="animation-delay: 4s;"></div>
    </div>

    <!-- Enhanced Modern Header with Sticky Scroll Effect -->
    <header class="sticky top-0 z-50 transition-all duration-300" id="main-header" style="background-color: var(--primary-600); box-shadow: var(--shadow-md);" x-data="{ mobileMenuOpen: false, userMenuOpen: false }">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <!-- Bookify Modern Logo -->
                <div class="flex items-center">
                    <a href="/" class="flex items-center space-x-3 group">
                        <span class="text-3xl font-black text-white group-hover:text-purple-100 transition-colors tracking-tight">
                            Bookify<span class="text-gradient-bookify text-pink-400">.hotel</span>
                        </span>
                    </a>
                </div>

                <!-- Desktop Navigation -->
                <nav class="hidden md:flex items-center space-x-1">
                    <a href="/" class="px-4 py-2 rounded-md font-bold text-white hover:bg-white/10 transition-all duration-200 flex items-center">
                        <i class="fas fa-bed mr-2"></i>
                        Stays
                    </a>
                    <a asp-controller="Room" asp-action="Index" class="px-4 py-2 rounded-md font-medium text-white hover:bg-white/10 transition-all duration-200 flex items-center opacity-90 hover:opacity-100">
                        <i class="fas fa-search mr-2"></i>
                        Find Rooms
                    </a>
                    <!-- AI Assistant Link -->
                    <a asp-controller="AIAssistant" asp-action="Index" class="px-4 py-2 rounded-md font-medium text-white hover:bg-gradient-to-r hover:from-purple-500 hover:to-indigo-500 transition-all duration-200 flex items-center opacity-90 hover:opacity-100 hover:shadow-lg">
                        <i class="fas fa-robot mr-2 animate-pulse"></i>
                        AI Assistant
                    </a>
                    <a asp-controller="About" asp-action="Index" class="px-4 py-2 rounded-md font-medium text-white hover:bg-white/10 transition-all duration-200 flex items-center opacity-90 hover:opacity-100">
                        <i class="fas fa-info-circle mr-2"></i>
                        About
                    </a>
                    <a asp-controller="Contact" asp-action="Index" class="px-4 py-2 rounded-md font-medium text-white hover:bg-white/10 transition-all duration-200 flex items-center opacity-90 hover:opacity-100">
                        <i class="fas fa-envelope mr-2"></i>
                        Contact
                    </a>
                </nav>

                <!-- Desktop Actions -->
                <div class="hidden md:flex items-center space-x-3">
                    <!-- Theme Toggle Button -->
                    <button data-theme-toggle 
                            class="p-2 rounded-md text-white hover:bg-white/10 transition-all duration-200"
                            aria-label="Toggle theme">
                        <i class="fas fa-sun text-xl" data-theme-icon="light" style="display: none;"></i>
                        <i class="fas fa-moon text-xl" data-theme-icon="dark"></i>
                    </button>
                    
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a asp-controller="Booking" asp-action="MyBookings" 
                           class="p-2 rounded-md text-white hover:bg-white/10 transition-all"
                           title="My Bookings">
                            <i class="fas fa-suitcase text-xl"></i>
                        </a>
                        
                        <a asp-controller="Favorite" asp-action="Index" 
                           class="p-2 rounded-md text-white hover:bg-white/10 transition-all"
                           title="Favorites">
                            <i class="fas fa-heart text-xl"></i>
                        </a>
                        
                        <!-- User Profile -->
                        <div class="relative" x-data="{ open: false }">
                            <button @@click="open = !open" 
                                    class="flex items-center space-x-2 px-3 py-1.5 rounded-md hover:bg-white/10 transition-all border border-transparent hover:border-white/20">
                                <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center text-white font-bold text-sm">
                                    @(User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U")
                                </div>
                                <span class="text-sm font-semibold text-white">@(User.Identity?.Name ?? "User")</span>
                                <i class="fas fa-chevron-down text-xs text-white"></i>
                            </button>
                            
                            <!-- Dropdown Menu -->
                            <div x-show="open" 
                                 @@click.away="open = false"
                                 x-transition:enter="transition ease-out duration-100"
                                 x-transition:enter-start="opacity-0 scale-95"
                                 x-transition:enter-end="opacity-100 scale-100"
                                 class="absolute right-0 mt-2 w-56 bg-white rounded-md shadow-xl py-2 z-50 border border-gray-200"
                                 x-cloak>
                                <div class="px-4 py-2 border-b border-gray-100">
                                    <p class="text-sm font-bold text-gray-900">@User.Identity?.Name</p>
                                    <p class="text-xs text-gray-500 truncate">@User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value</p>
                                </div>
                                
                                <a asp-controller="Profile" asp-action="Index" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                    <i class="fas fa-user mr-2 text-gray-400"></i> Manage account
                                </a>
                                <a asp-controller="Booking" asp-action="MyBookings" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                    <i class="fas fa-suitcase mr-2 text-gray-400"></i> Bookings
                                </a>
                                <a asp-controller="Favorite" asp-action="Index" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100">
                                    <i class="fas fa-heart mr-2 text-gray-400"></i> Saved
                                </a>
                                
                                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                {
                                    <div class="border-t border-gray-100 my-1"></div>
                                    <a asp-controller="Dashboard" asp-action="Index" class="block px-4 py-2 text-sm text-blue-600 font-semibold hover:bg-gray-100">
                                        <i class="fas fa-tachometer-alt mr-2"></i> Admin Dashboard
                                    </a>
                                }
                                
                                <div class="border-t border-gray-100 my-1"></div>
                                <form asp-controller="Login" asp-action="Logout" method="post">
                                    <button type="submit" class="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-gray-100">
                                        <i class="fas fa-sign-out-alt mr-2"></i> Sign out
                                    </button>
                                </form>
                            </div>
                        </div>
                    }
                    else
                    {
                        <a asp-controller="Register" asp-action="Register" 
                           class="px-4 py-1.5 rounded-sm font-bold text-bookify-600 bg-white border border-transparent hover:bg-purple-50 transition-all duration-200 text-sm shadow-sm">
                            Register
                        </a>
                        <a asp-controller="Login" asp-action="Login" 
                           class="px-4 py-1.5 rounded-sm font-bold text-bookify-600 bg-white border border-transparent hover:bg-purple-50 transition-all duration-200 text-sm shadow-sm">
                            Sign in
                        </a>
                    }
                </div>

                <!-- Mobile menu button -->
                <button @@click="mobileMenuOpen = !mobileMenuOpen" class="md:hidden text-white p-2">
                    <i class="fas fa-bars text-xl"></i>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div x-show="mobileMenuOpen" 
             x-transition:enter="transition ease-out duration-200"
             x-transition:enter-start="opacity-0 transform -translate-y-2"
             x-transition:enter-end="opacity-100 transform translate-y-0"
             class="md:hidden bg-bookify-900 border-t border-bookify-800"
             x-cloak>
            <div class="px-4 py-4 space-y-2">
                <a href="/" class="block text-white font-medium py-2 px-3 rounded-md hover:bg-white/10">Stays</a>
                <a asp-controller="Room" asp-action="Index" class="block text-white font-medium py-2 px-3 rounded-md hover:bg-white/10">Rooms</a>
                <!-- AI Assistant Link for Mobile -->
                <a asp-controller="AIAssistant" asp-action="Index" class="block text-white font-medium py-2 px-3 rounded-md hover:bg-gradient-to-r hover:from-purple-500 hover:to-indigo-500 flex items-center">
                    <i class="fas fa-robot mr-2"></i>
                    AI Assistant
                </a>
                <a asp-controller="About" asp-action="Index" class="block text-white font-medium py-2 px-3 rounded-md hover:bg-white/10">About</a>
                <a asp-controller="Contact" asp-action="Index" class="block text-white font-medium py-2 px-3 rounded-md hover:bg-white/10">Contact</a>
                
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <div class="pt-2 border-t border-white/10 space-y-1">
                        <a asp-controller="Profile" asp-action="Index" class="block text-white py-2 px-3 rounded-md hover:bg-white/10">My Profile</a>
                        <a asp-controller="Booking" asp-action="MyBookings" class="block text-white py-2 px-3 rounded-md hover:bg-white/10">My Bookings</a>
                        <a asp-controller="Favorite" asp-action="Index" class="block text-white py-2 px-3 rounded-md hover:bg-white/10">Favorites</a>
                        <form asp-controller="Login" asp-action="Logout" method="post" class="pt-1">
                            <button type="submit" class="w-full text-left text-red-400 py-2 px-3 rounded-md hover:bg-white/10">Sign out</button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="pt-2 border-t border-white/10 grid grid-cols-2 gap-2">
                        <a asp-controller="Register" asp-action="Register" class="text-center bg-white text-bookify-600 font-semibold py-2 rounded-sm text-sm">Register</a>
                        <a asp-controller="Login" asp-action="Login" class="text-center bg-white text-bookify-600 font-semibold py-2 rounded-sm text-sm">Sign in</a>
                    </div>
                }
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="flex-grow">
        @if (TempData["SuccessMessage"] != null || TempData["Success"] != null || TempData["ErrorMessage"] != null || TempData["Error"] != null)
        {
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4 animate-fade-in">
                @if (TempData["SuccessMessage"] != null || TempData["Success"] != null)
                {
                    <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-md relative flex items-center justify-between shadow-sm" role="alert">
                        <div class="flex items-center">
                            <i class="fas fa-check-circle text-emerald-500 mr-3 text-lg"></i>
                            <span class="text-sm font-medium">@(TempData["SuccessMessage"] ?? TempData["Success"])</span>
                        </div>
                        <button onclick="this.parentElement.remove()" class="text-emerald-500 hover:text-emerald-700 focus:outline-none">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                }
                @if (TempData["ErrorMessage"] != null || TempData["Error"] != null)
                {
                    <div class="bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-md relative flex items-center justify-between shadow-sm" role="alert">
                        <div class="flex items-center">
                            <i class="fas fa-exclamation-circle text-red-500 mr-3 text-lg"></i>
                            <span class="text-sm font-medium">@(TempData["ErrorMessage"] ?? TempData["Error"])</span>
                        </div>
                        <button onclick="this.parentElement.remove()" class="text-red-500 hover:text-red-700 focus:outline-none">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                }
            </div>
        }
        @RenderBody()
    </main>

    <!-- Bookify Modern Footer -->
    <footer class="bg-bookify-900 text-white border-t border-white/10">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <!-- Newsletter -->
            <div class="max-w-xl mx-auto text-center mb-12">
                <h3 class="text-xl font-bold mb-2">Save time, save money!</h3>
                <p class="text-blue-200 mb-4 text-sm">Sign up and we'll send the best deals to you</p>
                <form class="flex gap-1 justify-center">
                    <input type="email" placeholder="Your email address" class="px-4 py-2 w-64 rounded-sm text-gray-900 text-sm focus:outline-none">
                    <button class="bg-bookify-primary hover:bg-bookify-primary-dark text-white px-6 py-2 rounded-sm font-medium text-sm transition-colors">Subscribe</button>
                </form>
            </div>

            <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-8 text-xs">
                <div>
                    <ul class="space-y-2">
                        <li><a href="#" class="hover:underline">Countries</a></li>
                        <li><a href="#" class="hover:underline">Regions</a></li>
                        <li><a href="#" class="hover:underline">Cities</a></li>
                        <li><a href="#" class="hover:underline">Districts</a></li>
                        <li><a href="#" class="hover:underline">Airports</a></li>
                        <li><a href="#" class="hover:underline">Hotels</a></li>
                    </ul>
                </div>
                <div>
                    <ul class="space-y-2">
                        <li><a href="#" class="hover:underline">Homes</a></li>
                        <li><a href="#" class="hover:underline">Apartments</a></li>
                        <li><a href="#" class="hover:underline">Resorts</a></li>
                        <li><a href="#" class="hover:underline">Villas</a></li>
                        <li><a href="#" class="hover:underline">Hostels</a></li>
                        <li><a href="#" class="hover:underline">B&Bs</a></li>
                    </ul>
                </div>
                <div>
                    <ul class="space-y-2">
                        <li><a href="#" class="hover:underline">Unique places to stay</a></li>
                        <li><a href="#" class="hover:underline">Reviews</a></li>
                        <li><a href="#" class="hover:underline">Unpacked: Travel articles</a></li>
                        <li><a href="#" class="hover:underline">Travel communities</a></li>
                        <li><a href="#" class="hover:underline">Seasonal and holiday deals</a></li>
                    </ul>
                </div>
                <div>
                    <ul class="space-y-2">
                        <li><a href="#" class="hover:underline">Car rental</a></li>
                        <li><a href="#" class="hover:underline">Flight Finder</a></li>
                        <li><a href="#" class="hover:underline">Restaurant reservations</a></li>
                        <li><a href="#" class="hover:underline">Bookify for Travel Agents</a></li>
                    </ul>
                </div>
            </div>

            <div class="border-t border-white/10 pt-6 text-center text-[10px] text-blue-200">
                <p class="mb-4">Copyright © 1996–2024 Bookify.hotel™. All rights reserved.</p>
                <div class="flex justify-center space-x-4 opacity-70 grayscale">
                    <img src="https://cf.bstatic.com/static/img/tfl/group_logos/logo_priceline/f80e2f4c30c85cc821104e76cd55bc7b.png" alt="Priceline" class="h-4">
                    <img src="https://cf.bstatic.com/static/img/tfl/group_logos/logo_kayak/194833216897910aa9e3f9453717df20.png" alt="Kayak" class="h-4">
                    <img src="https://cf.bstatic.com/static/img/tfl/group_logos/logo_agoda/1c5211a76d1685324e930f62294c65e8.png" alt="Agoda" class="h-4">
                </div>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    <!-- Alpine.js Cloak Style -->
    <style>
        [x-cloak] { display: none !important; }
    </style>

    @await RenderSectionAsync("Scripts", required: false)
    
    <!-- Sticky Header Scroll Effect -->
    <script>
        let lastScroll = 0;
        const header = document.getElementById('main-header');
        
        window.addEventListener('scroll', () => {
            const currentScroll = window.pageYOffset;
            
            if (currentScroll > 50) {
                header.style.boxShadow = 'var(--shadow-xl)';
                header.style.backdropFilter = 'blur(10px)';
                header.style.backgroundColor = 'rgba(124, 111, 242, 0.95)';
            } else {
                header.style.boxShadow = 'var(--shadow-md)';
                header.style.backdropFilter = 'none';
                header.style.backgroundColor = 'var(--primary-600)';
            }
            
            lastScroll = currentScroll;
        });
    </script>

    <!-- Floating AI Assistant Button -->
    <a href="/aiAssistant" 
       class="fixed bottom-6 right-6 z-50 w-16 h-16 bg-gradient-to-br from-purple-600 to-indigo-600 rounded-full shadow-2xl flex items-center justify-center text-white hover:scale-110 transition-all duration-300 hover:shadow-purple-500/50 group"
       title="AI Assistant - Get instant help">
        <i class="fas fa-robot text-2xl group-hover:animate-bounce"></i>
        <span class="absolute -top-1 -right-1 w-4 h-4 bg-green-500 rounded-full border-2 border-white animate-pulse"></span>
    </a>
</body>
</html>
