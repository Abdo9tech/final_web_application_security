@model BookifyHotel.Model.Booking
@{
    ViewData["Title"] = "Payment Successful";
}

<div class="min-h-screen bg-gradient-to-br from-emerald-50 via-white to-green-50 flex items-center justify-center py-12 px-4">
    <div class="max-w-2xl w-full">
        <div class="bg-white rounded-2xl shadow-2xl p-8 text-center">
            <!-- Success Icon -->
            <div class="mb-6">
                <div class="w-24 h-24 mx-auto bg-emerald-100 rounded-full flex items-center justify-center">
                    <i class="fas fa-check text-emerald-600 text-5xl"></i>
                </div>
            </div>

            <!-- Success Message -->
            <h1 class="text-3xl font-bold text-gray-900 mb-4">Payment Successful!</h1>
            <p class="text-gray-600 mb-8">Your booking has been confirmed. We've sent a confirmation email to your inbox.</p>

            <!-- Booking Details -->
            <div class="bg-gray-50 rounded-xl p-6 mb-8 text-left">
                <h3 class="text-xl font-bold text-gray-900 mb-4">Booking Details</h3>
                <div class="space-y-3">
                    <div class="flex justify-between">
                        <span class="text-gray-600">Booking ID</span>
                        <span class="font-semibold text-gray-900">#@Model.BookingId</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-600">Room</span>
                        <span class="font-semibold text-gray-900">@Model.Room?.RoomType?.Name - Room @Model.Room?.RoomNumber</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-600">Check-in</span>
                        <span class="font-semibold text-gray-900">@Model.CheckInDate.ToString("MMM dd, yyyy")</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-gray-600">Check-out</span>
                        <span class="font-semibold text-gray-900">@Model.CheckOutDate.ToString("MMM dd, yyyy")</span>
                    </div>
                    <div class="flex justify-between pt-3 border-t">
                        <span class="text-gray-900 font-bold">Total Paid</span>
                        <span class="text-emerald-600 font-bold text-xl">$@Model.TotalPrice</span>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex gap-4">
                <a asp-controller="Booking" asp-action="MyBookings" 
                   class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-lg transition duration-200">
                    View My Bookings
                </a>
                <a asp-controller="Home" asp-action="Index" 
                   class="flex-1 bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-3 px-6 rounded-lg transition duration-200">
                    Back to Home
                </a>
            </div>
        </div>
    </div>
</div>
