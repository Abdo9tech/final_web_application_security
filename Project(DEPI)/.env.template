# ------------------------------------------------------------
# BookifyHotel Environment Template
# Copy this file to ".env" and fill in production secrets.
# Never commit .env to source control.
# ------------------------------------------------------------

# App runtime
ASPNETCORE_ENVIRONMENT=Production
APP_PORT=8080
ALLOWED_HOSTS=*

# SQL Server
SQL_DATABASE=BookifyHotelDB
SQL_USER=sa
SQL_PASSWORD=ReplaceWithAStrongPassword_AtLeast16Chars!
SQL_PORT=1433
SQL_ENCRYPT=False
SQL_TRUST_SERVER_CERTIFICATE=True
MSSQL_PID=Developer

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ReplaceWithStrongRedisPassword!
REDIS_CONNECTION=redis:6379,password=ReplaceWithStrongRedisPassword!,abortConnect=false,connectTimeout=5000,syncTimeout=5000

# Stripe
STRIPE_PUBLISHABLE_KEY=pk_live_REPLACE_ME
STRIPE_SECRET_KEY=sk_live_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Default seeded users (change immediately after first login)
ADMIN_EMAIL=admin@bookifyhotel.com
ADMIN_PASSWORD=ReplaceWithStrongAdminPassword!
ADMIN_PHONE=+201234567890
USER_EMAIL=user@bookifyhotel.com
USER_PASSWORD=ReplaceWithStrongUserPassword!
USER_PHONE=+201556677889

# Optional image metadata and registry
DOCKER_REGISTRY=ghcr.io/your-org-or-user
DOCKER_IMAGE_NAME=bookifyhotel
DOCKER_IMAGE_TAG=latest

# Fly.io deployment
FLY_APP_NAME=bookifyhotel
FLY_PRIMARY_REGION=fra
